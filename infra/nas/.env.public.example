NAS_ROOT_PATH=/volume1/docker/georaeplan
HOST_BIND_IP=127.0.0.1
POSTGRES_DB=georaeplan
POSTGRES_USER=georaeplan
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_DB_PASSWORD
POSTGRES_HOST_PORT=15434
ITWORLD_POSTGRES_DB=georaeplan_itworld
API_HOST_PORT=18082

# Preferred: deploy PC triggers apply-release.sh over SSH
NAS_SSH_HOST=
NAS_SSH_PORT=22
NAS_SSH_USER=
# Example: C:\Users\beene\.ssh\tradeplan_nas_ed25519
# Note: this path is on the Windows deploy PC, not on the NAS.
NAS_SSH_KEY_PATH=
NAS_REMOTE_OPS_PATH=/volume1/docker/georaeplan/ops

# Fallback: NAS Task Scheduler polls pending-release.txt and runs auto-apply-release.sh
NAS_SCHEDULED_APPLY_ENABLED=true

JWT_ISSUER=georaeplan
JWT_AUDIENCE=georaeplan-client
JWT_SIGNING_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_JWT_SIGNING_KEY
JWT_EXPIRATION_MINUTES=480
PUBLIC_BASE_URL=https://api.example.invalid
TZ=Asia/Seoul

# Security hardening
SECURITY_ENABLE_RATE_LIMITING=true
SECURITY_LOGIN_PERMIT_LIMIT_PER_MINUTE=10
SECURITY_API_PERMIT_LIMIT_PER_MINUTE=300
SECURITY_ADD_SECURITY_HEADERS=true
SECURITY_REQUIRE_HTTPS_FORWARDED_PROTO=true
SECURITY_ALLOW_ANY_CORS_ORIGIN=false
# Example: https://admin.example.com
SECURITY_ALLOWED_CORS_ORIGIN_0=

# Seed user passwords: blank, CHANGE_THIS_*, or __DISABLE__ means skip creation/update
SEED_USERS_ENABLE_SEED_USERS=true
SEED_USERS_ADMIN_PASSWORD=
SEED_USERS_USER_PASSWORD=
SEED_USERS_ITW_PASSWORD=
SEED_USERS_UPDATE_EXISTING_ITW_PASSWORD=true
SEED_USERS_WARN_ON_DEFAULT_PASSWORDS=true

# Routine ops checks / backup / certificate
DAILY_CHECKS_ENABLED=true
WEEKLY_CHECKS_ENABLED=true
BACKUP_CREATE_ENABLED=true
BACKUP_RETENTION_DAYS=14
BACKUP_MAX_AGE_HOURS=36
FILE_EXPORT_ENABLED=true
EXTERNAL_REPLICA_ENABLED=true
EXTERNAL_REPLICA_PATH="/volume1/???????/???? ??"
EXTERNAL_REPLICA_MIN_AGE_DAYS=1
CERT_RENEW_ENABLED=true
CERT_RENEW_BEFORE_DAYS=30

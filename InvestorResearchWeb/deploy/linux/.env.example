# Investor Research Web Linux PC environment
# Copy to /home/itw/investor-research/.env or /srv/investor-research/.env.
# Keep this file on the server only. Do not expose secrets to the browser build.

INVESTOR_RESEARCH_HOST_PORT=18088
INVESTOR_RESEARCH_HOST_BIND=127.0.0.1
INVESTOR_RESEARCH_IMAGE=investor-research-web:local

# LAN operation:
APP_BASE_URL=http://192.168.0.199:18088
# Public domain operation after DNS/reverse proxy/SSL:
# APP_BASE_URL=https://research.2884.kr

SESSION_SECRET=replace-with-32-byte-random-secret
COOKIE_SECURE=false
AUTH_REQUIRED=true
AUTH_ALLOWED_EMAILS=

# OAuth/OIDC user login.
# Google example:
# 1) Create an OAuth web application client.
# 2) Add redirect URI: http://192.168.0.199:18088/api/auth/callback
#    or https://research.2884.kr/api/auth/callback after public domain setup.
OAUTH_ENABLED=false
OAUTH_PROVIDER=google
OAUTH_PROVIDER_NAME=Google
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://192.168.0.199:18088/api/auth/callback
OAUTH_SCOPES=openid email profile

# Custom provider URLs, if not using the Google shortcut.
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=

# OpenAI Responses API. API keys or WIF access tokens must stay server-side.
OPENAI_API_KEY=
OPENAI_BEARER_TOKEN=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_ENABLE_WEB_SEARCH=true
OPENAI_MAX_OUTPUT_TOKENS=6500

# Optional AI-provider OAuth registration buttons.
# Public-domain callbacks after DNS/proxy setup:
# https://research.2884.kr/api/ai-providers/gpt/oauth/callback
# https://research.2884.kr/api/ai-providers/claude/oauth/callback
# https://research.2884.kr/api/ai-providers/gemini/oauth/callback
# https://research.2884.kr/api/ai-providers/perplexity/oauth/callback
AI_GPT_OAUTH_ENABLED=false
AI_GPT_CLIENT_ID=
AI_GPT_CLIENT_SECRET=
AI_GPT_AUTHORIZATION_URL=
AI_GPT_TOKEN_URL=
AI_GPT_USERINFO_URL=
AI_GPT_SCOPES=openid email profile
AI_GPT_REDIRECT_URI=http://192.168.0.199:18088/api/ai-providers/gpt/oauth/callback

AI_CLAUDE_OAUTH_ENABLED=false
AI_CLAUDE_CLIENT_ID=
AI_CLAUDE_CLIENT_SECRET=
AI_CLAUDE_AUTHORIZATION_URL=
AI_CLAUDE_TOKEN_URL=
AI_CLAUDE_USERINFO_URL=
AI_CLAUDE_SCOPES=openid email profile
AI_CLAUDE_REDIRECT_URI=http://192.168.0.199:18088/api/ai-providers/claude/oauth/callback

AI_GEMINI_OAUTH_ENABLED=false
AI_GEMINI_CLIENT_ID=
AI_GEMINI_CLIENT_SECRET=
AI_GEMINI_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
AI_GEMINI_TOKEN_URL=https://oauth2.googleapis.com/token
AI_GEMINI_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
AI_GEMINI_SCOPES=openid email profile
AI_GEMINI_REDIRECT_URI=http://192.168.0.199:18088/api/ai-providers/gemini/oauth/callback

AI_PERPLEXITY_OAUTH_ENABLED=false
AI_PERPLEXITY_CLIENT_ID=
AI_PERPLEXITY_CLIENT_SECRET=
AI_PERPLEXITY_AUTHORIZATION_URL=
AI_PERPLEXITY_TOKEN_URL=
AI_PERPLEXITY_USERINFO_URL=
AI_PERPLEXITY_SCOPES=openid email profile
AI_PERPLEXITY_REDIRECT_URI=http://192.168.0.199:18088/api/ai-providers/perplexity/oauth/callback

# Optional future data APIs.
OPENDART_API_KEY=
KRX_API_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=

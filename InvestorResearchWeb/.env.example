# Local development notes
# Vite dev mode serves only the frontend. Run `npm run build && npm start`
# to test the Node API server locally.

APP_BASE_URL=http://127.0.0.1:8080
SESSION_SECRET=replace-with-32-byte-random-secret
COOKIE_SECURE=false
AUTH_REQUIRED=true
AUTH_ALLOWED_EMAILS=

# OAuth/OIDC user login. Google is supported by setting OAUTH_PROVIDER=google.
OAUTH_ENABLED=false
OAUTH_PROVIDER=google
OAUTH_PROVIDER_NAME=Google
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:8080/api/auth/callback
OAUTH_SCOPES=openid email profile

# For custom OAuth/OIDC providers, set these URLs.
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=

# OpenAI credentials stay on the server only.
# OpenAI API calls use Bearer credentials from API keys or WIF access tokens.
OPENAI_API_KEY=
OPENAI_BEARER_TOKEN=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_ENABLE_WEB_SEARCH=true
OPENAI_MAX_OUTPUT_TOKENS=6500

# Optional AI-provider OAuth registration buttons.
# These are for linking provider accounts in the UI. Model API keys still stay server-side.
AI_GPT_OAUTH_ENABLED=false
AI_GPT_CLIENT_ID=
AI_GPT_CLIENT_SECRET=
AI_GPT_AUTHORIZATION_URL=
AI_GPT_TOKEN_URL=
AI_GPT_USERINFO_URL=
AI_GPT_SCOPES=openid email profile
AI_GPT_REDIRECT_URI=http://127.0.0.1:8080/api/ai-providers/gpt/oauth/callback

AI_CLAUDE_OAUTH_ENABLED=false
AI_CLAUDE_CLIENT_ID=
AI_CLAUDE_CLIENT_SECRET=
AI_CLAUDE_AUTHORIZATION_URL=
AI_CLAUDE_TOKEN_URL=
AI_CLAUDE_USERINFO_URL=
AI_CLAUDE_SCOPES=openid email profile
AI_CLAUDE_REDIRECT_URI=http://127.0.0.1:8080/api/ai-providers/claude/oauth/callback

AI_GEMINI_OAUTH_ENABLED=false
AI_GEMINI_CLIENT_ID=
AI_GEMINI_CLIENT_SECRET=
AI_GEMINI_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
AI_GEMINI_TOKEN_URL=https://oauth2.googleapis.com/token
AI_GEMINI_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
AI_GEMINI_SCOPES=openid email profile
AI_GEMINI_REDIRECT_URI=http://127.0.0.1:8080/api/ai-providers/gemini/oauth/callback

AI_PERPLEXITY_OAUTH_ENABLED=false
AI_PERPLEXITY_CLIENT_ID=
AI_PERPLEXITY_CLIENT_SECRET=
AI_PERPLEXITY_AUTHORIZATION_URL=
AI_PERPLEXITY_TOKEN_URL=
AI_PERPLEXITY_USERINFO_URL=
AI_PERPLEXITY_SCOPES=openid email profile
AI_PERPLEXITY_REDIRECT_URI=http://127.0.0.1:8080/api/ai-providers/perplexity/oauth/callback

VITE_APP_DATA_MODE=demo

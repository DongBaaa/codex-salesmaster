# Local development notes
# Vite dev mode serves only the frontend. Run `npm run build && npm start`
# to test the Node API server locally.

APP_BASE_URL=http://127.0.0.1:8080
SESSION_SECRET=replace-with-32-byte-random-secret
COOKIE_SECURE=false
AUTH_REQUIRED=true
AUTH_ALLOWED_EMAILS=

# OAuth/OIDC user login. Google is supported by setting OAUTH_PROVIDER=google.
OAUTH_ENABLED=false
OAUTH_PROVIDER=google
OAUTH_PROVIDER_NAME=Google
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:8080/api/auth/callback
OAUTH_SCOPES=openid email profile

# For custom OAuth/OIDC providers, set these URLs.
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=

# OpenAI credentials stay on the server only.
# OpenAI API calls use Bearer credentials from API keys or WIF access tokens.
OPENAI_API_KEY=
OPENAI_BEARER_TOKEN=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_ENABLE_WEB_SEARCH=true
OPENAI_MAX_OUTPUT_TOKENS=6500

VITE_APP_DATA_MODE=demo

<Window x:Class="거래플랜.Desktop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:거래플랜.Desktop.App.Converters"
        Title="거래플랜" Height="860" Width="1440"
        WindowStartupLocation="CenterScreen"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:DecimalToStringConverter x:Key="DecimalToString"/>
        <conv:VoucherTypeConverter x:Key="VoucherTypeConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="CopyablePreviewCustomerNameTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CaretBrush" Value="#4FC3F7"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>
        <Style x:Key="InvoiceListCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="InvoiceListColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#151F2E"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#9FB3C8"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0"
                                Margin="0,0,2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#29466E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A2B4A" Padding="16,10" BorderBrush="#2E4060" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="거래플랜" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,0,14,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 재고/거래처 그룹 -->
                    <Button Content="품목/재고 관리" Background="#1B5E20" Margin="0,0,6,0" Click="InventoryButton_Click"
                            ToolTip="품목 등록, 가격, 재고 수량과 이동 내역을 관리합니다."/>
                    <Button x:Name="NewRentalCustomerButton" Content="신규 렌탈 등록" Background="#00897B" Margin="0,0,6,0" Click="NewRentalCustomerButton_Click"
                            ToolTip="신규 렌탈 거래처와 청구/장비 연결을 단계별로 등록합니다."/>
                    <Button x:Name="CustomerSettingsButton" Content="거래처 관리" Background="#6D4C41" Margin="0,0,6,0" Click="CustomerSettingsButton_Click"
                            ToolTip="거래처 등록, 삭제, 담당지점 관리를 선택합니다.">
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom" PlacementTarget="{Binding ElementName=CustomerSettingsButton}">
                                <MenuItem Header="거래처 등록" Click="CustomerRegisterMenuItem_Click"/>
                                <MenuItem Header="거래처 삭제" Click="CustomerDeleteMenuItem_Click"/>
                                <MenuItem Header="거래처 관리" Click="CustomerManagementMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="#3E5875" Margin="4,0,10,0" VerticalAlignment="Center"/>
                    <!-- 집계/설정 그룹 -->
                    <Button Content="매입/매출 장부" Background="#5E35B1" Margin="0,0,6,0" Click="YeonsuDeliveryButton_Click"
                            ToolTip="매입·매출 전표를 기간/구분별 장부 형태로 조회합니다."/>
                    <Button Content="기간별 집계" Background="#6A1B9A" Margin="0,0,6,0" Click="PeriodLedgerButton_Click"
                            ToolTip="거래처별 집계, 판매/구매/수금·지급 원장을 조회합니다."/>
                    <Button x:Name="RentalManagementButton" Content="렌탈 업무" Background="#1565C0" Margin="0,0,6,0" Click="RentalManagementButton_Click"
                            ToolTip="렌탈 대시보드, 청구관리, 자산/설치현황, 기준설정을 선택합니다.">
                        <Button.ContextMenu>
                            <ContextMenu Placement="Bottom" PlacementTarget="{Binding ElementName=RentalManagementButton}">
                                <MenuItem Header="렌탈 대시보드" Click="RentalDashboardMenuItem_Click"/>
                                <MenuItem Header="렌탈 청구관리" Click="RentalBillingMenuItem_Click"/>
                                <MenuItem Header="렌탈 자산 / 설치현황" Click="RentalAssetMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="렌탈 기준설정" Click="RentalSettingsMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="#3E5875" Margin="4,0,10,0" VerticalAlignment="Center"/>
                    <Button Content="환경설정" Background="#546E7A" Margin="0,0,6,0" Click="EnvironmentSettingsButton_Click"
                            ToolTip="회사설정, 사용자 권한, 기준정보, 휴지통을 관리합니다."/>
                    <Grid Margin="0,0,6,0">
                        <Button Content="휴지통" Background="#6D4C41" Click="RecycleBinButton_Click"
                                ToolTip="삭제 보관된 데이터를 확인하고 복구/영구삭제를 처리합니다."/>
                        <Border Background="#C62828"
                                CornerRadius="10"
                                Padding="6,1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-4,-4,0"
                                Visibility="{Binding HasDashboardRecycleBinItems, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding DashboardRecycleBinCount}"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"/>
                        </Border>
                    </Grid>
                    <Rectangle Width="1" Height="20" Fill="#3E5875" Margin="4,0,10,0" VerticalAlignment="Center"/>
                    <!-- 사용자 그룹 -->
                    <TextBlock Text="{Binding CurrentUserDisplay}" Foreground="#9FB3C8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="로그아웃" Background="#6C5B7B" Click="LogoutButton_Click"
                            ToolTip="현재 계정에서 로그아웃하고 로그인 화면으로 돌아갑니다."/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="#17324F"
                BorderBrush="#2E5C82"
                BorderThickness="0,0,0,1"
                Padding="14,8"
                Visibility="{Binding IsDesktopUpdateBannerVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="업데이트"
                           Foreground="#4FC3F7"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DesktopUpdateVersionText}"
                               Foreground="#EAF2FF"
                               FontWeight="Bold"
                               FontSize="13"/>
                    <TextBlock Text="{Binding DesktopUpdateStatusText}"
                               Foreground="#B7C8DA"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="2"
                        Content="{Binding DesktopUpdateActionText}"
                        Command="{Binding StartPreparedDesktopUpdateCommand}"
                        Background="#00897B"
                        Margin="14,0,6,0"
                        MinWidth="116"/>
                <Button Grid.Column="3"
                        Content="나중에"
                        Command="{Binding DismissDesktopUpdateBannerCommand}"
                        Background="#546E7A"
                        MinWidth="76"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Background="#122038" Padding="12,10" BorderBrush="#2E4060" BorderThickness="0,0,0,1">
            <UniformGrid Columns="9">
                <Border Background="Transparent" Margin="0,0,8,0" CornerRadius="6" Padding="10"/>
                <Border Background="Transparent" Margin="0,0,8,0" CornerRadius="6" Padding="10"/>
                <Border Background="Transparent" Margin="0,0,8,0" CornerRadius="6" Padding="10"/>
                <Border Background="Transparent" Margin="0,0,8,0" CornerRadius="6" Padding="10"/>
                <Border Background="Transparent" Margin="0,0,8,0" CornerRadius="6" Padding="10"/>
                <Border Background="Transparent" Margin="0,0,8,0" CornerRadius="6" Padding="10"/>
                <Border Background="Transparent" Margin="0,0,8,0" CornerRadius="6" Padding="10"/>
                <Border Background="Transparent" Margin="0,0,8,0" CornerRadius="6" Padding="10"/>
                <Border Background="#1A2B4A" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <TextBlock Text="렌탈 예정 / 지연" Foreground="#9FB3C8" FontSize="11"/>
                        <TextBlock Text="{Binding DashboardRentalUpcomingCount, StringFormat={}{0:N0} 건 예정}" Foreground="#A5D6A7" FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="{Binding DashboardRentalOverdueCount, StringFormat=지연 {0:N0}건}" Foreground="#EF9A9A" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <Border DockPanel.Dock="Top" Background="#102039" Padding="12,10" BorderBrush="#2E4060" BorderThickness="0,0,0,1">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="계약서 알림" Foreground="#4FC3F7" FontWeight="Bold"/>
                        <TextBlock Text="{Binding DashboardContractAlertSummary}" Foreground="#9FB3C8" Margin="12,0,0,0"/>
                    </StackPanel>

                    <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1E3A5F" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding DashboardCustomersWithContractsCount, StringFormat=계약서 {0:N0}곳}"
                                       Foreground="#B3E5FC"
                                       FontSize="11"
                                       FontWeight="Bold"/>
                        </Border>
                        <Border Background="#7F1D1D" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding DashboardContractExpiredCount, StringFormat=만료 {0:N0}건}"
                                       Foreground="#FFCDD2"
                                       FontSize="11"
                                       FontWeight="Bold"/>
                        </Border>
                        <Border Background="#7C2D12" CornerRadius="12" Padding="10,4">
                            <TextBlock Text="{Binding DashboardContractExpiringSoonCount, StringFormat=30일 내 {0:N0}건}"
                                       Foreground="#FFE0B2"
                                       FontSize="11"
                                       FontWeight="Bold"/>
                        </Border>
                    </WrapPanel>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding DashboardContractAlerts}"
                              Margin="0,8,0,0"
                              Visibility="{Binding HasDashboardContractAlerts, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A2B4A"
                                    BorderBrush="#2E4060"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    Margin="0,0,8,6"
                                    Width="236">
                                <StackPanel>
                                    <TextBlock Text="{Binding CustomerName}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ContractType}" Foreground="#90CAF9" FontSize="11" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding AlertText}" Foreground="#FFCC80" FontSize="11" Margin="0,1,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#0D1B2A" Padding="10,6"><TextBlock Text="{Binding SyncStatus}" Foreground="#9FB3C8" FontSize="11"/></Border>

        <DockPanel Margin="10">
                    <Border DockPanel.Dock="Top" Background="#1A2B4A" Padding="10" CornerRadius="6" Margin="0,0,0,8">
                        <WrapPanel>
                            <TextBlock Text="유형" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding VoucherTypeFilterOptions}" SelectedItem="{Binding SelectedVoucherTypeFilter}" Width="100" Margin="0,0,10,0"/>

                            <TextBlock Text="담당지점" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding InvoiceOfficeFilterOptions}"
                                      SelectedValue="{Binding SelectedInvoiceOfficeFilterCode}"
                                      SelectedValuePath="Code"
                                      DisplayMemberPath="DisplayName"
                                      Width="120"
                                      Margin="0,0,10,0"/>

                            <Button Content="조회" Background="#37474F" Command="{Binding LoadInvoiceListCommand}" Margin="0,0,6,0"/>
                            <Button Content="필터초기화" Background="#455A64" Command="{Binding ResetInvoiceFiltersCommand}" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding FavoriteInvoices}" SelectedItem="{Binding SelectedFavoriteInvoice}" DisplayMemberPath="DisplayText" Width="380" Margin="0,0,6,0"/>
                            <Button Content="즐겨찾기 이동" Background="#546E7A" Command="{Binding OpenFavoriteInvoiceCommand}" Margin="0,0,6,0"/>
                            <Button Content="즐겨찾기 추가/해제" Background="#6D4C41" Command="{Binding ToggleInvoiceFavoriteCommand}" Margin="0,0,6,0"/>

                            <Rectangle Width="1" Height="22" Fill="#3E5875" Margin="8,0,12,0" VerticalAlignment="Center"/>

                            <Button Content="판매작성" Background="#1565C0" Click="SalesToolbarButton_Click" Margin="0,0,6,0"/>
                            <Button Content="구매작성" Background="#0277BD" Click="PurchaseToolbarButton_Click" Margin="0,0,6,0"/>
                            <Button Content="견적/발주" Background="#455A64" Click="ProcurementToolbarButton_Click" Margin="0,0,6,0"/>
                            <Button Content="삭제" Background="#E53935" Command="{Binding DeleteInvoiceCommand}" Margin="0,0,6,0"/>
                            <Button Content="수금 입력" Background="#00897B" Click="PaymentEntryButton_Click" Margin="0,0,6,0"/>
                            <Button Content="전표 인쇄[F9]" Background="#1E88E5" Command="{Binding PrintStatementCommand}"/>
                        </WrapPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#102039" CornerRadius="6,6,0,0" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="거래처 목록" Foreground="#4FC3F7" FontWeight="Bold"/>
                                        <TextBox Text="{Binding CustomerFilterText, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,8,0,0"
                                                 ToolTip="상호, 전화, 휴대폰, 사업자번호, 담당자, 담당지점, 메모로 검색할 수 있습니다."/>
                                        <TextBlock Text="상호/전화/사업자번호/담당자 검색"
                                                   Foreground="#90CAF9"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"/>
                                        <Button Content="전체 보기" Background="#2E4158" Command="{Binding ClearCustomerFilterCommand}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ListBox ItemsSource="{Binding FilteredCustomers}" SelectedItem="{Binding SelectedCustomerFilter}" Background="Transparent" BorderThickness="0" PreviewMouseRightButtonDown="CustomerListBox_PreviewMouseRightButtonDown" MouseDoubleClick="CustomerListBox_MouseDoubleClick">
                                    <ListBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="거래처 수정" Click="CustomerEditContextMenu_Click"/>
                                            <MenuItem Header="거래처 삭제" Click="CustomerDeleteContextMenu_Click"/>
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="8,6"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding NameOriginal}" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" TextTrimming="CharacterEllipsis"/></DataTemplate></ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="8" Background="#0D1B2A"/>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="220"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#1A2B4A"
                                    BorderBrush="#2E4060"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <DataGrid ItemsSource="{Binding InvoiceRows}"
                                          SelectedItem="{Binding SelectedInvoiceRow}"
                                          IsReadOnly="True"
                                          BorderThickness="0"
                                          GridLinesVisibility="All"
                                          HorizontalGridLinesBrush="#2E4060"
                                          VerticalGridLinesBrush="#2E4060"
                                          CellStyle="{StaticResource InvoiceListCellStyle}"
                                          ColumnHeaderStyle="{StaticResource InvoiceListColumnHeaderStyle}"
                                          PreviewMouseRightButtonDown="InvoiceRowsDataGrid_PreviewMouseRightButtonDown"
                                          MouseDoubleClick="InvoiceRowsDataGrid_MouseDoubleClick"
                                          SelectionMode="Extended"
                                          SelectionUnit="FullRow">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="선택한 전표 삭제" Click="DeleteSelectedInvoicesContextMenu_Click"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="일자" Binding="{Binding InvoiceDateDisplay}" Width="98"/>
                                        <DataGridTextColumn Header="세금계산서" Binding="{Binding TaxInvoiceDisplay}" Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                    <Setter Property="Foreground" Value="#A5D6A7"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="Black"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.CellStyle>
                                                <Style TargetType="DataGridCell" BasedOn="{StaticResource InvoiceListCellStyle}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.CellStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding PrimaryColumnText}" Width="2*">
                                            <DataGridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DataContext.InvoicePrimaryColumnHeader, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                                </DataTemplate>
                                            </DataGridTextColumn.HeaderTemplate>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="유형" Binding="{Binding VoucherTypeDisplay}" Width="70"/>
                                        <DataGridTextColumn Header="입고상태" Binding="{Binding PurchaseReceivingDisplay}" Width="110"/>
                                        <DataGridTextColumn Header="공급가" Binding="{Binding SupplyAmount, StringFormat=N0}" Width="100"/>
                                        <DataGridTextColumn Header="부가세" Binding="{Binding VatAmount, StringFormat=N0}" Width="90"/>
                                        <DataGridTextColumn Header="합계" Binding="{Binding TotalAmount, StringFormat=N0}" Width="100"/>
                                        <DataGridTextColumn Header="수금액" Binding="{Binding ReceiptAmount, StringFormat=N0}" Width="90"/>
                                        <DataGridTextColumn Header="지급액" Binding="{Binding PaymentAmount, StringFormat=N0}" Width="90"/>
                                        <DataGridTextColumn Header="잔액" Binding="{Binding BalanceAmount, StringFormat=N0}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <GridSplitter Grid.Row="1" Height="8" Background="#0D1B2A"/>

                            <Border Grid.Row="2" Background="#1A2B4A" CornerRadius="6">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#102039" CornerRadius="6,6,0,0" Padding="10,7">
                                        <TextBlock Text="선택 전표 라인 미리보기" Foreground="#4FC3F7" FontWeight="Bold"/>
                                    </Border>
                                    <Border DockPanel.Dock="Bottom" Padding="10,8" BorderBrush="#2E4060" BorderThickness="0,1,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="공급가" Foreground="#9FB3C8" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding PreviewSupplyAmount, StringFormat=N0}" Width="90" TextAlignment="Right"/>
                                            <TextBlock Text="원" Margin="2,0,16,0"/>
                                            <TextBlock Text="부가세" Foreground="#9FB3C8" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding PreviewVatAmount, StringFormat=N0}" Width="80" TextAlignment="Right"/>
                                            <TextBlock Text="원" Margin="2,0,16,0"/>
                                            <TextBlock Text="합계" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding PreviewTotalAmount, StringFormat=N0}" Foreground="#4FC3F7" FontWeight="Bold" Width="100" TextAlignment="Right"/>
                                            <TextBlock Text="원" Foreground="#4FC3F7" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding PreviewLines}" IsReadOnly="True" BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="품목" Binding="{Binding ItemName}" Width="*"/>
                                            <DataGridTextColumn Header="규격" Binding="{Binding Specification}" Width="120"/>
                                            <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="70"/>
                                            <DataGridTextColumn Header="수량" Binding="{Binding Quantity, StringFormat=N0}" Width="80"/>
                                            <DataGridTextColumn Header="단가" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100"/>
                                            <DataGridTextColumn Header="금액" Binding="{Binding LineAmount, StringFormat=N0}" Width="100"/>
                                            <DataGridTextColumn Header="비고" Binding="{Binding Remark}" Width="140"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <GridSplitter Grid.Column="3" Width="8" Background="#0D1B2A"/>

                        <Border Grid.Column="4"
                                Background="#1A2B4A"
                                BorderBrush="#2E4060"
                                BorderThickness="1"
                                CornerRadius="6">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#102039" CornerRadius="6,6,0,0" Padding="10,8"><TextBlock Text="거래처 정보" Foreground="#4FC3F7" FontWeight="Bold"/></Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="10,8">
                                        <TextBlock Text="상호" FontSize="11" Foreground="#9FB3C8"/>
                                        <TextBox Text="{Binding PreviewCustomerName, Mode=OneWay}"
                                                 Style="{StaticResource CopyablePreviewCustomerNameTextBoxStyle}"
                                                 IsReadOnly="True"
                                                 IsReadOnlyCaretVisible="True"
                                                 ToolTip="거래처명을 선택해 복사할 수 있습니다."
                                                 Margin="0,4,0,8"/>
                                        <TextBlock Text="{Binding CustomerInlineSaveStatus}"
                                                   Foreground="#A5D6A7"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="사업자번호" FontSize="11" Foreground="#9FB3C8"/>
                                        <TextBox Text="{Binding EditCustBizNumber, UpdateSourceTrigger=LostFocus}"
                                                 IsReadOnly="{Binding IsPreviewCustomerInfoReadOnly}"
                                                 IsReadOnlyCaretVisible="True"
                                                 Margin="0,4,0,8"/>
                                        <TextBlock Text="전화" FontSize="11" Foreground="#9FB3C8"/>
                                        <TextBox Text="{Binding EditCustPhone, UpdateSourceTrigger=LostFocus}"
                                                 IsReadOnly="{Binding IsPreviewCustomerInfoReadOnly}"
                                                 IsReadOnlyCaretVisible="True"
                                                 Margin="0,4,0,8"/>
                                        <TextBlock Text="담당자" FontSize="11" Foreground="#9FB3C8"/>
                                        <TextBox Text="{Binding EditCustContactPerson, UpdateSourceTrigger=LostFocus}"
                                                 IsReadOnly="{Binding IsPreviewCustomerInfoReadOnly}"
                                                 IsReadOnlyCaretVisible="True"
                                                 Margin="0,4,0,8"/>
                                        <TextBlock Text="주소" FontSize="11" Foreground="#9FB3C8"/>
                                        <TextBox Text="{Binding EditCustAddress, UpdateSourceTrigger=LostFocus}"
                                                 IsReadOnly="{Binding IsPreviewCustomerInfoReadOnly}"
                                                 IsReadOnlyCaretVisible="True"
                                                 TextWrapping="Wrap"
                                                 Margin="0,4,0,8"/>
                                        <TextBlock Text="메모" FontSize="11" Foreground="#9FB3C8"/>
                                        <TextBox Text="{Binding EditCustNotes, UpdateSourceTrigger=LostFocus}"
                                                 IsReadOnly="{Binding IsPreviewCustomerInfoReadOnly}"
                                                 IsReadOnlyCaretVisible="True"
                                                 Height="112"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Margin="0,4,0,0"/>

                                        <Border Margin="0,10,0,0"
                                                Padding="10,8"
                                                Background="#162642"
                                                BorderBrush="#2E4060"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="118"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="선수금" Foreground="#9FB3C8" Margin="0,0,12,0"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewCustomerAdvanceBalance, StringFormat={}{0:N0}원}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="미수금" Foreground="#9FB3C8" Margin="0,6,12,0"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewCustomerReceivableBalance, StringFormat={}{0:N0}원}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="미지급금" Foreground="#9FB3C8" Margin="0,6,12,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewCustomerPayableBalance, StringFormat={}{0:N0}원}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="선지급금" Foreground="#9FB3C8" Margin="0,6,12,0"/>
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PreviewCustomerPrepaymentBalance, StringFormat={}{0:N0}원}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,6,0,0"/>
                                            </Grid>
                                        </Border>
                                        <Border Margin="0,10,0,0"
                                                Padding="10,8"
                                                Background="#162642"
                                                BorderBrush="#2E4060"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="118"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="최근 렌탈 청구" Foreground="#4FC3F7" FontWeight="Bold"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="청구일" Foreground="#9FB3C8" Margin="0,8,12,0"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewLatestRentalInvoiceDateText}" HorizontalAlignment="Right" Margin="0,8,0,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="거래내역" Foreground="#9FB3C8" Margin="0,6,12,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewLatestRentalItemSummary}" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="청구금액 / 미수금" Foreground="#9FB3C8" Margin="0,6,12,0"/>
                                                <Grid Grid.Row="3" Grid.Column="1"
                                                      MinWidth="180"
                                                      HorizontalAlignment="Right"
                                                      Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding PreviewLatestRentalInvoiceAmount, StringFormat={}{0:N0}원}" FontWeight="Bold" TextAlignment="Right"/>
                                                    <TextBlock Grid.Column="1" Text=" / " Margin="4,0"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding PreviewRentalOutstandingAmount, StringFormat={}{0:N0}원}" FontWeight="Bold" Foreground="#FFB74D" TextAlignment="Right"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Button Content="계약서 보기"
                                                Margin="0,10,0,0"
                                                HorizontalAlignment="Stretch"
                                                Background="#355C7D"
                                                Command="{Binding OpenPreviewCustomerContractCommand}"
                                                IsEnabled="{Binding HasPreviewCustomerContract}"
                                                ToolTip="{Binding PreviewCustomerContractButtonToolTip}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
    </DockPanel>
</Window>

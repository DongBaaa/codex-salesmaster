<Window x:Class="거래플랜.Desktop.App.Views.DataIntegrityIssueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="운영 점검 상세" Width="1540" Height="900" MinWidth="1260" MinHeight="760"
        WindowStartupLocation="CenterOwner" Background="#0B1628" KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Foreground" Value="#DDEBFF"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E5C7D"/>
            <Setter Property="BorderBrush" Value="#4C6F91"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#DDE7F2"/>
            <Setter Property="Foreground" Value="#071222"/>
            <Setter Property="BorderBrush" Value="#405D7A"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#DDE7F2"/>
            <Setter Property="Foreground" Value="#071222"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowBackground" Value="#E6F0FA"/>
            <Setter Property="AlternatingRowBackground" Value="#D4E2F0"/>
            <Setter Property="Foreground" Value="#071222"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#20344F"/>
            <Setter Property="Foreground" Value="#66D9FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style TargetType="Border" x:Key="PanelBorder">
            <Setter Property="Background" Value="#14243A"/>
            <Setter Property="BorderBrush" Value="#2A4666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="운영 점검 상세" FontSize="30" FontWeight="Bold" Foreground="#5BD4FF"/>
                    <TextBlock Text="동기화 후 확인된 데이터 위험 신호를 목록으로 보고 원본 화면으로 바로 이동합니다." FontSize="15" Foreground="#B8C7D8" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding ScanSummaryText}" FontSize="13" Foreground="#FFD56B" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="새로고침(F5)" Command="{Binding RefreshCommand}" Background="#1976A8"/>
                    <Button Content="엑셀 저장" Command="{Binding ExportExcelCommand}" Background="#1565C0"/>
                    <Button Content="닫기(F12)" Click="CloseButton_Click" Background="#455A64"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="유형" Foreground="#8FB6D8" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding IssueTypeOptions}" SelectedItem="{Binding SelectedIssueType, Mode=TwoWay}" DisplayMemberPath="DisplayName"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="등급" Foreground="#8FB6D8" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding SeverityOptions}" SelectedItem="{Binding SelectedSeverity, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="검색" Foreground="#8FB6D8" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <DataGrid ItemsSource="{Binding Issues}"
                          SelectedItem="{Binding SelectedIssue, Mode=TwoWay}"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="등급" Binding="{Binding SeverityDisplay}" Width="70"/>
                        <DataGridTextColumn Header="유형" Binding="{Binding Title}" Width="190"/>
                        <DataGridTextColumn Header="거래처" Binding="{Binding CustomerName}" Width="180"/>
                        <DataGridTextColumn Header="품목" Binding="{Binding ItemName}" Width="170"/>
                        <DataGridTextColumn Header="자산" Binding="{Binding AssetDisplayName}" Width="220"/>
                        <DataGridTextColumn Header="지점" Binding="{Binding OfficeCode}" Width="90"/>
                        <DataGridTextColumn Header="현재값" Binding="{Binding CurrentValue}" Width="220"/>
                        <DataGridTextColumn Header="기준값" Binding="{Binding ExpectedValue}" Width="220"/>
                        <DataGridTextColumn Header="판단/참조" Binding="{Binding ReviewInfoDisplay}" Width="380"/>
                        <DataGridTextColumn Header="내용" Binding="{Binding Message}" Width="420"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="선택 항목" FontSize="20" FontWeight="Bold" Foreground="#61D4FF" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedIssue}">
                            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#EAF4FF" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Message}" Foreground="#B8C7D8" TextWrapping="Wrap" Margin="0,8,0,16"/>

                            <TextBlock Text="수정 방향" Foreground="#8FB6D8"/>
                            <TextBlock Text="{Binding SuggestedAction}" Foreground="#7FD0FF" TextWrapping="Wrap" Margin="0,4,0,16"/>

                            <TextBlock Text="삭제/병합 판단 정보" Foreground="#8FB6D8"/>
                            <TextBlock Text="{Binding ReviewInfoDisplay}" Foreground="#FFD56B" TextWrapping="Wrap" Margin="0,4,0,16"/>

                            <TextBlock Text="관련 후보 ID" Foreground="#8FB6D8"/>
                            <TextBlock Text="{Binding RelatedEntityIdText}" Foreground="#B8C7D8" TextWrapping="Wrap" Margin="0,4,0,16"/>

                            <TextBlock Text="거래처" Foreground="#8FB6D8"/>
                            <TextBlock Text="{Binding CustomerName}" Foreground="#EAF4FF" Margin="0,4,0,12"/>
                            <TextBlock Text="품목" Foreground="#8FB6D8"/>
                            <TextBlock Text="{Binding ItemName}" Foreground="#EAF4FF" Margin="0,4,0,12"/>
                            <TextBlock Text="자산" Foreground="#8FB6D8"/>
                            <TextBlock Text="{Binding AssetDisplayName}" Foreground="#EAF4FF" TextWrapping="Wrap" Margin="0,4,0,12"/>
                            <TextBlock Text="현재값" Foreground="#8FB6D8"/>
                            <TextBlock Text="{Binding CurrentValue}" Foreground="#FFD56B" TextWrapping="Wrap" Margin="0,4,0,12"/>
                            <TextBlock Text="기준값" Foreground="#8FB6D8"/>
                            <TextBlock Text="{Binding ExpectedValue}" Foreground="#B8FFB2" TextWrapping="Wrap" Margin="0,4,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="{Binding SelectedIssue.MergeActionText, FallbackValue=중복 병합}"
                                Click="MergeSelectedButton_Click"
                                IsEnabled="{Binding SelectedIssue.CanMergeDuplicates}"
                                Background="#7B5E00"/>
                        <Button Content="바로 수정" Click="FixSelectedButton_Click" Background="#00897B"/>
                        <Button Content="닫기" Click="CloseButton_Click" Background="#455A64"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#0E1D31" BorderBrush="#2A4666" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#B8C7D8"/>
        </Border>
    </Grid>
</Window>

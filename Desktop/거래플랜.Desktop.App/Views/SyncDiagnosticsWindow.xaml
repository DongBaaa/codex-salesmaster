<Window x:Class="거래플랜.Desktop.App.Views.SyncDiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="동기화 진단"
        Height="980"
        Width="1600"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A2B4A"
                Padding="12"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="동기화 진단" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7"/>
                    <TextBlock Text="동기화 실패 원인, 서버/로컬 무결성, sync outbox 재시도 상태를 한 화면에서 확인합니다."
                               Foreground="#9FB3C8"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding SummaryStatusText}" Foreground="#90CAF9" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="새로고침(F5)" Background="#37474F" Command="{Binding RefreshCommand}" Margin="0,0,6,0"/>
                    <Button Content="동기화 재시도" Background="#1565C0" Command="{Binding RetrySyncCommand}" Margin="0,0,6,0"/>
                    <Button Content="공유 캐시 재구성" Background="#0277BD" Command="{Binding RebuildSharedCacheCommand}" Margin="0,0,6,0"/>
                    <Button Content="선택 오류 복구" Background="#00897B" Command="{Binding RunSelectedRepairCommand}" Margin="0,0,6,0"/>
                    <Button Content="전체 자동 복구" Background="#2E7D32" Command="{Binding RunAutoRepairCommand}" Margin="0,0,6,0"/>
                    <Button Content="닫기(F12)" Background="#6C5B7B" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#102039" CornerRadius="8" Padding="14" BorderBrush="#2E4060" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="미해결 오류" Foreground="#9FB3C8" FontSize="12"/>
                    <TextBlock Text="{Binding OpenIssueCount, StringFormat={}{0:N0}건}" FontSize="28" FontWeight="Bold" Foreground="#FFCC80" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#102039" CornerRadius="8" Padding="14" BorderBrush="#2E4060" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="자동 복구 가능" Foreground="#9FB3C8" FontSize="12"/>
                    <TextBlock Text="{Binding RecoverableIssueCount, StringFormat={}{0:N0}건}" FontSize="28" FontWeight="Bold" Foreground="#90CAF9" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="#102039" CornerRadius="8" Padding="14" BorderBrush="#2E4060" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="수동 확인 필요" Foreground="#9FB3C8" FontSize="12"/>
                    <TextBlock Text="{Binding ManualReviewIssueCount, StringFormat={}{0:N0}건}" FontSize="28" FontWeight="Bold" Foreground="#EF9A9A" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Background="#102039" CornerRadius="8" Padding="14" BorderBrush="#2E4060" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="마지막 성공" Foreground="#9FB3C8" FontSize="12"/>
                    <TextBlock Text="{Binding LastSuccessText}" FontSize="18" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="8" Background="#102039" CornerRadius="8" Padding="14" BorderBrush="#2E4060" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="마지막 실패 / revision" Foreground="#9FB3C8" FontSize="12"/>
                    <TextBlock Text="{Binding LastFailureText}" FontSize="16" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding LastRevisionText, StringFormat=서버 revision {0}}" Foreground="#90CAF9" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1A2B4A" Padding="10" CornerRadius="6" Margin="0,0,0,8" BorderBrush="#2E4060" BorderThickness="1">
                <WrapPanel>
                    <TextBlock Text="검색" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Width="280" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                    <TextBlock Text="유형" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Width="160" ItemsSource="{Binding CategoryOptions}" SelectedItem="{Binding SelectedCategory}" Margin="0,0,10,0"/>
                    <TextBlock Text="상태" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Width="120" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Margin="0,0,10,0"/>
                    <TextBlock Text="심각도" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Width="120" ItemsSource="{Binding SeverityOptions}" SelectedItem="{Binding SelectedSeverity}" Margin="0,0,10,0"/>
                    <CheckBox Content="자동 복구 가능만" IsChecked="{Binding OnlyRecoverable}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="진단 리포트" Background="#546E7A" Command="{Binding ExportReportCommand}" Margin="0,0,6,0"/>
                    <Button Content="진단 이벤트 엑셀" Background="#2E7D32" Command="{Binding ExportDiagnosticExcelCommand}" Margin="0,0,6,0"/>
                    <Button Content="서버 무결성 새로고침" Background="#455A64" Command="{Binding RefreshServerIntegrityCommand}" Margin="0,0,6,0"/>
                    <Button Content="통합 무결성 리포트" Background="#546E7A" Command="{Binding ExportIntegrityReportCommand}" Margin="0,0,6,0"/>
                    <Button Content="로그 폴더" Background="#546E7A" Command="{Binding OpenLogFolderCommand}" Margin="0,0,6,0"/>
                    <Button Content="해결 이력 정리" Background="#6D4C41" Command="{Binding ClearResolvedCommand}"/>
                </WrapPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="170"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="서버 무결성 리포트" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Grid.Row="1" Foreground="#9FB3C8" Margin="0,6,0,0">
                            <Run Text="{Binding ServerIntegrityStatusText}"/>
                            <Run Text="  ·  생성 "/>
                            <Run Text="{Binding ServerIntegrityGeneratedAtText}"/>
                            <Run Text="  ·  상세 "/>
                            <Run Text="{Binding ServerIntegrityDetailCount, StringFormat={}{0:N0}건}"/>
                        </TextBlock>
                        <TextBlock Grid.Row="2" Text="{Binding ServerIntegritySummaryText}" Foreground="#EAF2FF" Margin="0,6,0,8" TextWrapping="Wrap"/>
                        <WrapPanel Grid.Row="3" Margin="0,0,0,8">
                            <Button Content="상세 목록 조회" Background="#0277BD" Command="{Binding LoadServerIntegrityDetailsCommand}" Margin="0,0,6,0"/>
                            <Button Content="선택 이슈 엑셀" Background="#2E7D32" Command="{Binding ExportServerIntegrityDetailsExcelCommand}"/>
                        </WrapPanel>
                        <DataGrid Grid.Row="4" ItemsSource="{Binding ServerIntegrityIssues}" SelectedItem="{Binding SelectedServerIntegrityIssue}" IsReadOnly="True" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="심각도" Binding="{Binding Severity}" Width="90"/>
                                <DataGridTextColumn Header="건수" Binding="{Binding Count, StringFormat={}{0:N0}}" Width="70"/>
                                <DataGridTextColumn Header="코드" Binding="{Binding Code}" Width="190"/>
                                <DataGridTextColumn Header="내용" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="5" Margin="0,10,0,6">
                            <TextBlock Text="선택 이슈 상세 목록" Foreground="#4FC3F7" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ServerIntegrityDetailSummaryText}" Foreground="#EAF2FF" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ServerIntegrityDetailStatusText}" Foreground="#9FB3C8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <DataGrid Grid.Row="6" ItemsSource="{Binding ServerIntegrityDetailRows}" IsReadOnly="True" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="엔터티" Binding="{Binding EntityType}" Width="100"/>
                                <DataGridTextColumn Header="엔터티 ID" Binding="{Binding EntityIdText}" Width="180"/>
                                <DataGridTextColumn Header="주요 정보" Binding="{Binding PrimaryText}" Width="170"/>
                                <DataGridTextColumn Header="보조 정보" Binding="{Binding SecondaryText}" Width="220"/>
                                <DataGridTextColumn Header="참조" Binding="{Binding ReferenceText}" Width="200"/>
                                <DataGridTextColumn Header="범위" Binding="{Binding ScopeText}" Width="200"/>
                                <DataGridTextColumn Header="상세" Binding="{Binding DetailText}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Sync Outbox" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                        <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                            <Border Background="#102039" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="대기" Foreground="#9FB3C8" FontSize="11"/>
                                    <TextBlock Text="{Binding PendingOutboxCount, StringFormat={}{0:N0}건}" FontSize="20" FontWeight="Bold" Foreground="#FFCC80"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#102039" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="실패" Foreground="#9FB3C8" FontSize="11"/>
                                    <TextBlock Text="{Binding FailedOutboxCount, StringFormat={}{0:N0}건}" FontSize="20" FontWeight="Bold" Foreground="#EF9A9A"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#102039" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="완료" Foreground="#9FB3C8" FontSize="11"/>
                                    <TextBlock Text="{Binding AcknowledgedOutboxCount, StringFormat={}{0:N0}건}" FontSize="20" FontWeight="Bold" Foreground="#A5D6A7"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <TextBlock Grid.Row="2" Text="{Binding OutboxSummaryText}" Foreground="#EAF2FF" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        <WrapPanel Grid.Row="3" Margin="0,12,0,0">
                            <Button Content="선택 재시도" Background="#1565C0" Command="{Binding RetrySelectedOutboxCommand}" Margin="0,0,6,0"/>
                            <Button Content="전체 재시도" Background="#2E7D32" Command="{Binding RetryAllOutboxCommand}" Margin="0,0,6,0"/>
                            <Button Content="완료 정리" Background="#6D4C41" Command="{Binding ClearAcknowledgedOutboxCommand}"/>
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.25*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="250"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding Events}" SelectedItem="{Binding SelectedEvent}" IsReadOnly="True" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="마지막 발생" Binding="{Binding LastOccurredAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="160"/>
                                <DataGridTextColumn Header="유형" Binding="{Binding Category}" Width="130"/>
                                <DataGridTextColumn Header="필터" Binding="{Binding SummaryText}" Width="220"/>
                                <DataGridTextColumn Header="원인 요약" Binding="{Binding RawMessage}" Width="2*"/>
                                <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="90"/>
                                <DataGridCheckBoxColumn Header="복구" Binding="{Binding IsRecoverable}" Width="70"/>
                                <DataGridTextColumn Header="횟수" Binding="{Binding OccurrenceCount}" Width="70"/>
                                <DataGridTextColumn Header="사용자 범위" Binding="{Binding UserScopeText}" Width="170"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Row="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sync Outbox 최근 기록" Foreground="#4FC3F7" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding OutboxStatusText}" Foreground="#9FB3C8"/>
                                </Grid>
                            </Border>
                            <DataGrid ItemsSource="{Binding OutboxEntries}" SelectedItem="{Binding SelectedOutboxEntry}" IsReadOnly="True" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="90"/>
                                    <DataGridTextColumn Header="엔터티" Binding="{Binding EntityName}" Width="130"/>
                                    <DataGridTextColumn Header="엔터티 ID" Binding="{Binding EntityIdText}" Width="180"/>
                                    <DataGridTextColumn Header="기대 rev" Binding="{Binding ExpectedRevision, StringFormat={}{0:N0}}" Width="80"/>
                                    <DataGridTextColumn Header="준비시각" Binding="{Binding PreparedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="160"/>
                                    <DataGridTextColumn Header="전송시각" Binding="{Binding SentAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="160"/>
                                    <DataGridTextColumn Header="오류사유" Binding="{Binding ErrorMessage}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1" Width="12" Background="#0D1B2A"/>

                <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                            <TextBlock Text="진단 상세" Foreground="#4FC3F7" FontWeight="Bold"/>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12">
                                <TextBlock Text="원인 요약" Foreground="#9FB3C8" FontSize="11"/>
                                <TextBox Text="{Binding SelectedEvent.RawMessage}" Margin="0,4,0,10" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="64" Height="Auto" IsReadOnly="True"/>

                                <TextBlock Text="분류" Foreground="#9FB3C8" FontSize="11"/>
                                <Grid Margin="0,4,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="카테고리" Foreground="#9FB3C8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedEvent.Category}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="세부유형" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedEvent.Subcategory}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="동기화 단계" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedEvent.SyncPhase}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="복구 조치" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedEvent.RecoveryAction}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </Grid>

                                <TextBlock Text="연관 필터" Foreground="#9FB3C8" FontSize="11"/>
                                <Grid Margin="0,4,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="필터" Foreground="#9FB3C8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedEvent.SummaryText}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="참조" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedEvent.ReferenceText}" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="사용자 범위" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedEvent.UserScopeText}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="PC/버전" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedEvent.MachineVersionText}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </Grid>

                                <TextBlock Text="동기화 상태 스냅샷" Foreground="#9FB3C8" FontSize="11"/>
                                <Grid Margin="0,4,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="서버 revision" Foreground="#9FB3C8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedEvent.Snapshot.LastKnownSyncRevision, StringFormat={}{0:N0}}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="dirty(거래처/전표)" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0">
                                        <Run Text="거래처 "/><Run Text="{Binding SelectedEvent.Snapshot.DirtyCustomerCount}"/><Run Text="건 / 전표 "/><Run Text="{Binding SelectedEvent.Snapshot.DirtyInvoiceCount}"/><Run Text="건"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="dirty(거래/첨부/결제)" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0">
                                        <Run Text="거래 "/><Run Text="{Binding SelectedEvent.Snapshot.DirtyTransactionCount}"/><Run Text="건 / 첨부 "/><Run Text="{Binding SelectedEvent.Snapshot.DirtyAttachmentCount}"/><Run Text="건 / 결제 "/><Run Text="{Binding SelectedEvent.Snapshot.DirtyPaymentCount}"/><Run Text="건"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="dirty(렌탈/이동)" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0">
                                        <Run Text="렌탈 "/><Run Text="{Binding SelectedEvent.Snapshot.DirtyRentalAssetCount}"/><Run Text="건 / 재고이동 "/><Run Text="{Binding SelectedEvent.Snapshot.DirtyInventoryTransferCount}"/><Run Text="건"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="누락 참조" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap">
                                        <Run Text="고객 "/><Run Text="{Binding SelectedEvent.Snapshot.MissingCustomerReferenceCount}"/><Run Text="건 / 전표 "/><Run Text="{Binding SelectedEvent.Snapshot.MissingInvoiceReferenceCount}"/><Run Text="건 / 거래 "/><Run Text="{Binding SelectedEvent.Snapshot.MissingTransactionReferenceCount}"/><Run Text="건 / 렌탈항목 "/><Run Text="{Binding SelectedEvent.Snapshot.MissingRentalItemReferenceCount}"/><Run Text="건"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="마지막 sync 오류" Foreground="#9FB3C8" Margin="0,6,0,0"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SelectedEvent.Snapshot.LastKnownSyncError}" Margin="0,6,0,0" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="54" Height="Auto" IsReadOnly="True"/>
                                </Grid>

                                <TextBlock Text="권장 복구" Foreground="#9FB3C8" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedRecoveryActionTitle}" Margin="0,4,0,0" FontWeight="Bold" Foreground="#B3E5FC"/>
                                <TextBlock Text="{Binding SelectedRecoveryActionDetail}" Margin="0,4,0,10" TextWrapping="Wrap" Foreground="#90CAF9"/>

                                <TextBlock Text="복구 메모" Foreground="#9FB3C8" FontSize="11"/>
                                <TextBlock Text="{Binding RepairSummaryText}" Margin="0,4,0,10" TextWrapping="Wrap"/>

                                <TextBlock Text="예외 상세" Foreground="#9FB3C8" FontSize="11"/>
                                <TextBox Text="{Binding SelectedEvent.StackTrace}" Margin="0,4,0,0" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="140" Height="200" IsReadOnly="True"/>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="#0D1B2A" Padding="10,6" Margin="0,12,0,0">
            <TextBlock Text="{Binding SummaryStatusText}" Foreground="#9FB3C8" FontSize="11"/>
        </Border>
    </Grid>
</Window>

<Window x:Class="거래플랜.Desktop.App.Views.SalesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:거래플랜.Desktop.App.Converters"
        Title="{Binding WindowTitleText}" Height="920" Width="1460" MinWidth="1280" MinHeight="820"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>
        <conv:VoucherTypeConverter x:Key="VoucherTypeConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#101010"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#8F8F8F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="UnifiedDatePickerButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#AFC2D8"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#D1E1F2"/>
            <Setter Property="RowBackground" Value="#DCE9F8"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#DCE9F8"/>
            <Setter Property="BorderBrush" Value="#AFC2D8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#90CAF9"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#D8D8D8"/>
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#062445" Padding="10,6" BorderBrush="#011327" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="{Binding HeaderTitleText}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="{Binding HeaderSubtitleText}" Foreground="#E7EEF9" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource BaseButtonStyle}" Content="{Binding NewDocumentButtonText}" Margin="0,0,8,0" Command="{Binding StartNewInvoiceCommand}"/>
                    <Button Style="{StaticResource BaseButtonStyle}"
                            Content="{Binding PaymentActionButtonText}"
                            Margin="0,0,8,0"
                            Visibility="{Binding ShowPaymentAction, Converter={StaticResource BoolToVisibilityConverter}}"
                            Click="PaymentButton_Click"/>
                    <Button Style="{StaticResource BaseButtonStyle}" Content="닫기(F12)" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#122038" BorderBrush="#2E4060" BorderThickness="0,1,0,0" Padding="8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#A5D6A7"/>
        </Border>

        <Grid Margin="6" Grid.IsSharedSizeScope="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="184"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="8,7" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SalesInfoLabelPrimary"/>
                        <ColumnDefinition Width="236"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SalesInfoLabelSecondary"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="SalesInfoLabelTertiary"/>
                        <ColumnDefinition Width="154"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding CustomerSectionTitleText}" FontWeight="Bold"/>
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource BaseButtonStyle}"
                            Content="{Binding CustomerName}"
                            Background="#D9E6F5"
                            Foreground="Black"
                            FontWeight="Bold"
                            HorizontalAlignment="Stretch"
                            Padding="6,2"
                            Margin="0,0,14,6"
                            Click="CustomerSelectButton_Click"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="고객분류" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="3"
                             Text="{Binding CustomerTradeType}"
                             IsReadOnly="True"
                             TextAlignment="Left"
                             Margin="0,0,14,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="합계금액" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="5"
                             Text="{Binding TotalAmount, StringFormat={}{0:N0}}"
                             IsReadOnly="True"
                             FontWeight="Bold"
                             Foreground="#C62828"
                             Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="대표전화" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CustomerPhone}" IsReadOnly="True" TextAlignment="Left" Margin="0,0,14,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="가격등급" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding CustomerPriceGrade}" IsReadOnly="True" TextAlignment="Left" Margin="0,0,14,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Text="공급가" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding SupplyAmount, StringFormat={}{0:N0}}" IsReadOnly="True" FontWeight="Bold" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="휴대폰" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CustomerMobile}" IsReadOnly="True" TextAlignment="Left" Margin="0,0,14,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="담당지점" Margin="0,0,0,6"/>
                    <ComboBox Grid.Row="2"
                              Grid.Column="3"
                              ItemsSource="{Binding Offices}"
                              DisplayMemberPath="Code"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding SelectedResponsibleOfficeCode}"
                              Margin="0,0,14,6"
                              MinHeight="28"/>
                    <TextBlock Grid.Row="2" Grid.Column="4" Text="부가세" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding VatAmount, StringFormat={}{0:N0}}" IsReadOnly="True" FontWeight="Bold" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding WarehouseLabelText}"/>
                    <ComboBox Grid.Row="3"
                              Grid.Column="1"
                              ItemsSource="{Binding Warehouses}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding SelectedWarehouseCode}"
                              Margin="0,0,14,0"
                              MinHeight="28"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding CustomerBalanceLabelText}"/>
                    <TextBox Grid.Row="3"
                             Grid.Column="3"
                             Text="{Binding CustomerBalance, StringFormat={}{0:N0}}"
                             IsReadOnly="True"
                             FontWeight="Bold"
                             Foreground="#C62828"
                             Margin="0,0,14,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="4" Text="선수금"/>
                    <TextBox Grid.Row="3"
                             Grid.Column="5"
                             Text="{Binding CustomerAdvanceBalance, StringFormat={}{0:N0}}"
                             IsReadOnly="True"
                             FontWeight="Bold"/>

                    <CheckBox Grid.Row="4"
                              Grid.Column="4"
                              Grid.ColumnSpan="2"
                              Content="세금계산서 발행 완료"
                              IsChecked="{Binding TaxInvoiceIssued}"
                              Visibility="{Binding ShowTaxInvoiceIssuedOption, Converter={StaticResource BoolToVisibilityConverter}}"
                              Margin="0,8,0,0"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="236"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="6" Margin="0,0,8,4">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="SalesDocLabel"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="152"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="SalesDocLabel"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DocumentSectionTitleText}" FontWeight="Bold" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="전표일자" HorizontalAlignment="Left"/>
                            <DatePicker Grid.Column="2"
                                        SelectedDate="{Binding WorkDate, Converter={StaticResource DateOnlyConverter}}"
                                        SelectedDateFormat="Short"
                                        Margin="4,0,6,0">
                                <DatePicker.Resources>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="MinHeight" Value="34"/>
                                        <Setter Property="Height" Value="34"/>
                                        <Setter Property="MinWidth" Value="34"/>
                                        <Setter Property="Width" Value="34"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </DatePicker.Resources>
                            </DatePicker>
                            <Button Grid.Column="3"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Content="이전기록불러오기"
                                    Margin="0,0,8,0"
                                    Padding="12,6"
                                    IsEnabled="{Binding CanLoadPreviousHistory}"
                                    Click="LoadPreviousHistoryButton_Click"/>
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DocumentDetailTitleText}" HorizontalAlignment="Center" FontWeight="Bold"/>
                                <ComboBox Width="150"
                                          Margin="0,4,0,0"
                                          ItemsSource="{Binding ProcurementDocumentTitleOptions}"
                                          SelectedItem="{Binding SelectedProcurementDocumentTitle}"
                                          Visibility="{Binding ShowProcurementTitleSelector, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="5" Text="전표메모" HorizontalAlignment="Right"/>
                            <TextBox Grid.Column="6" Text="{Binding InvoiceMemo, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="172"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="품명/청구항목 [바코드사용가능]" Margin="2,0,0,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="규격" Margin="2,0,0,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="수량" Margin="2,0,0,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="단위" Margin="2,0,0,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="5" Text="단가" Margin="2,0,0,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="금액" Margin="2,0,0,1"/>
                            <TextBlock Grid.Row="0" Grid.Column="7" Text="비고" Margin="2,0,0,1"/>

                            <TextBox x:Name="InputItemNameTextBox" Grid.Row="1" Grid.Column="0" Height="30"
                                     Text="{Binding InputItemName, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="InputItemNameTextBox_KeyDown"/>
                            <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource BaseButtonStyle}" Height="30" Margin="4,0,0,0" Padding="0"
                                    Content="..." Click="ItemLookupButton_Click"/>
                            <TextBox Grid.Row="1" Grid.Column="2" Height="30" Text="{Binding InputSpec, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Height="30" Text="{Binding InputQty, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" TextAlignment="Right"/>
                            <TextBox Grid.Row="1" Grid.Column="4" Height="30" Text="{Binding InputUnit, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="5" Height="30" Text="{Binding InputUnitPrice, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" TextAlignment="Right"/>
                            <TextBox Grid.Row="1" Grid.Column="6" Height="30" Text="{Binding InputLineAmount, StringFormat=N0}" IsReadOnly="True" Margin="4,0,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="7" Height="30" Text="{Binding InputRemark, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>

                            <StackPanel Grid.Row="1" Grid.Column="8" Orientation="Horizontal" Margin="6,0,0,0" HorizontalAlignment="Left">
                                <Button Style="{StaticResource BaseButtonStyle}" Content="항목추가" MinWidth="80" Margin="0,0,6,0" Command="{Binding AddLineCommand}"/>
                                <Button Style="{StaticResource BaseButtonStyle}" Content="항목수정" MinWidth="80" Command="{Binding UpdateLineCommand}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1">
                    <DataGrid ItemsSource="{Binding Lines}" SelectedItem="{Binding SelectedLine}" IsReadOnly="False" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No" Width="42" IsReadOnly="True" Binding="{Binding Id}"/>
                            <DataGridTextColumn Header="품명" Width="*" Binding="{Binding ItemName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="규격" Width="188" Binding="{Binding Specification, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="수량" Width="60" Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}"/>
                            <DataGridTextColumn Header="단위" Width="52" Binding="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="단가" Width="92" Binding="{Binding UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}"/>
                            <DataGridTextColumn Header="금액" Width="98" IsReadOnly="True" Binding="{Binding LineAmount, StringFormat=N0}"/>
                            <DataGridTextColumn Header="비고" Width="150" Binding="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Background="#122038" BorderBrush="#2E4060" BorderThickness="1" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <StackPanel Visibility="{Binding ShowStatementOptions, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,10">
                                <TextBlock Text="인쇄옵션" Foreground="#EAF2FF" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock Text="[출력 서류]" Foreground="#EAF2FF" Margin="0,0,0,4"/>
                                <CheckBox Content="거래명세서" IsChecked="{Binding PrintStatementDocument}" Foreground="#EAF2FF" FontSize="13" Margin="0,0,0,2"/>
                                <CheckBox Content="견적서" IsChecked="{Binding PrintEstimateDocument}" Foreground="#EAF2FF" FontSize="13" Margin="0,0,0,2"/>
                                <CheckBox Content="대금청구서" IsChecked="{Binding PrintPaymentClaimDocument}" Foreground="#EAF2FF" FontSize="13" Margin="0,0,0,8"/>
                                <TextBlock Text="[인쇄 설정]" Foreground="#EAF2FF" Margin="0,0,0,4"/>
                                <CheckBox Content="날짜 인쇄함" IsChecked="{Binding PrintWithDate}" Foreground="#EAF2FF" FontSize="13" Margin="0,0,0,4"/>
                                <CheckBox Content="단가 인쇄함" IsChecked="{Binding PrintWithPrice}" Foreground="#EAF2FF" FontSize="13"/>
                            </StackPanel>

                            <Border Background="#18314C"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding ShowPurchasePrintHint, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="구매 전표는 매입 명세서 양식으로 바로 출력됩니다."
                                           Foreground="#EAF2FF"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Border Background="#18314C"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding ShowProcurementPrintHint, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="견적/발주 전표는 선택한 제목의 발주서 양식으로 바로 출력됩니다."
                                           Foreground="#EAF2FF"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Button Style="{StaticResource BaseButtonStyle}" Content="인쇄하기[F9]" Margin="0,0,0,6" Command="{Binding PrintCommand}"/>
                            <Button Style="{StaticResource BaseButtonStyle}" Content="출력물 편집"
                                    Margin="0,0,0,6"
                                    Command="{Binding EditPrintOutputCommand}"
                                    Visibility="{Binding CanEditPrintOutput, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Button Style="{StaticResource BaseButtonStyle}" Content="세금계산인쇄"
                                    Margin="0,0,0,6"
                                    Command="{Binding PrintTaxInvoiceCommand}"
                                    Visibility="{Binding CanPrintTaxInvoice, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Button Style="{StaticResource BaseButtonStyle}" Content="항목삭제" Margin="0,0,0,10" Command="{Binding DeleteLineCommand}"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

                <Border Grid.Row="3" Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="[전표 입력 가능 품목 - 재고/비재고 청구항목]" FontWeight="Bold" Margin="0,0,12,0"/>
                        <TextBlock Text="검색" Margin="0,0,6,0"/>
                        <TextBox Width="220" Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ItemSearchResults}" SelectedItem="{Binding SelectedInputItem}" IsReadOnly="True" BorderThickness="0" FontSize="12" MouseDoubleClick="ItemSearchResultsDataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="품목명" Binding="{Binding NameOriginal}" Width="*"/>
                            <DataGridTextColumn Header="운영유형" Binding="{Binding ItemKind}" Width="86"/>
                            <DataGridTextColumn Header="재고방식" Binding="{Binding TrackingType}" Width="72"/>
                            <DataGridTextColumn Header="규격" Binding="{Binding SpecificationOriginal}" Width="116"/>
                            <DataGridTextColumn Header="현재재고" Binding="{Binding CurrentStock, StringFormat=N0}" Width="84"/>
                            <DataGridTextColumn Header="매출단가" Binding="{Binding SalePrice, StringFormat=N0}" Width="84"/>
                            <DataGridTextColumn Header="소매단가" Binding="{Binding RetailPrice, StringFormat=N0}" Width="84"/>
                            <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="62"/>
                            <DataGridTextColumn Header="A.단가" Binding="{Binding PriceGradeA, StringFormat=N0}" Width="76"/>
                            <DataGridTextColumn Header="B.단가" Binding="{Binding PriceGradeB, StringFormat=N0}" Width="76"/>

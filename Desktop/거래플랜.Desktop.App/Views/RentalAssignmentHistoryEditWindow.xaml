<Window x:Class="거래플랜.Desktop.App.Views.RentalAssignmentHistoryEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="임대이력 편집"
        Width="620"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#151F2E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Background" Value="#DDEBFA"/>
            <Setter Property="BorderBrush" Value="#3E5D86"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Background" Value="#DDEBFA"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="MaxWidth" Value="150"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F6FCE"/>
            <Setter Property="BorderBrush" Value="#5E93D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#20345A" BorderBrush="#33517C" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="렌탈 자산 임대이력" FontSize="20" FontWeight="Bold" Foreground="#66D9FF"/>
                <TextBlock Text="이력 추가/수정은 임대했던 거래처, 회수일, 월 렌탈료 기록만 변경하며 자산 정보는 삭제하지 않습니다."
                           Margin="0,6,0,0"
                           Foreground="#B8C6D8"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#1C2B43" BorderBrush="#33517C" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="상태"/>
                <CheckBox Grid.Row="0" Grid.Column="1"
                          VerticalAlignment="Center"
                          Foreground="#EAF2FF"
                          Content="현재 임대 중"
                          IsChecked="{Binding IsCurrent, Mode=TwoWay}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="시작일"/>
                <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding LinkedAtLocal, Mode=TwoWay}">
                    <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                </DatePicker>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="회수/종료일"/>
                <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding UnlinkedAtLocal, Mode=TwoWay}">
                    <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                </DatePicker>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="거래처/임대처"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="설치위치"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding InstallLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="청구연결"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding BillingProfileDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="품명"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ItemName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="기계/관리번호"/>
                <Grid Grid.Row="7" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding MachineNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Grid.Column="2" Text="{Binding ManagementNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="월 렌탈료"/>
                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding MonthlyFee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="사유/메모" VerticalAlignment="Top" Margin="0,8,0,0"/>
                <TextBox Grid.Row="9" Grid.Column="1"
                         Height="72"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding ChangeReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="저장" Click="Save_Click" Background="#157A2D"/>
            <Button Content="취소" Click="Cancel_Click" Background="#4E6681"/>
        </StackPanel>
    </Grid>
</Window>

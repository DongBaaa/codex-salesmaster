<Window x:Class="거래플랜.Desktop.App.Views.EnvironmentSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경설정"
        Height="820"
        Width="1240"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0C4DA"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#151F2E"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#9FB3C8"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A2B4A"
                Padding="12"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="환경설정" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7"/>
                    <TextBlock Text="회사 정보, 담당지점, 사용자 계정, 휴지통 복원과 버전 업데이트를 관리합니다." Foreground="#9FB3C8" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="닫기(F12)"
                        Width="120"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <TabControl x:Name="SettingsTabs" Grid.Row="1" Margin="0,10,0,0">
            <TabItem Header="회사 설정">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#1A2B4A" CornerRadius="6" Padding="16" BorderBrush="#2E4060" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="사용자별 회사 설정" FontSize="18" FontWeight="Bold" Foreground="#4FC3F7"/>
                                <TextBlock Text="계약서와 렌탈 문서는 현재 로그인 사용자에게 연결된 회사설정을 기준으로 작성됩니다." Foreground="#9FB3C8" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CompanyProfileManagementHint}" Foreground="#90CAF9" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="내 회사설정" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding CompanyProfileOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding CurrentUserCompanyProfileId}"
                                              Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="내 설정 적용" Background="#1565C0" Command="{Binding SaveCurrentUserCompanyProfileCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1.8*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="신규 회사설정" Background="#1565C0" Margin="0,0,6,0" Command="{Binding NewCompanyProfileCommand}" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                            <Button Content="삭제" Background="#C62828" Margin="0,0,6,0" Command="{Binding DeleteCompanyProfileCommand}" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                            <Button Content="새로고침" Background="#455A64" Command="{Binding ReloadCompanyProfilesCommand}"/>
                                        </StackPanel>
                                    </Border>
                                    <DataGrid ItemsSource="{Binding CompanyProfiles}"
                                              SelectedItem="{Binding SelectedCompanyProfile}"
                                              IsReadOnly="True"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="프로필명" Binding="{Binding ProfileName}" Width="*"/>
                                            <DataGridTextColumn Header="담당지점" Binding="{Binding OfficeCode}" Width="110"/>
                                            <DataGridTextColumn Header="상호" Binding="{Binding TradeName}" Width="150"/>
                                            <DataGridCheckBoxColumn Header="기본" Binding="{Binding IsDefaultForOffice}" Width="70"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" Padding="16" BorderBrush="#2E4060" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="회사설정 편집" FontSize="18" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Label Grid.Row="0" Grid.Column="0" Content="프로필명"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CompanyProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="1" Grid.Column="0" Content="담당지점"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  ItemsSource="{Binding UserOfficeOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding CompanyOfficeCode}"
                                                  Margin="0,0,0,8"
                                                  IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <CheckBox Grid.Row="2" Grid.Column="1" Content="해당 담당지점 기본 회사설정" IsChecked="{Binding CompanyIsDefaultForOffice}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="3" Grid.Column="0" Content="상호"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CompanyTradeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="4" Grid.Column="0" Content="대표자"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CompanyRepresentative, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="5" Grid.Column="0" Content="사업자번호"/>
                                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CompanyBusinessNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="6" Grid.Column="0" Content="업태"/>
                                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding CompanyBusinessType, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="7" Grid.Column="0" Content="종목"/>
                                        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding CompanyBusinessItem, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="8" Grid.Column="0" Content="주소"/>
                                        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="9" Grid.Column="0" Content="연락처"/>
                                        <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding CompanyContactNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="10" Grid.Column="0" Content="이메일"/>
                                        <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Label Grid.Row="11" Grid.Column="0" Content="계좌/안내문구"/>
                                        <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding CompanyBankAccountText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="72" Margin="0,0,0,8" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="직인 이미지"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding CompanyStampImagePath}" VerticalAlignment="Center" Foreground="#90CAF9" Margin="0,0,10,0"/>
                                            <Button Content="이미지 선택" Background="#37474F" Command="{Binding SelectStampImageCommand}" Margin="0,0,6,0" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                            <Button Content="삭제" Background="#E53935" Command="{Binding ClearStampImageCommand}" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        </StackPanel>
                                    </Grid>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Button Content="회사 정보 저장" Background="#1E88E5" Command="{Binding SaveCompanyProfileCommand}" Margin="0,0,8,0" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                        <Button Content="신규 회사설정" Background="#455A64" Command="{Binding NewCompanyProfileCommand}" IsEnabled="{Binding CanEditCompanyProfiles}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="#102039" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="외부 레거시 데이터 추출/가져오기" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="원본 DB(FDB)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding LegacySourceDbPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="찾기" Background="#455A64" Command="{Binding SelectLegacySourceDbPathCommand}"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="거래처 엑셀" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding LegacyCustomerExcelPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="찾기" Background="#455A64" Command="{Binding SelectLegacyCustomerExcelPathCommand}"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="제품 엑셀" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding LegacyItemExcelPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="찾기" Background="#455A64" Command="{Binding SelectLegacyItemExcelPathCommand}"/>
                                </Grid>

                                <WrapPanel Margin="0,4,0,0">
                                    <Button Content="1) 원본 DB → 엑셀 추출" Background="#00796B" Command="{Binding ExportLegacyDataCommand}" Margin="0,0,8,0"/>
                                    <Button Content="2) 엑셀 → 거래플랜 DB 반영" Background="#1565C0" Command="{Binding ImportLegacyExcelDataCommand}" Margin="0,0,8,0"/>
                                    <Button Content="추출 + 반영 한번에" Background="#6D4C41" Command="{Binding ExportAndImportLegacyDataCommand}"/>
                                </WrapPanel>

                                <TextBlock Text="{Binding LegacyMigrationStatus}" Foreground="#90CAF9" Margin="0,10,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="선택값 관리">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#1A2B4A" CornerRadius="6" Padding="16" BorderBrush="#2E4060" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="거래처/품목 선택값 관리" FontSize="18" FontWeight="Bold" Foreground="#4FC3F7"/>
                                <TextBlock Text="거래처 등록/수정과 재고관리에서 사용하는 고객분류, 가격등급, 거래구분, 품목분류 선택값을 관리합니다." Foreground="#9FB3C8" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Margin="0,14,0,0">
                            <Grid Margin="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="고객분류" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    <Button Content="신규" Background="#1565C0" Margin="14,0,6,0" Command="{Binding NewCategoryOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveCategoryOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                    <Button Content="삭제" Background="#C62828" Command="{Binding DeleteCategoryOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                </StackPanel>

                                <DataGrid Grid.Row="1" Grid.Column="0"
                                          ItemsSource="{Binding CustomerCategories}"
                                          SelectedItem="{Binding SelectedCategoryOption}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1" Grid.Column="2" Background="#102039" CornerRadius="6" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="고객분류 편집" Foreground="#90CAF9" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Label Content="이름"/>
                                        <TextBox Text="{Binding CategoryOptionName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                        <TextBlock Text="고객분류명은 자유롭게 수정할 수 있으며, 사용 중인 고객분류는 삭제가 제한될 수 있습니다." Foreground="#9FB3C8" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Margin="0,14,0,0">
                            <Grid Margin="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="가격등급" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    <Button Content="신규" Background="#1565C0" Margin="14,0,6,0" Command="{Binding NewPriceGradeOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SavePriceGradeOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                    <Button Content="삭제" Background="#C62828" Command="{Binding DeletePriceGradeOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                </StackPanel>

                                <DataGrid Grid.Row="1" Grid.Column="0"
                                          ItemsSource="{Binding PriceGradeOptions}"
                                          SelectedItem="{Binding SelectedPriceGradeOption}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="기준단가" Binding="{Binding PriceSourceDisplay}" Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1" Grid.Column="2" Background="#102039" CornerRadius="6" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="가격등급 편집" Foreground="#90CAF9" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Label Content="이름"/>
                                        <TextBox Text="{Binding PriceGradeOptionName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                        <Label Content="기준단가"/>
                                        <ComboBox ItemsSource="{Binding PriceSourceOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding PriceGradePriceSource}"
                                                  IsEnabled="{Binding CanManageSelectionOptions}"/>
                                        <TextBlock Text="가격등급명은 자유롭게 수정할 수 있고, 기준단가는 실제 품목 단가 필드와 연결됩니다." Foreground="#9FB3C8" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Margin="0,14,0,0">
                            <Grid Margin="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="거래구분" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    <Button Content="신규" Background="#1565C0" Margin="14,0,6,0" Command="{Binding NewTradeTypeOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveTradeTypeOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                    <Button Content="삭제" Background="#C62828" Command="{Binding DeleteTradeTypeOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                </StackPanel>

                                <DataGrid Grid.Row="1" Grid.Column="0"
                                          ItemsSource="{Binding TradeTypeOptions}"
                                          SelectedItem="{Binding SelectedTradeTypeOption}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="매출" Binding="{Binding AllowsSales}" Width="80"/>
                                        <DataGridCheckBoxColumn Header="매입" Binding="{Binding AllowsPurchase}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1" Grid.Column="2" Background="#102039" CornerRadius="6" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="거래구분 편집" Foreground="#90CAF9" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Label Content="이름"/>
                                        <TextBox Text="{Binding TradeTypeOptionName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                        <CheckBox Content="매출 가능" IsChecked="{Binding TradeTypeAllowsSales}" Margin="0,0,0,6" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                        <CheckBox Content="매입 가능" IsChecked="{Binding TradeTypeAllowsPurchase}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                        <TextBlock Text="거래구분은 판매/구매 화면의 거래처 선택 가능 여부를 결정합니다." Foreground="#9FB3C8" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Margin="0,14,0,0">
                            <Grid Margin="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="품목분류" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    <Button Content="신규" Background="#1565C0" Margin="14,0,6,0" Command="{Binding NewItemCategoryOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveItemCategoryOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                    <Button Content="삭제" Background="#C62828" Command="{Binding DeleteItemCategoryOptionCommand}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                </StackPanel>

                                <DataGrid Grid.Row="1" Grid.Column="0"
                                          ItemsSource="{Binding ItemCategoryOptions}"
                                          SelectedItem="{Binding SelectedItemCategoryOption}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1" Grid.Column="2" Background="#102039" CornerRadius="6" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="품목분류 편집" Foreground="#90CAF9" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Label Content="이름"/>
                                        <TextBox Text="{Binding ItemCategoryOptionName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanManageSelectionOptions}"/>
                                        <TextBlock Text="재고관리 화면의 품목분류 선택 목록과 연결됩니다. 사용 중인 품목분류는 삭제할 수 없습니다."
                                                   Foreground="#9FB3C8"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="담당지점 관리">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.ColumnSpan="3"
                            Background="#102039"
                            BorderBrush="#2E4060"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="담당지점 안내"
                                       Foreground="#4FC3F7"
                                       FontWeight="Bold"/>
                            <TextBlock Text="이 화면은 자유롭게 담당지점을 추가/삭제하는 마스터 관리 화면이 아니라, 시스템 기준 담당지점(USENET, ITWORLD, YEONSU)을 확인하는 용도입니다."
                                       Foreground="#9FB3C8"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                <DockPanel>
                                    <TextBlock Text="시스템 기본 3개 담당지점만 유지됩니다."
                                               Foreground="#9FB3C8"
                                               VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right"
                                            Content="새로고침"
                                            Background="#455A64"
                                            Command="{Binding ReloadOfficesCommand}"/>
                                </DockPanel>
                            </Border>
                            <DataGrid ItemsSource="{Binding Offices}"
                                      SelectedItem="{Binding SelectedOffice}"
                                      IsReadOnly="True"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="코드" Binding="{Binding Code}" Width="140"/>
                                    <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                    <DataGridCheckBoxColumn Header="기본지점" Binding="{Binding IsHeadOffice}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <TextBlock Text="담당지점 편집" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="담당지점 코드는 서버/로컬 공통 canonical 값(USENET, ITWORLD, YEONSU)으로 고정됩니다." Foreground="#9FB3C8" Margin="0,8,0,12" TextWrapping="Wrap"/>

                            <Label Content="담당지점 코드"/>
                            <TextBox Text="{Binding OfficeCode, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanEditOfficeCode}"
                                     Margin="0,0,0,10"/>

                            <Label Content="담당지점 이름"/>
                            <TextBox Text="{Binding OfficeName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditOfficeName}" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="업체 / 데이터 권한">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="업체 / 데이터 권한" Foreground="#4FC3F7" FontWeight="Bold" FontSize="18"/>
                                    <TextBlock Text="{Binding TenantConfigurationHint}" Foreground="#9FB3C8" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="#37474F"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding CanManageTenantConfiguration, StringFormat=관리자 편집 가능: {0}}"
                                               Foreground="#EAF2FF"
                                               FontSize="11"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#1A2B4A"
                                CornerRadius="6"
                                BorderBrush="#2E4060"
                                BorderThickness="1"
                                Padding="16"
                                Margin="0,14,0,0"
                                Visibility="{Binding CanManageBusinessDatabaseSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="업체 DB 설정" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="관리자 계정만 업체 DB를 선택하고 불러올 수 있습니다. 현재 선택 DB와 드롭다운은 모두 업체명(DB명) 형식으로 표시됩니다."
                                           Foreground="#9FB3C8"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="현재 선택 DB"/>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding CurrentBusinessDatabaseLabel}"
                                               VerticalAlignment="Center"
                                               Foreground="#90CAF9"
                                               FontWeight="SemiBold"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="업체 DB 선택" Margin="0,10,0,0"/>
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              Margin="0,10,8,0"
                                              ItemsSource="{Binding BusinessDatabaseOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding SelectedBusinessDatabaseOption}"/>
                                    <Button Grid.Row="1"
                                            Grid.Column="2"
                                            Content="불러오기"
                                            Background="#1565C0"
                                            Margin="0,10,0,0"
                                            Command="{Binding LoadSelectedBusinessDatabaseCommand}"
                                            IsEnabled="{Binding CanLoadSelectedBusinessDatabase}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1.35*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                            <DockPanel>
                                                <TextBlock Text="업체 권역" Foreground="#4FC3F7" FontWeight="Bold" DockPanel.Dock="Left"/>
                                                <Button Content="새로고침"
                                                        DockPanel.Dock="Right"
                                                        Background="#455A64"
                                                        Command="{Binding ReloadTenantConfigurationCommand}"
                                                        IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            </DockPanel>
                                        </Border>
                                        <DataGrid ItemsSource="{Binding TenantDefinitions}"
                                                  SelectedItem="{Binding SelectedTenantDefinition}"
                                                  IsReadOnly="True"
                                                  Height="220"
                                                  BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="코드" Binding="{Binding TenantCode}" Width="130"/>
                                                <DataGridTextColumn Header="이름" Binding="{Binding DisplayName}" Width="*"/>
                                                <DataGridTextColumn Header="저장 방식" Binding="{Binding StorageMode}" Width="160"/>
                                                <DataGridCheckBoxColumn Header="활성" Binding="{Binding IsActive}" Width="70"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </Border>

                                <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="업체 권역 편집" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0" Content="업체 코드"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditingTenantCode}" IsReadOnly="True" Margin="0,0,0,8"/>
                                            <Label Grid.Row="1" Grid.Column="0" Content="표시 이름"/>
                                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditingTenantDisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <Label Grid.Row="2" Grid.Column="0" Content="저장 방식"/>
                                            <ComboBox Grid.Row="2" Grid.Column="1"
                                                      ItemsSource="{Binding TenantStorageModeOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding EditingTenantStorageMode}"
                                                      Margin="0,0,0,8"
                                                      IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <Label Grid.Row="3" Grid.Column="0" Content="설명"/>
                                            <TextBox Grid.Row="3" Grid.Column="1"
                                                     Text="{Binding EditingTenantDescription, UpdateSourceTrigger=PropertyChanged}"
                                                     Height="72"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                        </Grid>
                                        <CheckBox Content="활성 업체 권역" IsChecked="{Binding EditingTenantIsActive}" Margin="0,10,0,0" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                        <Button Content="업체 권역 저장"
                                                Background="#1565C0"
                                                Command="{Binding SaveTenantDefinitionCommand}"
                                                Margin="0,12,0,0"
                                                HorizontalAlignment="Left"
                                                IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14" Margin="0,12,0,0">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                            <TextBlock Text="지점 구조" Foreground="#4FC3F7" FontWeight="Bold"/>
                                        </Border>
                                        <DataGrid ItemsSource="{Binding TenantOfficeDefinitions}"
                                                  SelectedItem="{Binding SelectedTenantOfficeDefinition}"
                                                  IsReadOnly="True"
                                                  Height="180"
                                                  BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="지점" Binding="{Binding OfficeCode}" Width="100"/>
                                                <DataGridTextColumn Header="업체" Binding="{Binding TenantCode}" Width="130"/>
                                                <DataGridTextColumn Header="이름" Binding="{Binding DisplayName}" Width="*"/>
                                                <DataGridCheckBoxColumn Header="상급" Binding="{Binding IsHeadOffice}" Width="70"/>
                                                <DataGridCheckBoxColumn Header="활성" Binding="{Binding IsActive}" Width="70"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </Border>

                                <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="지점 편집" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Label Grid.Row="0" Grid.Column="0" Content="지점 코드"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditingOfficeCode}" IsReadOnly="True" Margin="0,0,0,8"/>
                                            <Label Grid.Row="1" Grid.Column="0" Content="업체 권역"/>
                                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditingOfficeTenantCode}" IsReadOnly="True" Margin="0,0,0,8"/>
                                            <Label Grid.Row="2" Grid.Column="0" Content="표시 이름"/>
                                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditingOfficeDisplayName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                        </Grid>
                                        <WrapPanel Margin="0,12,0,0">
                                            <CheckBox Content="상위 지점" IsChecked="{Binding EditingOfficeIsHeadOffice}" Margin="0,0,16,0" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="활성 지점" IsChecked="{Binding EditingOfficeIsActive}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                        </WrapPanel>
                                        <Button Content="지점 저장"
                                                Background="#1565C0"
                                                Command="{Binding SaveTenantOfficeDefinitionCommand}"
                                                Margin="0,12,0,0"
                                                HorizontalAlignment="Left"
                                                IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                            <DockPanel>
                                                <TextBlock Text="업체 / 지점 데이터 연동 정책" Foreground="#4FC3F7" FontWeight="Bold" DockPanel.Dock="Left"/>
                                                <WrapPanel DockPanel.Dock="Right">
                                                    <Button Content="신규 정책" Background="#455A64" Margin="0,0,8,0" Command="{Binding NewSharingPolicyCommand}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                                    <Button Content="삭제" Background="#C62828" Command="{Binding DeleteSharingPolicyCommand}" IsEnabled="{Binding CanDeleteSelectedSharingPolicy}"/>
                                                </WrapPanel>
                                            </DockPanel>
                                        </Border>
                                        <DataGrid ItemsSource="{Binding SharingPolicies}"
                                                  SelectedItem="{Binding SelectedSharingPolicy}"
                                                  IsReadOnly="True"
                                                  Height="280"
                                                  BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Source" Binding="{Binding SourceOfficeCode}" Width="90"/>
                                                <DataGridTextColumn Header="Target" Binding="{Binding TargetOfficeCode}" Width="90"/>
                                                <DataGridCheckBoxColumn Header="거래처" Binding="{Binding ShareCustomers}" Width="70"/>
                                                <DataGridCheckBoxColumn Header="전표" Binding="{Binding ShareInvoices}" Width="70"/>
                                                <DataGridCheckBoxColumn Header="수금" Binding="{Binding SharePayments}" Width="70"/>
                                                <DataGridCheckBoxColumn Header="집계" Binding="{Binding ShareReports}" Width="70"/>
                                                <DataGridCheckBoxColumn Header="렌탈" Binding="{Binding ShareRentals}" Width="70"/>
                                                <DataGridCheckBoxColumn Header="납품" Binding="{Binding ShareDeliveries}" Width="70"/>
                                                <DataGridCheckBoxColumn Header="Target 쓰기" Binding="{Binding AllowTargetWrite}" Width="90"/>
                                                <DataGridCheckBoxColumn Header="활성" Binding="{Binding IsActive}" Width="70"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </Border>

                                <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="연동 정책 편집" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Label Grid.Row="0" Grid.Column="0" Content="Source 업체"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1"
                                                      ItemsSource="{Binding SharingSourceTenantOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding SharingSourceTenantCode}"
                                                      IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <Label Grid.Row="0" Grid.Column="3" Content="Source 지점"/>
                                            <ComboBox Grid.Row="0" Grid.Column="4"
                                                      ItemsSource="{Binding SharingSourceOfficeOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding SharingSourceOfficeCode}"
                                                      IsEnabled="{Binding CanManageTenantConfiguration}"/>

                                            <Label Grid.Row="1" Grid.Column="0" Content="Target 업체"/>
                                            <ComboBox Grid.Row="1" Grid.Column="1"
                                                      ItemsSource="{Binding SharingTargetTenantOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding SharingTargetTenantCode}"
                                                      Margin="0,8,0,0"
                                                      IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <Label Grid.Row="1" Grid.Column="3" Content="Target 지점"/>
                                            <ComboBox Grid.Row="1" Grid.Column="4"
                                                      ItemsSource="{Binding SharingTargetOfficeOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding SharingTargetOfficeCode}"
                                                      Margin="0,8,0,0"
                                                      IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                        </Grid>

                                        <UniformGrid Columns="4" Margin="0,14,0,0">
                                            <CheckBox Content="거래처" IsChecked="{Binding SharingShareCustomers}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="품목" IsChecked="{Binding SharingShareItems}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="전표" IsChecked="{Binding SharingShareInvoices}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="수금/지급" IsChecked="{Binding SharingSharePayments}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="계약서" IsChecked="{Binding SharingShareContracts}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="집계" IsChecked="{Binding SharingShareReports}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="렌탈" IsChecked="{Binding SharingShareRentals}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="납품" IsChecked="{Binding SharingShareDeliveries}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                        </UniformGrid>

                                        <WrapPanel Margin="0,10,0,0">
                                            <CheckBox Content="Target 지점 쓰기 허용" IsChecked="{Binding SharingAllowTargetWrite}" Margin="0,0,16,0" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <CheckBox Content="활성 정책" IsChecked="{Binding SharingIsActive}" IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                        </WrapPanel>

                                        <Label Content="정책 메모" Margin="0,10,0,0"/>
                                        <TextBox Text="{Binding SharingNote, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="80"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 IsEnabled="{Binding CanManageTenantConfiguration}"/>

                                        <WrapPanel Margin="0,14,0,0">
                                            <Button Content="연동 정책 저장"
                                                    Background="#1565C0"
                                                    Command="{Binding SaveSharingPolicyCommand}"
                                                    Margin="0,0,8,0"
                                                    IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                            <Button Content="신규 정책으로 초기화"
                                                    Background="#455A64"
                                                    Command="{Binding NewSharingPolicyCommand}"
                                                    IsEnabled="{Binding CanManageTenantConfiguration}"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="사용자 관리">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="신규 사용자" Background="#1565C0" Margin="0,0,6,0" Command="{Binding NewUserCommand}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveUserCommand}" IsEnabled="{Binding CanManageUsers}"/>
                                    <Button Content="삭제" Background="#C62828" Margin="0,0,6,0" Command="{Binding DeleteUserCommand}" IsEnabled="{Binding CanManageUsers}"/>
                                    <Button Content="새로고침" Background="#455A64" Command="{Binding ReloadUsersCommand}" IsEnabled="{Binding CanManageUsers}"/>
                                </StackPanel>
                            </Border>
                            <DataGrid ItemsSource="{Binding Users}"
                                      SelectedItem="{Binding SelectedUser}"
                                      IsReadOnly="True"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="아이디" Binding="{Binding Username}" Width="*"/>
                                    <DataGridTextColumn Header="업체권역" Binding="{Binding TenantCode}" Width="130"/>
                                    <DataGridTextColumn Header="담당지점" Binding="{Binding OfficeCode}" Width="120"/>
                                    <DataGridTextColumn Header="범위" Binding="{Binding ScopeType}" Width="110"/>
                                    <DataGridTextColumn Header="권한" Binding="{Binding Role}" Width="120"/>
                                    <DataGridCheckBoxColumn Header="활성" Binding="{Binding IsActive}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <TextBlock Text="사용자 계정 편집" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding UserManagementHint}"
                                       Foreground="#9FB3C8"
                                       Margin="0,8,0,12"
                                       TextWrapping="Wrap"/>

                            <Label Content="아이디"/>
                            <TextBox Text="{Binding EditingUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"
                                     IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="업체권역"/>
                            <ComboBox ItemsSource="{Binding UserTenantOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding EditingUserTenantCode}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="담당지점"/>
                            <ComboBox ItemsSource="{Binding UserOfficeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding EditingUserOfficeCode}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="데이터 범위"/>
                            <ComboBox ItemsSource="{Binding ScopeTypeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding EditingUserScopeType}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="권한"/>
                            <ComboBox ItemsSource="{Binding RoleOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding EditingUserRole}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="회사설정"/>
                            <ComboBox ItemsSource="{Binding CompanyProfileOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding EditingUserCompanyProfileId}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <CheckBox Content="활성 계정"
                                      IsChecked="{Binding EditingUserIsActive}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="비밀번호"/>
                            <TextBox Text="{Binding EditingPassword, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"
                                     IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="비밀번호 확인"/>
                            <TextBox Text="{Binding EditingPasswordConfirm, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"
                                     IsEnabled="{Binding CanManageUsers}"/>

                            <TextBlock Text="신규 사용자는 비밀번호가 필수이고, 기존 사용자는 비워두면 변경하지 않습니다."
                                       Foreground="#9FB3C8"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="SyncTab" Header="동기화">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="동기화 / 동기화 진단 / 백업" Foreground="#4FC3F7" FontWeight="Bold" FontSize="18"/>
                                <TextBlock Text="동기화 관련 기능을 한 곳에서 실행하고 현재 업체 DB와 미동기화 현황을 함께 확인합니다."
                                           Foreground="#9FB3C8"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                                <Button Content="동기화"
                                        Background="#37474F"
                                        Margin="0,0,8,0"
                                        Command="{Binding RunSyncCommand}"/>
                                <Button Content="동기화 진단"
                                        Background="#5D4037"
                                        Margin="0,0,8,0"
                                        Command="{Binding OpenSyncDiagnosticsCommand}"/>
                                <Button Content="백업"
                                        Background="#455A64"
                                        Command="{Binding RunBackupCommand}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,14,0,0">
                        <Border Background="#132742" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="현재 모드" Foreground="#9FB3C8" FontSize="11"/>
                                <TextBlock Text="{Binding SyncModeText}" Foreground="#B3E5FC" FontSize="18" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#132742" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="업체 DB" Foreground="#9FB3C8" FontSize="11"/>
                                <TextBlock Text="{Binding SyncDatabaseText}" Foreground="#C5E1A5" FontSize="18" FontWeight="Bold" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#132742" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="14">
                            <StackPanel>
                                <TextBlock Text="미동기화 현황" Foreground="#9FB3C8" FontSize="11"/>
                                <TextBlock Text="{Binding SyncPendingChangesText}" Foreground="#FFCC80" FontSize="18" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="0.9*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="16">
                            <StackPanel>
                                <TextBlock Text="동기화 요약" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding SyncSummaryText}" Foreground="#9FB3C8" Margin="0,8,0,12" TextWrapping="Wrap"/>

                                <Border Background="#102039" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="최근 성공" Foreground="#9FB3C8" FontSize="11"/>
                                        <TextBlock Text="{Binding SyncLastSuccessText}" Foreground="#B3E5FC" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#102039" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="최근 실패" Foreground="#9FB3C8" FontSize="11"/>
                                        <TextBlock Text="{Binding SyncLastFailureText}" Foreground="#FFCC80" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#102039" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="마지막 오류" Foreground="#9FB3C8" FontSize="11"/>
                                        <TextBlock Text="{Binding SyncLastErrorText}" Foreground="#EF9A9A" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="16">
                            <StackPanel>
                                <TextBlock Text="지점별 동기화 계정" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding SyncStoredCredentialsSummaryText}"
                                           Foreground="#9FB3C8"
                                           Margin="0,8,0,12"
                                           TextWrapping="Wrap"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="지점" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              ItemsSource="{Binding UserOfficeOptions}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SyncCredentialOfficeCode}"
                                              Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="아이디" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding SyncCredentialUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="비밀번호" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1"
                                             Text="{Binding SyncCredentialPassword, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,8"/>
                                </Grid>

                                <WrapPanel>
                                    <Button Content="지점 로그인 저장"
                                            Background="#1565C0"
                                            Margin="0,0,8,0"
                                            Command="{Binding SaveSyncCredentialCommand}"/>
                                    <Button Content="선택 삭제"
                                            Background="#C62828"
                                            Command="{Binding DeleteSyncCredentialCommand}"/>
                                </WrapPanel>

                                <TextBlock Text="현재 지점/계정으로 로그인 검증 후 암호화 저장합니다. 저장된 지점 계정은 office별 dirty 추가 업로드에 사용됩니다."
                                           Foreground="#9FB3C8"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="저장된 계정이 없어도 현재 로그인 지점은 현재 세션으로 계속 동기화됩니다."
                                           Foreground="#9FB3C8"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.35*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#102039" CornerRadius="6,6,0,0" Padding="12">
                                    <TextBlock Text="저장된 지점 로그인" Foreground="#4FC3F7" FontWeight="Bold"/>
                                </Border>
                                <DataGrid ItemsSource="{Binding StoredSyncCredentials}"
                                          SelectedItem="{Binding SelectedStoredSyncCredential}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="지점" Binding="{Binding OfficeDisplayName}" Width="140"/>
                                        <DataGridTextColumn Header="업체" Binding="{Binding TenantDisplayName}" Width="110"/>
                                        <DataGridTextColumn Header="아이디" Binding="{Binding Username}" Width="120"/>
                                        <DataGridTextColumn Header="저장시각" Binding="{Binding SavedAtText}" Width="160"/>
                                        <DataGridTextColumn Header="상태" Binding="{Binding StatusText}" Width="140"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#102039" CornerRadius="6,6,0,0" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="지점별 / 공용 동기화 상태" Foreground="#4FC3F7" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding SyncScopeStatusSummaryText}" Foreground="#9FB3C8" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <DataGrid ItemsSource="{Binding SyncScopeStatuses}"
                                          SelectedItem="{Binding SelectedSyncScopeStatus}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="구분" Binding="{Binding ScopeTypeText}" Width="70"/>
                                        <DataGridTextColumn Header="대상" Binding="{Binding ScopeDisplayName}" Width="130"/>
                                        <DataGridTextColumn Header="대기건수" Binding="{Binding PendingCount}" Width="80"/>
                                        <DataGridTextColumn Header="대기요약" Binding="{Binding PendingSummary}" Width="2*"/>
                                        <DataGridTextColumn Header="계정상태" Binding="{Binding CredentialStatusText}" Width="150"/>
                                        <DataGridTextColumn Header="계정" Binding="{Binding CredentialUsername}" Width="120"/>
                                        <DataGridTextColumn Header="저장시각" Binding="{Binding SavedAtText}" Width="160"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem x:Name="RecycleBinTab" Header="휴지통">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <TextBlock Text="삭제 백업 / 복원" Foreground="#4FC3F7" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="거래처, 계약서, 품목, 전표, 수금/지급, 거래내역 삭제 시 바로 영구 제거하지 않고 휴지통에 보관합니다."
                                       Foreground="#9FB3C8"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>

                            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding RecycleBinSummary}" Foreground="#90CAF9" VerticalAlignment="Center"/>

                                <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Border Background="#1E3A5F" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding RecycleBinCustomerCount, StringFormat=거래처 {0:N0}}" Foreground="#B3E5FC" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#30475E" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding RecycleBinContractCount, StringFormat=계약서 {0:N0}}" Foreground="#D1C4E9" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#415A77" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding RecycleBinInvoiceCount, StringFormat=전표 {0:N0}}" Foreground="#C5E1A5" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <Border Background="#7C2D12" CornerRadius="12" Padding="10,4">
                                        <TextBlock Text="{Binding RecycleBinTotalCount, StringFormat=전체 {0:N0}}" Foreground="#FFE0B2" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </WrapPanel>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#102039" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12" Margin="0,12,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="구분" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Width="150"
                                      ItemsSource="{Binding RecycleBinTypeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedItem="{Binding SelectedRecycleBinTypeOption}"
                                      Margin="0,0,10,0"/>

                            <TextBlock Text="검색" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="280"
                                     Text="{Binding RecycleBinSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,10,0"/>

                            <Button Content="새로고침"
                                    Background="#455A64"
                                    Command="{Binding ReloadRecycleBinCommand}"
                                    Margin="0,0,6,0"/>
                            <Button Content="현재 필터 전체 선택"
                                    Background="#546E7A"
                                    Command="{Binding MarkAllFilteredRecycleBinEntriesCommand}"
                                    Margin="0,0,6,0"
                                    IsEnabled="{Binding HasRecycleBinEntries}"/>
                            <Button Content="선택 해제"
                                    Background="#37474F"
                                    Command="{Binding ClearRecycleBinMarksCommand}"
                                    Margin="0,0,6,0"
                                    IsEnabled="{Binding HasMarkedRecycleBinEntries}"/>
                            <Button Content="체크 항목 복원"
                                    Background="#1E88E5"
                                    Command="{Binding RestoreMarkedRecycleBinEntriesCommand}"
                                    Margin="0,0,6,0"
                                    IsEnabled="{Binding HasMarkedRecycleBinEntries}"/>
                            <Button Content="체크 항목 영구삭제"
                                    Background="#C62828"
                                    Command="{Binding PermanentlyDeleteMarkedRecycleBinEntriesCommand}"
                                    IsEnabled="{Binding HasMarkedRecycleBinEntries}"/>
                            <TextBlock Text="{Binding MarkedRecycleBinCount, StringFormat=선택 {0:N0}건}"
                                       Foreground="#FFD54F"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                    <TextBlock Text="삭제된 항목 목록" Foreground="#4FC3F7" FontWeight="Bold"/>
                                </Border>
                                <DataGrid ItemsSource="{Binding RecycleBinEntries}"
                                          SelectedItem="{Binding SelectedRecycleBinEntry}"
                                          IsReadOnly="False"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="선택" Binding="{Binding IsMarked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                        <DataGridTextColumn Header="구분" Binding="{Binding KindText}" Width="110" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="제목" Binding="{Binding Title}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="보조정보" Binding="{Binding Subtitle}" Width="1.2*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="삭제시각" Binding="{Binding DeletedAtLocalText}" Width="150" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="복원 / 영구삭제 상세" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="삭제된 항목을 선택하면 복원 전 내용을 미리 확인하고, 필요 시 영구삭제까지 처리할 수 있습니다."
                                               Foreground="#9FB3C8"
                                               Margin="0,8,0,12"
                                               TextWrapping="Wrap"/>

                                    <Label Content="구분"/>
                                    <TextBlock Text="{Binding SelectedRecycleBinEntry.KindText, TargetNullValue=항목을 선택하세요.}" Margin="0,0,0,10"/>

                                    <Label Content="제목"/>
                                    <TextBlock Text="{Binding SelectedRecycleBinEntry.Title}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                    <Label Content="보조정보"/>
                                    <TextBlock Text="{Binding SelectedRecycleBinEntry.Subtitle}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                    <Label Content="상세"/>
                                    <TextBlock Text="{Binding SelectedRecycleBinEntry.Detail}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                    <Label Content="삭제시각"/>
                                    <TextBlock Text="{Binding SelectedRecycleBinEntry.DeletedAtLocalText}" Margin="0,0,0,12"/>

                                    <Label Content="삭제 차단 사유"/>
                                    <Border Background="#102039" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedRecycleBinDependencySummary}" TextWrapping="Wrap" Foreground="#FFD180"/>
                                            <TextBlock Text="삭제 차단 사유를 불러오는 중입니다."
                                                       Margin="0,8,0,0"
                                                       Foreground="#90CAF9"
                                                       Visibility="{Binding IsRecycleBinDependencyBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding SelectedRecycleBinDependencies}"
                                                  Visibility="{Binding HasSelectedRecycleBinDependencies, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#132742" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayText}" Foreground="#B3E5FC" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Detail}" Foreground="#9FB3C8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Background="#102039"
                                            BorderBrush="#2E4060"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding HasSelectedRecycleBinMergeCandidates, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="중복 거래처 정리" Foreground="#4FC3F7" FontWeight="Bold"/>
                                            <TextBlock Text="삭제된 거래처에 남아 있는 연결 데이터를 다른 활성 거래처로 옮긴 뒤 영구삭제할 수 있습니다."
                                                       Foreground="#9FB3C8"
                                                       Margin="0,6,0,10"
                                                       TextWrapping="Wrap"/>
                                            <ComboBox ItemsSource="{Binding SelectedRecycleBinMergeCandidates}"
                                                      SelectedItem="{Binding SelectedRecycleBinMergeTarget}"
                                                      DisplayMemberPath="DisplayText"
                                                      Height="34"
                                                      Margin="0,0,0,10"/>
                                            <Button Content="선택 거래처로 연결 이동 후 영구삭제"
                                                    Background="#8E24AA"
                                                    Command="{Binding MergeSelectedRecycleBinCustomerCommand}"
                                                    IsEnabled="{Binding CanMergeSelectedRecycleBinCustomer}"/>
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel>
                                        <Button Content="선택 항목 복원"
                                                Background="#1565C0"
                                                Command="{Binding RestoreSelectedRecycleBinEntryCommand}"
                                                Margin="0,0,8,0"
                                                IsEnabled="{Binding HasSelectedRecycleBinEntry}"/>
                                        <Button Content="선택 항목 영구삭제"
                                                Background="#C62828"
                                                Command="{Binding PermanentlyDeleteSelectedRecycleBinEntryCommand}"
                                                IsEnabled="{Binding HasSelectedRecycleBinEntry}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem x:Name="UpdateTab" Header="버전 / 업데이트">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="버전 / 업데이트" Foreground="#4FC3F7" FontWeight="Bold" FontSize="18"/>
                                    <TextBlock Text="현재 설치 버전과 NAS 배포본을 비교해 내부 업데이트를 진행합니다." Foreground="#9FB3C8" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                                    <Button Content="업데이트 확인"
                                            Background="#455A64"
                                            Margin="0,0,8,0"
                                            Command="{Binding CheckForUpdatesCommand}"/>
                                    <Button Content="업데이트 시작"
                                            Background="#1565C0"
                                            Command="{Binding StartDesktopUpdateCommand}"
                                            IsEnabled="{Binding IsUpdateAvailable}"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1.8*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="설치 상태" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Label Grid.Row="0" Grid.Column="0" Content="현재 버전"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentAppVersion}" VerticalAlignment="Center"/>

                                        <Label Grid.Row="1" Grid.Column="0" Content="최신 버전"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LatestDesktopVersion}" VerticalAlignment="Center"/>

                                        <Label Grid.Row="2" Grid.Column="0" Content="배포 시각"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UpdateReleasedAtText}" VerticalAlignment="Center"/>

                                        <Label Grid.Row="3" Grid.Column="0" Content="상태"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding UpdateStatusText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="배포 메모" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                                    <Border Background="#102039" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,14,0,0">
                                        <TextBlock Text="{Binding UpdateNotes}" Foreground="#EAF2FF" TextWrapping="Wrap"/>
                                    </Border>
                                    <TextBlock Text="업데이트 시작을 누르면 현재 앱이 저장/동기화 후 종료되고, 다운로드/설치가 완료되면 자동으로 다시 실행됩니다."
                                               Foreground="#9FB3C8"
                                               Margin="0,14,0,0"
                                               TextWrapping="Wrap"/>
                                    <Border Background="#7C2D12"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,12,0,0">
                                        <TextBlock Text="이 버전부터 내부 업데이트 도우미가 포함됩니다. 이미 설치된 예전 버전은 이번 빌드를 한 번 설치한 뒤부터 내부 업데이트를 사용할 수 있습니다."
                                                   Foreground="#FFE0B2"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar Width="220" Height="12" IsIndeterminate="{Binding IsBusy}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#90CAF9" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>

<Window x:Class="거래플랜.Desktop.App.Views.AttachmentSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="첨부서류 선택"
        Width="760"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E">
    <Window.Resources>
        <Style x:Key="DialogActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="112"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A2B4A" Padding="16,14" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="대금청구서 첨부서류 선택" Foreground="#EAF2FF" FontFamily="맑은 고딕" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#A7D1FF" FontFamily="맑은 고딕" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="14"
                BorderBrush="#2E4060"
                BorderThickness="1"
                Background="#1A2B4A"
                CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6"
                                    Padding="12,10"
                                    CornerRadius="6"
                                    BorderThickness="1"
                                    BorderBrush="#2E4060"
                                    Background="#122038">
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          IsEnabled="{Binding IsToggleEnabled}"
                                          Foreground="#EAF2FF"
                                          FontFamily="맑은 고딕"
                                          FontSize="14"
                                          VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Width="34"
                                                   Text="{Binding OrderDisplay}"
                                                   Foreground="#90CAF9"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                Padding="14,12"
                Margin="0,12,0,0"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="체크한 순서가 인쇄 순서로 반영됩니다."
                           Foreground="#90CAF9"
                           FontFamily="맑은 고딕"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="순서 초기화"
                            Style="{StaticResource DialogActionButtonStyle}"
                            Width="128"
                            Background="#526985"
                            Foreground="White"
                            Command="{Binding ResetOrderCommand}"/>
                    <Button Content="확인"
                            Style="{StaticResource DialogActionButtonStyle}"
                            Background="#1F7ACC"
                            Foreground="White"
                            Command="{Binding ConfirmCommand}"/>
                    <Button Content="취소"
                            Style="{StaticResource DialogActionButtonStyle}"
                            Margin="0"
                            Background="#3D4F66"
                            Foreground="White"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>


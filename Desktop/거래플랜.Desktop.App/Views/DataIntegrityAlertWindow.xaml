<Window x:Class="거래플랜.Desktop.App.Views.DataIntegrityAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="운영 점검 알림" Width="1040" Height="680" MinWidth="920" MinHeight="560"
        WindowStartupLocation="CenterOwner" Background="#0B1628" KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Foreground" Value="#DDEBFF"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E5C7D"/>
            <Setter Property="BorderBrush" Value="#4C6F91"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Border" x:Key="PanelBorder">
            <Setter Property="Background" Value="#14243A"/>
            <Setter Property="BorderBrush" Value="#2A4666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="운영 점검 알림" FontSize="30" FontWeight="Bold" Foreground="#5BD4FF"/>
                    <TextBlock Text="{Binding HeadingText}" FontSize="16" Foreground="#B8C7D8" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding ScannedAtText}" FontSize="13" Foreground="#7F93AA" Margin="0,8,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#071222" BorderBrush="#2A4666" BorderThickness="1" CornerRadius="6" Padding="18" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="위험 신호" Foreground="#8FB6D8" FontSize="13" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding SummaryText}" Foreground="#FFD56B" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="확인된 항목" FontSize="20" FontWeight="Bold" Foreground="#61D4FF" Margin="0,0,0,12"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Summaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0E1D31" BorderBrush="#28445F" BorderThickness="1" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding SeverityDisplay}" Foreground="#FF8D8D" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Area}" Foreground="#8BA2BA" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,14,0">
                                            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold" Foreground="#EAF4FF"/>
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#B8C7D8" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding SuggestedAction}" TextWrapping="Wrap" Foreground="#7FD0FF" Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="20" FontWeight="Bold" Foreground="#FFD56B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Content="자세히 보기" Click="DetailsButton_Click" Background="#1976A8"/>
                                            <Button Content="선택 항목 자동 수정" Click="FixButton_Click" Background="#00897B"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="알림은 데이터를 자동으로 고치지 않습니다. 각 바로가기에서 원본 화면을 열어 확인 후 저장하세요." Foreground="#93A8BE" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="전체 자세히 보기" Click="AllDetailsButton_Click" Background="#394F66"/>
                <Button Content="닫기(F12)" Click="CloseButton_Click" Background="#455A64"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

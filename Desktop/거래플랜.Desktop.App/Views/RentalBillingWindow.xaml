<Window x:Class="거래플랜.Desktop.App.Views.RentalBillingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="렌탈 청구관리"
        Height="960"
        Width="1680"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#C7D7EA"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#C7D7EA"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RentalBillingComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
            <Setter Property="Background" Value="#D9E6F5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#90CAF9"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#64B5F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource RentalBillingComboBoxItemStyle}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#C7D7EA"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="SelectedDateFormat" Value="Short"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="MaxWidth" Value="150"/>
            <Setter Property="CalendarStyle" Value="{StaticResource GeoraePlanDatePickerCalendarStyle}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#C7D7EA"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0,4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="30"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#C7D7EA"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#C7D7EA"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RentalDatePickerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}">
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BillingDetailLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Margin" Value="0,0,4,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BillingAnchorMonthLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BillingDetailLabelStyle}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style x:Key="BillingAnchorMonthComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                    <Setter Property="Background" Value="#C7D7EA"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="SettlementBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#324863"/>
            <Setter Property="BorderBrush" Value="#45617C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettlementBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SelectedBillingMetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#9FB3C8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SelectedBillingMetricValueStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="렌탈 청구관리" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7"/>
                    <TextBlock Text="청구서 표시 품목(거래명세서 출력 라인)과 내부 포함 장비(실제 청구/전표 대상 자산)를 분리 관리합니다. 저장 시 내부 포함 장비의 설치 거래처/청구 연결만 함께 반영됩니다." Foreground="#9FB3C8" Margin="0,4,0,0"/>
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="새로고침" Margin="0,0,6,6" Command="{Binding ReloadCommand}"/>
                    <Button Content="신규 렌탈 거래처 등록" Background="#1565C0" BorderBrush="#1565C0" Margin="0,0,6,6" Click="NewRentalCustomerButton_Click"/>
                    <Button Content="신규 설정" Background="#3949AB" BorderBrush="#3949AB" Margin="0,0,6,6" Command="{Binding NewProfileCommand}"/>
                    <Button Content="저장" Background="#1B5E20" BorderBrush="#1B5E20" Margin="0,0,6,6" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}" ToolTip="청구설정 필요 장비를 선택한 뒤 저장하면 청구 프로필이 생성됩니다."/>
                    <Button Content="선택 월 청구서 만들기" Background="#2E7D32" BorderBrush="#2E7D32" Margin="0,0,6,6" Click="StartBillingButton_Click" IsEnabled="{Binding CanStartBillingSelected}"
                            ToolTip="청구일 전후와 관계없이 조회/작성 기준일에 해당하는 전표를 생성하거나 기존 청구서를 엽니다."/>
                    <Button Content="선택 청구 보류" Background="#F9A825" BorderBrush="#F9A825" Margin="0,0,6,6" Command="{Binding HoldBillingCommand}" IsEnabled="{Binding CanHoldSelected}"/>
                    <Button Content="입금 등록" Background="#00897B" BorderBrush="#00897B" Margin="0,0,6,6" Click="RegisterSettlementButton_Click" IsEnabled="{Binding CanRegisterSettlementSelected}"/>
                    <Button Content="완납 처리" Background="#00695C" BorderBrush="#00695C" Margin="0,0,6,6" Command="{Binding MarkCompletedCommand}" IsEnabled="{Binding CanMarkCompletedSelected}"/>
                    <Button Content="선택 청구 삭제" Background="#C62828" BorderBrush="#C62828" Margin="0,0,6,6" Command="{Binding DeleteCommand}" IsEnabled="{Binding CanDeleteSelected}"/>
                    <Button Content="그룹을 개별 청구건으로 보기" Background="#455A64" BorderBrush="#455A64" Margin="0,0,6,6" Command="{Binding ExpandSelectedSummaryCommand}" IsEnabled="{Binding CanExpandSelectedSummary}" ToolTip="거래처 그룹을 개별 청구 프로필로 전환합니다."/>
                    <Button Content="체크 청구 일괄삭제" Background="#8E24AA" BorderBrush="#8E24AA" Margin="0,0,6,6" Command="{Binding DeleteCheckedCommand}"/>
                    <Button Content="닫기 (F12)" Click="CloseButton_Click" Margin="0,0,0,6"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <StackPanel>
                    <TextBlock Text="조회 건수" Foreground="#9FB3C8"/>
                    <TextBlock Text="{Binding TotalCount, StringFormat=N0}" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <StackPanel>
                    <TextBlock Text="알림 대상" Foreground="#9FB3C8"/>
                    <TextBlock Text="{Binding DueCount, StringFormat=N0}" FontSize="22" FontWeight="Bold" Foreground="#FFB74D" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <StackPanel>
                    <TextBlock Text="이상 데이터" Foreground="#9FB3C8"/>
                    <TextBlock Text="{Binding IssueCount, StringFormat=N0}" FontSize="22" FontWeight="Bold" Foreground="#EF5350" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <StackPanel>
                    <TextBlock Text="완료 건수" Foreground="#9FB3C8"/>
                    <TextBlock Text="{Binding CompletedCount, StringFormat=N0}" FontSize="22" FontWeight="Bold" Foreground="#66BB6A" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="8" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <StackPanel>
                    <TextBlock Text="부분입금" Foreground="#9FB3C8"/>
                    <TextBlock Text="{Binding PartialSettlementCount, StringFormat=N0}" FontSize="22" FontWeight="Bold" Foreground="#4DD0E1" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="10" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <StackPanel>
                    <TextBlock Text="총 미수금" Foreground="#9FB3C8"/>
                    <TextBlock Text="{Binding TotalOutstandingAmount, StringFormat=N0}" FontSize="22" FontWeight="Bold" Foreground="#81D4FA" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,10,0,0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <StackPanel>
                <Border Background="#4A341F"
                        BorderBrush="#FFB74D"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,0,0,10"
                        Visibility="{Binding HasPastUnresolved, Converter={StaticResource BoolToVisibility}}">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Content="미처리 거래처만 보기"
                                Background="#F9A825"
                                BorderBrush="#F9A825"
                                Margin="10,0,0,0"
                                MinWidth="148"
                                Command="{Binding ShowPastDueOnlyCommand}"/>
                        <TextBlock Text="{Binding PastUnresolvedSummaryText}"
                                   Foreground="#FFE0B2"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </DockPanel>
                </Border>
                <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="검색어" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Width="280" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=350}" Margin="0,0,12,0"/>
                <TextBlock Text="담당지점" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="180" ItemsSource="{Binding OfficeOptions}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedOfficeFilter}" Margin="0,0,12,0"/>
                <TextBlock Text="상태" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="140" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatusFilter}" Margin="0,0,12,0"/>
                <CheckBox Content="알림대상만" IsChecked="{Binding DueOnly}" Foreground="#EAF2FF" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <CheckBox Content="과거 미처리만 보기" IsChecked="{Binding PastDueOnly}" Foreground="#EAF2FF" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <CheckBox Content="개별 청구건 보기" IsChecked="{Binding ShowIndividualProfiles}" Foreground="#EAF2FF" VerticalAlignment="Center" Margin="0,0,12,0" ToolTip="거래처별 묶음 대신 개별 청구 프로필을 모두 표시합니다."/>
                <TextBlock Text="조회/작성 기준일" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Width="180" SelectedDate="{Binding ReferenceDate, Converter={StaticResource DateOnlyConverter}}" SelectedDateFormat="Short">
                    <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                </DatePicker>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}" BorderThickness="0" IsReadOnly="False" MouseDoubleClick="BillingRowsDataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="46">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate><TextBlock Text="선택" HorizontalAlignment="Center"/></DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="거래처명" Binding="{Binding CustomerDisplayName}" Width="220" IsReadOnly="True"/>
                        <DataGridTextColumn Header="청구주기" Binding="{Binding BillingCycleDisplay}" Width="88" IsReadOnly="True"/>
                        <DataGridTextColumn Header="설치위치" Binding="{Binding InstallLocationDisplay}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="예정일" Binding="{Binding NextBillingDate}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="청구기간" Binding="{Binding CurrentBillingPeriodLabel}" Width="130" IsReadOnly="True"/>
                        <DataGridTextColumn Header="청구상태" Binding="{Binding DisplayStatus}" Width="88" IsReadOnly="True"/>
                        <DataGridTextColumn Header="청구설정" Binding="{Binding BillingSetupStatus}" Width="116" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="수금상태" Width="108" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="SettlementBadge" Style="{StaticResource SettlementBadgeBorderStyle}">
                                        <TextBlock x:Name="SettlementBadgeText" Text="{Binding SettlementStatusDisplay}" Style="{StaticResource SettlementBadgeTextStyle}"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding SettlementStatusDisplay}" Value="부분입금">
                                            <Setter TargetName="SettlementBadge" Property="Background" Value="#1F4A36"/>
                                            <Setter TargetName="SettlementBadge" Property="BorderBrush" Value="#43A047"/>
                                            <Setter TargetName="SettlementBadgeText" Property="Foreground" Value="#C8E6C9"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SettlementStatusDisplay}" Value="입금확인">
                                            <Setter TargetName="SettlementBadge" Property="Background" Value="#1F4A36"/>
                                            <Setter TargetName="SettlementBadge" Property="BorderBrush" Value="#43A047"/>
                                            <Setter TargetName="SettlementBadgeText" Property="Foreground" Value="#C8E6C9"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SettlementStatusDisplay}" Value="미입금">
                                            <Setter TargetName="SettlementBadge" Property="Background" Value="#324863"/>
                                            <Setter TargetName="SettlementBadge" Property="BorderBrush" Value="#4FC3F7"/>
                                            <Setter TargetName="SettlementBadgeText" Property="Foreground" Value="#B3E5FC"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SettlementStatusDisplay}" Value="청구 전">
                                            <Setter TargetName="SettlementBadge" Property="Background" Value="#33465C"/>
                                            <Setter TargetName="SettlementBadge" Property="BorderBrush" Value="#90A4AE"/>
                                            <Setter TargetName="SettlementBadgeText" Property="Foreground" Value="#CFD8DC"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SettlementStatusDisplay}" Value="카드승인완료">
                                            <Setter TargetName="SettlementBadge" Property="Background" Value="#4A4A4A"/>
                                            <Setter TargetName="SettlementBadge" Property="BorderBrush" Value="#9E9E9E"/>
                                            <Setter TargetName="SettlementBadgeText" Property="Foreground" Value="#ECEFF1"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="유형" Binding="{Binding BillingType}" Width="72" IsReadOnly="True"/>
                        <DataGridTextColumn Header="표시품목수" Binding="{Binding TemplateItemCount}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="내부장비수" Binding="{Binding IncludedAssetCount}" Width="92" IsReadOnly="True"/>
                        <DataGridTextColumn Header="청구금액" Binding="{Binding CurrentBilledAmount, StringFormat=N0}" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="누적수금" Binding="{Binding SettledAmount, StringFormat=N0}" Width="110" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="미수금" Width="100" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding OutstandingAmount, StringFormat=N0}"
                                               Margin="0,0,8,0"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               Foreground="#FFB74D"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="마지막수금일" Binding="{Binding LastSettledDate}" Width="112" IsReadOnly="True"/>
                        <DataGridTextColumn Header="이상" Binding="{Binding DataIssueSummary}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="담당지점" Binding="{Binding ResponsibleOfficeName}" Width="110" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="렌탈 청구 상세" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,10"/>

                        <Border Background="#263A55"
                                BorderBrush="#4FC3F7"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,10"
                                Visibility="{Binding IsCustomerGroupSelection, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="거래처 그룹 보기입니다. 중복 거래처처럼 보이지 않도록 청구 프로필/청구설정 필요 장비를 묶어 보여줍니다. 저장/삭제/장비연결 편집은 '개별 청구건 보기'에서 진행합니다."
                                       Foreground="#B3E5FC"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#4A341F"
                                BorderBrush="#FFB74D"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8"
                                Margin="0,0,0,10"
                                Visibility="{Binding SelectedRow.HasUnlinkedBillingAssets, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding SelectedRow.BillingSetupHelpText}"
                                       Foreground="#FFE0B2"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#223754" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="선택 청구 요약" Foreground="#4FC3F7" FontWeight="Bold"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="청구기간" Style="{StaticResource SelectedBillingMetricLabelStyle}"/>
                                        <TextBlock Text="{Binding SelectedRow.CurrentBillingPeriodLabel}" Style="{StaticResource SelectedBillingMetricValueStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="청구금액" Style="{StaticResource SelectedBillingMetricLabelStyle}"/>
                                        <TextBlock Text="{Binding SelectedRow.CurrentBilledAmount, StringFormat=N0}" Style="{StaticResource SelectedBillingMetricValueStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="4">
                                        <TextBlock Text="누적수금" Style="{StaticResource SelectedBillingMetricLabelStyle}"/>
                                        <TextBlock Text="{Binding SelectedRow.SettledAmount, StringFormat=N0}" Style="{StaticResource SelectedBillingMetricValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                                        <TextBlock Text="미수금" Style="{StaticResource SelectedBillingMetricLabelStyle}"/>
                                        <TextBlock Text="{Binding SelectedRow.OutstandingAmount, StringFormat=N0}" Style="{StaticResource SelectedBillingMetricValueStyle}" Foreground="#FFCC80"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                        <TextBlock Text="수금상태" Style="{StaticResource SelectedBillingMetricLabelStyle}"/>
                                        <TextBlock Text="{Binding SelectedRow.SettlementStatusDisplay}" Style="{StaticResource SelectedBillingMetricValueStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,10,0,0">
                                        <TextBlock Text="마지막수금일" Style="{StaticResource SelectedBillingMetricLabelStyle}"/>
                                        <TextBlock Text="{Binding SelectedRow.LastSettledDate}" Style="{StaticResource SelectedBillingMetricValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="입금은 '입금 등록' 또는 아래 '청구/입금 내역'의 월별 버튼에서 기록됩니다."
                                           Foreground="#90CAF9"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#4A341F"
                                BorderBrush="#FFB74D"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8"
                                Margin="0,0,0,10"
                                Visibility="{Binding SelectedRowHasPastUnresolved, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding SelectedPastUnresolvedSummaryText}"
                                       Foreground="#FFE0B2"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="청구/입금 내역" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,6"/>
                        <DataGrid ItemsSource="{Binding BillingHistoryRows}"
                                  SelectedItem="{Binding SelectedBillingHistory}"
                                  PreviewMouseRightButtonDown="BillingHistoryDataGrid_PreviewMouseRightButtonDown"
                                  Height="155"
                                  Margin="0,0,0,10"
                                  IsReadOnly="True">
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="선택 내역 삭제"
                                              Command="{Binding DeleteSelectedBillingHistoryCommand}"
                                              IsEnabled="{Binding CanDeleteSelectedBillingHistory}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="청구기간" Binding="{Binding PeriodLabel}" Width="120"/>
                                <DataGridTextColumn Header="청구일" Binding="{Binding ScheduledDate, StringFormat={}{0:yyyy-MM-dd}}" Width="96"/>
                                <DataGridTextColumn Header="청구금액" Binding="{Binding BilledAmount, StringFormat=N0}" Width="92"/>
                                <DataGridTextColumn Header="입금액" Binding="{Binding SettledAmount, StringFormat=N0}" Width="86"/>
                                <DataGridTextColumn Header="미수금" Binding="{Binding OutstandingAmount, StringFormat=N0}" Width="86"/>
                                <DataGridTextColumn Header="입금일" Binding="{Binding SettledDate, StringFormat={}{0:yyyy-MM-dd}}" Width="96"/>
                                <DataGridTextColumn Header="상태" Binding="{Binding SettlementStatus}" Width="84"/>
                                <DataGridTemplateColumn Header="작업" Width="92">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding ActionLabel}"
                                                    Height="28"
                                                    MinWidth="76"
                                                    Padding="8,0"
                                                    Click="BillingHistoryRegisterButton_Click"
                                                    IsEnabled="{Binding CanRegisterSettlement}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid IsEnabled="{Binding CanEditBillingProfileDetails}">
                            <Grid.Resources>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BillingDetailLabelStyle}"/>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}"/>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}"/>
                                <Style TargetType="DatePicker" BasedOn="{StaticResource {x:Type DatePicker}}"/>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="거래처명"/>
                            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding EditCustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/>
                                <Button Grid.Column="1" Content="조회" MinWidth="72" Padding="10,0" Click="CustomerLookupButton_Click"/>
                            </Grid>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="상태"/>
                            <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding EditBillingStatus, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="설치위치"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditInstallLocation, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="사업자번호"/>
                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding EditBusinessNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="담당지점"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding EditOfficeOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding EditOfficeCode}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="이메일"/>
                            <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="청구유형"/>
                            <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding BillingTypeOptions}" SelectedItem="{Binding EditBillingType}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="선불/후불"/>
                            <ComboBox Grid.Row="3" Grid.Column="4" ItemsSource="{Binding BillingAdvanceModeOptions}" SelectedItem="{Binding EditBillingAdvanceMode}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="청구일 유형"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding BillingDayModeOptions}" SelectedItem="{Binding EditBillingDayMode}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="청구일"/>
                            <TextBox Grid.Row="4" Grid.Column="4" Text="{Binding EditBillingDay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsFixedBillingDayMode}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="청구 주기(개월)"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditBillingCycleMonths, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="5" Grid.Column="3" Text="청구기간 시작월"/>
                            <ComboBox Grid.Row="5" Grid.Column="4" Style="{StaticResource BillingAnchorMonthComboBoxStyle}" ItemsSource="{Binding BillingAnchorMonthOptions}" SelectedItem="{Binding EditBillingAnchorMonth}" Margin="0,0,0,6">
                                <ComboBox.Resources>
                                    <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="Black"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="계약 체결일"/>
                            <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,0,0,6">
                                <DatePicker SelectedDate="{Binding EditContractDate}" SelectedDateFormat="Short">
                                    <DatePicker.Resources>
                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/>
                                    </DatePicker.Resources>
                                </DatePicker>
                                <TextBlock Text="{Binding ContractDateWarningMessage}"
                                           Foreground="#FFCC80"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ShouldShowContractDateWarning, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="6" Grid.Column="3" Text="월 기준금액"/>
                            <TextBox Grid.Row="6" Grid.Column="4" Text="{Binding EditMonthlyAmount, StringFormat=N0}" IsReadOnly="True" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="서류 발송 규칙"/>
                            <ComboBox Grid.Row="7" Grid.Column="1" ItemsSource="{Binding DocumentIssueModeOptions}" SelectedItem="{Binding EditDocumentIssueMode}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="7" Grid.Column="3" Text="선행일수"/>
                            <TextBox Grid.Row="7" Grid.Column="4" Text="{Binding EditDocumentLeadDays, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsDocumentLeadDaysVisible}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="청구방식" Margin="0,0,4,6"/>
                            <ComboBox Grid.Row="8" Grid.Column="1" ItemsSource="{Binding BillingMethodOptions}" SelectedItem="{Binding EditBillingMethod}" Margin="0,0,0,6"/>
                            <TextBlock Grid.Row="8" Grid.Column="3" Text="제출서류" VerticalAlignment="Top" Margin="0,0,4,6"/>
                            <TextBox Grid.Row="8" Grid.Column="4" Text="{Binding EditSubmissionDocuments, UpdateSourceTrigger=PropertyChanged}" Height="66" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="메모" VerticalAlignment="Top" Margin="0,2,4,0"/>
                            <TextBox Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}" Height="66" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,2,0,0"/>
                        </Grid>

                        <WrapPanel Margin="0,10,0,10">
                            <Button Content="계약서 열기" Background="#2E7D32" BorderBrush="#2E7D32" Command="{Binding OpenCustomerContractCommand}"/>
                        </WrapPanel>

                        <Border Background="#223754" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="표시품목 요약" Foreground="#4FC3F7" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TemplateSummary}" Margin="0,6,0,0"/>
                                <Border Background="#4A2F13"
                                        BorderBrush="#FFB74D"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8"
                                        Margin="0,6,0,0"
                                        Visibility="{Binding HasBillingAssetCoverageWarning, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding BillingAssetCoverageWarning}"
                                               Foreground="#FFCC80"
                                               TextWrapping="Wrap"/>
                                </Border>
                                <TextBlock Text="{Binding BillingSchedulePreviewText}" Foreground="#B3E5FC" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding DocumentIssuePreviewText}" Foreground="#B3E5FC" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="표시 라인 추가" Background="#3949AB" BorderBrush="#3949AB" Margin="0,0,8,0" Command="{Binding AddTemplateItemCommand}" IsEnabled="{Binding CanSave}"/>
                            <Button Content="▲" Width="34" MinWidth="34" Padding="0" Background="#455A64" BorderBrush="#455A64" Margin="0,0,4,0" Command="{Binding MoveTemplateItemUpCommand}" ToolTip="선택한 표시 품목을 위로 이동"/>
                            <Button Content="▼" Width="34" MinWidth="34" Padding="0" Background="#455A64" BorderBrush="#455A64" Margin="0,0,8,0" Command="{Binding MoveTemplateItemDownCommand}" ToolTip="선택한 표시 품목을 아래로 이동"/>
                            <Button Content="선택 표시 라인 삭제" Background="#C62828" BorderBrush="#C62828" Margin="0,0,8,0" Command="{Binding RemoveTemplateItemCommand}"/>
                            <Button Content="내부 포함 장비 연결" Background="#6A1B9A" BorderBrush="#6A1B9A" Click="OpenAssetLinkDialogButton_Click" IsEnabled="{Binding CanOpenAssetLinkDialog}"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding ApplySelectedAssetsHint}" Foreground="#90CAF9" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock Text="청구유형이 묶음/개별이면 표시품목 라인유형이 자동으로 같은 값으로 고정됩니다. 품목별로 섞어 쓰려면 청구유형을 혼합으로 선택하세요."
                                   Foreground="#90CAF9" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <TextBlock Text="청구서 표시 품목 (거래명세서 출력 라인)" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="거래명세서/청구서에 인쇄될 표시 라인입니다. 이 표에서는 품명·규격·라인유형만 정하고, 실제 청구/전표 대상 자산은 아래 '내부 포함 장비' 목록에서만 결정됩니다. 개별 라인은 같은 모델명끼리 청구서 만들기 시 수량 합산됩니다."
                                   Foreground="#90CAF9"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>
                        <DataGrid ItemsSource="{Binding TemplateItems}" SelectedItem="{Binding SelectedTemplateItem}" Height="210" Margin="0,0,0,10" IsReadOnly="{Binding IsCustomerGroupSelection}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="라인유형" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.BillingLineModeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding BillingLineMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding DataContext.CanEditTemplateLineMode, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="표시 품목명" Binding="{Binding DisplayItemName, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                                <DataGridTextColumn Header="규격" Binding="{Binding Specification, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                                <DataGridTextColumn Header="수량" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                <DataGridTextColumn Header="단위" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="62"/>
                                <DataGridTextColumn Header="단가" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                <DataGridTextColumn Header="금액" Binding="{Binding Amount, StringFormat=N0}" Width="90" IsReadOnly="True"/>
                                <DataGridTextColumn Header="자재번호" Binding="{Binding MaterialNumber, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                <DataGridTextColumn Header="연결장비" Binding="{Binding IncludedAssetSummary}" Width="220" IsReadOnly="True"/>
                                <DataGridTextColumn Header="대표자산" Binding="{Binding RepresentativeAssetSummary}" Width="180" IsReadOnly="True"/>
                                <DataGridTextColumn Header="비고" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Expander Header="내부 포함 장비 (실제 청구/전표 대상 자산)" IsExpanded="False" Margin="0,0,0,10" IsEnabled="{Binding CanEditBillingProfileDetails}">
                            <StackPanel>
                                <WrapPanel Margin="0,8,0,8">
                                    <Button Content="대표자산 지정" Background="#1565C0" BorderBrush="#1565C0" Margin="0,0,8,0" Command="{Binding SetRepresentativeAssetCommand}" IsEnabled="{Binding CanSetRepresentativeAsset}"/>
                                    <Button Content="선택 장비 삭제" Background="#C62828" BorderBrush="#C62828" Margin="0,0,8,0" Command="{Binding RemoveIncludedAssetCommand}" IsEnabled="{Binding CanRemoveIncludedAsset}"/>
                                    <TextBlock Text="이 목록의 장비만 실제 청구/전표 생성 대상입니다. 청구서 표시 품목명을 바꿔도 자산이 추가/삭제되지 않습니다. 삭제 후 저장하면 해당 장비만 현재 청구 연결에서 해제됩니다." Foreground="#90CAF9" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </WrapPanel>
                                <DataGrid ItemsSource="{Binding IncludedAssets}" SelectedItem="{Binding SelectedIncludedAsset}" Height="190" Margin="0,0,0,10">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="대표" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsRepresentativeAsset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              ToolTip="대표자산으로 지정합니다."/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="시리얼번호" Binding="{Binding MachineNumber}" Width="120"/>
                                        <DataGridTextColumn Header="품명" Binding="{Binding ItemName}" Width="120"/>
                                        <DataGridTextColumn Header="월요금" Binding="{Binding MonthlyFee, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=N0}" Width="90"/>
                                        <DataGridTextColumn Header="현재 거래처" Binding="{Binding CurrentCustomerName}" Width="160"/>
                                        <DataGridTextColumn Header="설치위치" Binding="{Binding InstallLocation}" Width="160"/>
                                        <DataGridTextColumn Header="상태" Binding="{Binding AssetStatus}" Width="76"/>
                                        <DataGridTextColumn Header="청구상태" Binding="{Binding BillingEligibilityStatus}" Width="90"/>
                                        <DataGridTextColumn Header="자산소속" Binding="{Binding AssetScopeDisplay}" Width="170"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="선택 장비 임대 이력" Foreground="#4FC3F7" FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                        <Button Content="임대이력 추가" Background="#1565C0" BorderBrush="#1565C0" Margin="0,0,6,0" Command="{Binding AddIncludedAssetAssignmentHistoryCommand}" IsEnabled="{Binding CanAddIncludedAssetAssignmentHistory}"/>
                                        <Button Content="선택 이력 수정" Background="#3949AB" BorderBrush="#3949AB" Margin="0,0,6,0" Command="{Binding EditIncludedAssetAssignmentHistoryCommand}" IsEnabled="{Binding CanEditIncludedAssetAssignmentHistory}"/>
                                        <Button Content="선택 이력 삭제" Background="#C62828" BorderBrush="#C62828" Command="{Binding DeleteIncludedAssetAssignmentHistoryCommand}" IsEnabled="{Binding CanDeleteIncludedAssetAssignmentHistory}"/>
                                    </WrapPanel>
                                </DockPanel>
                                <DataGrid ItemsSource="{Binding IncludedAssetAssignmentHistories}" SelectedItem="{Binding SelectedIncludedAssetAssignmentHistory}" Height="160" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="상태" Binding="{Binding StatusDisplay}" Width="90"/>
                                        <DataGridTextColumn Header="기간" Binding="{Binding PeriodDisplay}" Width="210"/>
                                        <DataGridTextColumn Header="거래처" Binding="{Binding CustomerName}" Width="160"/>
                                        <DataGridTextColumn Header="설치위치" Binding="{Binding InstallLocation}" Width="150"/>
                                        <DataGridTextColumn Header="청구연결" Binding="{Binding BillingProfileDisplay}" Width="180"/>
                                        <DataGridTextColumn Header="월요금" Binding="{Binding MonthlyFee, StringFormat=N0}" Width="90"/>
                                        <DataGridTextColumn Header="담당지점" Binding="{Binding ResponsibleOfficeName}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="4" Margin="0,10,0,0" Background="#122038" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10">
            <DockPanel LastChildFill="False">
                <ProgressBar Width="220" Height="12" IsIndeterminate="{Binding IsBusy}" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#90CAF9" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>

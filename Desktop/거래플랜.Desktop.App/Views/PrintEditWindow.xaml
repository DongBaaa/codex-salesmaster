<Window x:Class="거래플랜.Desktop.App.Views.PrintEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="출력물 편집"
        Width="1360"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="MaxWidth" Value="150"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,0,4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#101010"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#8F8F8F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#AFC2D8"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#D1E1F2"/>
            <Setter Property="RowBackground" Value="#DCE9F8"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#D8D8D8"/>
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#062445" Padding="12,10">
            <TextBlock Text="출력물 편집" FontSize="22" FontWeight="Bold"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#122038" BorderBrush="#2E4060" BorderThickness="0,1,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#A5D6A7"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="미리보기 갱신" Margin="0,0,8,0" Command="{Binding RefreshPreviewCommand}"/>
                    <Button Content="저장" Margin="0,0,8,0" Background="#DDE9FF" Command="{Binding SaveCommand}"/>
                    <Button Content="닫기" Command="{Binding CloseCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="520"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="전표번호"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="전표일자" Margin="0,6,0,0"/>
                            <DatePicker Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" SelectedDate="{Binding InvoiceDate, Mode=TwoWay}">
                                <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                            </DatePicker>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="유형" Margin="0,6,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding VoucherType, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <Border Background="#203A62" BorderBrush="#3F5D86" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedPreviewDocument, StringFormat={}{0} 편집 항목}"
                                       FontWeight="Bold"
                                       Foreground="#90CAF9"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding PreviewDocumentGuideText}"
                                       Foreground="#B7C9E8"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="※ 저장 시 현재 전표/거래처 출력물에만 저장되며 거래처 원장 정보는 변경하지 않습니다."
                                       Foreground="#A7D1FF"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A2B4A"
                            BorderBrush="#2E4060"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsStatementPreviewSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="거래명세서 편집" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding SettlementAmountLabelText}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding OutstandingAmountLabelText}" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding BalanceAmount, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="전표메모" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="계좌문구" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Text="{Binding BankAccountText, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="하단문구" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" Text="{Binding FooterText, UpdateSourceTrigger=PropertyChanged}"/>
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                    <CheckBox Content="날짜 인쇄" IsChecked="{Binding PrintWithDate}" Foreground="#EAF2FF" Margin="0,0,12,0"/>
                                    <CheckBox Content="단가/금액 인쇄" IsChecked="{Binding PrintWithPrice}" Foreground="#EAF2FF"/>
                                </StackPanel>
                                <TextBlock Grid.Row="6"
                                           Grid.Column="1"
                                           Margin="0,4,0,0"
                                           Foreground="#B7C9E8"
                                           Text="※ 거래명세서 하단의 입금안내/비고 영역에 반영됩니다."
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A2B4A"
                            BorderBrush="#2E4060"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsEstimatePreviewSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="견적서 편집" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="견적기간"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EstimateValidityText, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="특이사항" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding EstimateRemarks, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Margin="0,4,0,0"
                                           Foreground="#B7C9E8"
                                           Text="※ 견적서 상단 견적기간과 하단 특이사항에 반영됩니다."
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A2B4A"
                            BorderBrush="#2E4060"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsPaymentClaimPreviewSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="대금청구서 편집" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="용역명"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="입금계좌" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding BankAccountText, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Margin="0,4,0,0"
                                           Foreground="#B7C9E8"
                                           Text="※ 대금청구서의 용역명/입금계좌 표기에 반영됩니다."
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="공급자 정보" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="사업번호"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SupplierBusinessNumber, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="상호" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SupplierName, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="대표자" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SupplierRepresentative, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="전화번호" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SupplierPhone, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="주소" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SupplierAddress, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="공급받는자 정보" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="사업번호"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BuyerBusinessNumber, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="상호" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding BuyerName, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="대표자" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding BuyerRepresentative, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="전화번호" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Text="{Binding BuyerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="주소" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" Text="{Binding BuyerAddress, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding AmountSectionTitleText}" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="공급가"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SupplyAmount, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="부가세" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding VatAmount, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="합계" Margin="0,6,0,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding TotalAmount, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="#1A2B4A" ShowsPreview="True"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="미리보기 문서" FontWeight="Bold" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding PreviewDocumentOptions}"
                                  SelectedItem="{Binding SelectedPreviewDocument, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  MinHeight="30"/>
                         <TextBlock Grid.Column="2"
                                    Margin="12,0,0,0"
                                    Foreground="#B7C9E8"
                                    Text="{Binding PreviewDocumentGuideText}"
                                    TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#0F1D31" BorderBrush="#2E4060" BorderThickness="1" Padding="6">
                    <DocumentViewer Document="{Binding PreviewDocument}" />
                </Border>

                <Border Grid.Row="2"
                        Margin="0,8,0,0"
                        Height="250"
                        Background="#1A2B4A"
                        BorderBrush="#2E4060"
                        BorderThickness="1"
                        Padding="6"
                        Visibility="{Binding ShowLineEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="{Binding LineEditorTitleText}" FontWeight="Bold" Margin="0,0,4,0"/>
                            <Button Content="행 추가" Command="{Binding AddLineCommand}" Padding="8,3"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding Lines}"
                                  SelectedItem="{Binding SelectedLine}"
                                  CanUserAddRows="False"
                                  IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No" Width="40" Binding="{Binding No, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="품목" Width="*" Binding="{Binding ItemName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="규격" Width="120" Binding="{Binding Specification, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="단위" Width="60" Binding="{Binding Unit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="수량" Width="70" Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="단가" Width="90" Binding="{Binding UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="금액" Width="90" Binding="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="비고" Width="120" Binding="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTemplateColumn Header="삭제" Width="58">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="삭제"
                                                    Padding="4,2"
                                                    Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>

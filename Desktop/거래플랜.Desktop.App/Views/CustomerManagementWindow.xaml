<Window x:Class="거래플랜.Desktop.App.Views.CustomerManagementWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:거래플랜.Desktop.App.Converters"
        Title="거래처 관리"
        Height="820"
        Width="1160"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#90CAF9"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="BorderBrush" Value="#5EAEEB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CustomerGridTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="CustomerGridComboCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A2B4A"
                Padding="12"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="거래처 등록, 수정, 담당지점 변경 즉시저장과 계약서 만료 현황을 관리합니다."
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#4FC3F7"/>
                <TextBlock Text="거래처 등록, 수정, 담당지점 변경 즉시저장과 계약서 만료 현황을 관리합니다."
                           Foreground="#9FB3C8"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,8,0,0"
                Background="#1A2B4A"
                Padding="10"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <Grid Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerFilterLabel"/>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerFilterLabel"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerFilterLabel"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerFilterLabel"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#9FB3C8"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="2"
                            Content="찾기"
                            Margin="0,0,12,0"
                            Command="{Binding SearchCommand}"
                            VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3"
                               Text="검색"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="#9FB3C8"/>
                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding CategoryFilters}"
                              SelectedItem="{Binding SelectedCategoryFilter}"
                              VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5"
                               Text="담당지점"
                               Margin="12,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="#9FB3C8"/>
                    <ComboBox Grid.Column="6"
                              ItemsSource="{Binding OfficeFilters}"
                              SelectedItem="{Binding SelectedOfficeFilter}"
                              VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="7"
                               Text="고객분류"
                               Margin="12,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="#9FB3C8"/>
                    <ComboBox Grid.Column="8"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSortOption}"
                              VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">
                    <Button Content="새 거래처 등록"
                            Background="#1565C0"
                            BorderBrush="#1565C0"
                            Margin="0,0,6,0"
                            Click="CreateCustomerButton_Click"/>
                    <Button Content="선택 거래처 수정"
                            Background="#8E24AA"
                            BorderBrush="#8E24AA"
                            Margin="0,0,6,0"
                            Click="EditCustomerButton_Click"/>
                    <Button Content="선택 거래처 삭제"
                            Background="#C62828"
                            BorderBrush="#C62828"
                            Margin="0,0,6,0"
                            Click="DeleteCustomerButton_Click"/>
                    <Rectangle Width="1"
                               Height="18"
                               Fill="#3E5875"
                               Margin="4,0,10,0"
                               VerticalAlignment="Center"/>
                    <Button Content="담당지점 저장"
                            Background="#1B5E20"
                            BorderBrush="#1B5E20"
                            Margin="0,0,6,0"
                            ToolTip="담당지점 변경은 즉시 저장됩니다. 저장 실패로 남은 변경만 다시 저장합니다."
                            Command="{Binding SaveOfficeChangesCommand}"/>
                    <Button Content="새로고침"
                            Margin="0,0,6,0"
                            Command="{Binding ReloadCommand}"/>
                    <Button Content="닫기"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,8,0,0"
                Background="#2A1E1E"
                Padding="10"
                CornerRadius="6"
                BorderBrush="#7F1D1D"
                BorderThickness="1"
                Visibility="{Binding HasContractAlerts, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="118"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="계약 만료 알림"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#FFCDD2"/>
                    <TextBlock Text="{Binding ContractAlertSummary}"
                               Foreground="#FFEBEE"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding ContractAlerts}"
                          SelectedItem="{x:Null}"
                          IsReadOnly="True"
                          BorderThickness="0"
                          CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="거래처명"
                                            Binding="{Binding CustomerName}"
                                            Width="2*"
                                            ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                        <DataGridTextColumn Header="계약구분"
                                            Binding="{Binding ContractType}"
                                            Width="120"
                                            ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                        <DataGridTextColumn Header="만료일"
                                            Binding="{Binding ExpireDate}"
                                            Width="110"
                                            ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                        <DataGridTextColumn Header="알림"
                                            Binding="{Binding AlertText}"
                                            Width="2*"
                                            ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,8,0,0"
                Background="#1A2B4A"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <DataGrid x:Name="CustomerRowsDataGrid"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}"
                      IsReadOnly="False"
                      BorderThickness="0"
                      MouseDoubleClick="CustomerRowsDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="거래처명" Width="2.2*" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NameOriginal}"
                                           Style="{StaticResource CustomerGridTextStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                        <DataGridTextColumn Header="고객분류"
                                        Binding="{Binding CategoryName, Mode=OneWay}"
                                        Width="120"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                    <DataGridTextColumn Header="거래구분"
                                        Binding="{Binding TradeType, Mode=OneWay}"
                                        Width="110"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                    <DataGridTextColumn Header="사업자번호"
                                        Binding="{Binding BusinessNumber, Mode=OneWay}"
                                        Width="160"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                    <DataGridTextColumn Header="대표전화"
                                        Binding="{Binding Phone, Mode=OneWay}"
                                        Width="140"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                    <DataGridTextColumn Header="계약서"
                                        Binding="{Binding ContractPresenceText, Mode=OneWay}"
                                        Width="82"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                    <DataGridTextColumn Header="계약상태"
                                        Binding="{Binding ContractStatusText, Mode=OneWay}"
                                        Width="130"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource CustomerGridTextStyle}"/>
                    <DataGridTemplateColumn Header="담당지점" Width="172" CellStyle="{StaticResource CustomerGridComboCellStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.OfficeCodes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding ResponsibleOfficeCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectionChanged="ResponsibleOfficeComboBox_SelectionChanged"
                                          Height="28"
                                          MinHeight="28"
                                          Padding="6,2"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Margin="1,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridCheckBoxColumn Header="변경됨"
                                            Binding="{Binding IsModified, Mode=OneWay}"
                                            Width="72"
                                            IsReadOnly="True">
                        <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </Style>
                        </DataGridCheckBoxColumn.ElementStyle>
                    </DataGridCheckBoxColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4"
                Margin="0,10,0,0"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ProgressBar Width="220"
                                 Height="12"
                                 IsIndeterminate="{Binding IsBusy}"
                                 Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#90CAF9"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>

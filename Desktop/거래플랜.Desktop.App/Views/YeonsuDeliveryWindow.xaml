<Window x:Class="거래플랜.Desktop.App.Views.YeonsuDeliveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:거래플랜.Desktop.App.Converters"
        Title="매입/매출 장부"
        Height="860"
        Width="1500"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="MaxWidth" Value="150"/>
            <Setter Property="CalendarStyle" Value="{StaticResource GeoraePlanDatePickerCalendarStyle}"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,0,4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FilterDatePickerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#2D8DE0"/>
            <Setter Property="BorderBrush" Value="#2D8DE0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#47A1F1"/>
                    <Setter Property="BorderBrush" Value="#47A1F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#122038"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9FB3C8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <Style x:Key="RightAlignedCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A2B4A"
                Padding="12"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="매입/매출 장부"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#4FC3F7"/>
                <TextBlock Text="로그인 계정 기준으로 거래처 매입/매출 장부를 조회합니다."
                           Foreground="#9FB3C8"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,8,0,0"
                Background="#1A2B4A"
                Padding="10"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="거래건수" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding SummaryCount, StringFormat={}{0:N0}건}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="매입금액 합계" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding SummaryPurchaseAmount, StringFormat={}{0:N0}원}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="매출금액 합계" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding SummarySalesAmount, StringFormat={}{0:N0}원}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource SummaryCardStyle}">
                        <StackPanel>
                            <TextBlock Text="수익금액 합계" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding SummaryProfitAmount, StringFormat={}{0:N0}원}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource SummaryCardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="수수료 합계" Style="{StaticResource SummaryLabelStyle}"/>
                            <TextBlock Text="{Binding SummaryFeeAmount, StringFormat={}{0:N0}원}" Style="{StaticResource SummaryValueStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="거래처명"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,16,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="매입/매출"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <ComboBox Grid.Row="0" Grid.Column="3"
                              ItemsSource="{Binding ViewTargetOptions}"
                              SelectedItem="{Binding SelectedViewTarget}"
                              Margin="0,0,16,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="4"
                               Text="세부유형"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <ComboBox Grid.Row="0" Grid.Column="5"
                              ItemsSource="{Binding EntryCategoryOptions}"
                              SelectedItem="{Binding SelectedEntryCategory}"
                              Margin="0,0,16,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="6"
                               Text="수수료율"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <TextBox Grid.Row="0" Grid.Column="7"
                             HorizontalContentAlignment="Right"
                             Text="{Binding FeeRatePercentText, UpdateSourceTrigger=LostFocus}"
                             Margin="0,0,6,0"/>
                    <TextBlock Grid.Row="0" Grid.Column="8"
                               Text="%"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Button Grid.Row="0" Grid.Column="9"
                            Content="조회"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoadDeliveriesCommand}"
                            Margin="0,0,8,0"/>
                    <Button Grid.Row="0" Grid.Column="10"
                            Style="{StaticResource BaseButtonStyle}"
                            Content="초기화"
                            Command="{Binding ResetFiltersCommand}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="기간"
                               VerticalAlignment="Center"
                               Margin="0,8,12,0"/>
                    <DatePicker Grid.Row="1" Grid.Column="1"
                                SelectedDate="{Binding FromDate, Converter={StaticResource DateOnlyConverter}}"
                                SelectedDateFormat="Short"
                                Margin="0,8,16,0"
                                VerticalAlignment="Center">
                        <DatePicker.Resources>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource FilterDatePickerButtonStyle}"/>
                        </DatePicker.Resources>
                    </DatePicker>
                    <TextBlock Grid.Row="1" Grid.Column="2"
                               Text="~"
                               VerticalAlignment="Center"
                               Margin="0,8,12,0"/>
                    <DatePicker Grid.Row="1" Grid.Column="3"
                                SelectedDate="{Binding ToDate, Converter={StaticResource DateOnlyConverter}}"
                                SelectedDateFormat="Short"
                                Margin="0,8,16,0"
                                VerticalAlignment="Center">
                        <DatePicker.Resources>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource FilterDatePickerButtonStyle}"/>
                        </DatePicker.Resources>
                    </DatePicker>
                    <TextBlock Grid.Row="1" Grid.Column="4"
                               Text="창고"
                               VerticalAlignment="Center"
                               Margin="0,8,12,0"/>
                    <ComboBox Grid.Row="1" Grid.Column="5"
                              ItemsSource="{Binding WarehouseOptions}"
                              SelectedItem="{Binding SelectedWarehouseOption}"
                              Margin="0,8,16,0"
                              VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#1A2B4A"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <DataGrid x:Name="DeliveryRowsDataGrid"
                      ItemsSource="{Binding Deliveries}"
                      SelectedItem="{Binding SelectedDelivery}"
                      IsReadOnly="True"
                      BorderThickness="0"
                      MouseDoubleClick="DeliveryRowsDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="거래일" Binding="{Binding TradeDateDisplay}" Width="110"/>
                    <DataGridTextColumn Header="세부유형" Binding="{Binding EntryCategory}" Width="95"/>
                    <DataGridTextColumn Header="거래처명" Binding="{Binding CustomerName}" Width="190"/>
                    <DataGridTextColumn Header="사용모델" Binding="{Binding ModelName}" Width="190"/>
                    <DataGridTextColumn Header="거래내용" Binding="{Binding TradeDescription}" Width="280"/>
                    <DataGridTextColumn Header="매입금액" Binding="{Binding PurchaseAmount, StringFormat=N0}" Width="120" ElementStyle="{StaticResource RightAlignedCellTextStyle}"/>
                    <DataGridTextColumn Header="매출금액" Binding="{Binding SalesAmount, StringFormat=N0}" Width="120" ElementStyle="{StaticResource RightAlignedCellTextStyle}"/>
                    <DataGridTextColumn Header="수익금액" Binding="{Binding ProfitAmount, StringFormat=N0}" Width="120" ElementStyle="{StaticResource RightAlignedCellTextStyle}"/>
                    <DataGridTextColumn Header="수수료" Binding="{Binding FeeAmount, StringFormat=N0}" Width="120" ElementStyle="{StaticResource RightAlignedCellTextStyle}"/>
                    <DataGridTextColumn Header="비고" Binding="{Binding Note}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,10,0,0"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar Width="260"
                                 Height="14"
                                 IsIndeterminate="{Binding IsBusy}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               Foreground="#90CAF9"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="전표 열기"
                            Style="{StaticResource BaseButtonStyle}"
                            Width="110"
                            Margin="0,0,8,0"
                            Click="OpenInvoiceButton_Click"/>
                    <Button Content="닫기"
                            Style="{StaticResource BaseButtonStyle}"
                            Width="110"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>

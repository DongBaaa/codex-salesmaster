<Window x:Class="거래플랜.Desktop.App.Views.RentalEquipmentReplacementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="렌탈 장비 교체"
        Width="720"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#151F2E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Background" Value="#DDEBFA"/>
            <Setter Property="BorderBrush" Value="#3E5D86"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Background" Value="#DDEBFA"/>
            <Setter Property="BorderBrush" Value="#3E5D86"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Width" Value="160"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Background" Value="#DDEBFA"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="MaxWidth" Value="150"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F6FCE"/>
            <Setter Property="BorderBrush" Value="#5E93D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#20345A" BorderBrush="#33517C" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="렌탈 장비 교체" FontSize="20" FontWeight="Bold" Foreground="#66D9FF"/>
                <TextBlock Text="기존 임대 장비의 거래처·설치 위치·청구 프로필을 새 장비로 승계하고, 기존 장비는 회수 상태로 정리합니다."
                           Margin="0,6,0,0"
                           Foreground="#B8C6D8"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#1C2B43" BorderBrush="#33517C" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="기존 장비" FontWeight="Bold" Foreground="#FFCC80"/>
                <Border Grid.Row="0" Grid.Column="1" Background="#15243A" BorderBrush="#294B73" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <TextBlock x:Name="OriginalSummaryText" FontWeight="Bold"/>
                        <TextBlock x:Name="OriginalDetailText" Margin="0,5,0,0" Foreground="#B8C6D8" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="새 장비" FontWeight="Bold" Foreground="#80CBC4"/>
                <Border Grid.Row="2" Grid.Column="1" Background="#15243A" BorderBrush="#294B73" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <TextBlock x:Name="ReplacementSummaryText" FontWeight="Bold"/>
                        <TextBlock x:Name="ReplacementDetailText" Margin="0,5,0,0" Foreground="#B8C6D8" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="교체일"/>
                <DatePicker x:Name="ReplacementDatePicker" Grid.Row="4" Grid.Column="1">
                    <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                </DatePicker>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="기존 장비 상태"/>
                <ComboBox x:Name="OriginalStatusBox" Grid.Row="5" Grid.Column="1"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="사유/메모" VerticalAlignment="Top" Margin="0,8,0,0"/>
                <TextBox x:Name="ReasonBox"
                         Grid.Row="6"
                         Grid.Column="1"
                         Height="82"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="교체 실행" Click="Confirm_Click" Background="#157A2D"/>
            <Button Content="취소" Click="Cancel_Click" Background="#4E6681"/>
        </StackPanel>
    </Grid>
</Window>

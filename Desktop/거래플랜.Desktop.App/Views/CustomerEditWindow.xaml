<Window x:Class="거래플랜.Desktop.App.Views.CustomerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:거래플랜.Desktop.App.Converters"
        Title="거래처 등록/수정" Height="960" Width="860" MinHeight="860" MinWidth="820"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#1A2B4A" KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>
        <conv:NullableDateOnlyConverter x:Key="NullableDateOnlyConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="184"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="102"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#0D47A1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="거래처 등록 및 수정"
                           FontSize="14" FontWeight="Bold" Foreground="White"/>
                <Button Grid.Column="1" Content="닫기 (F12)" Background="#B71C1C"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#0D1B2A" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="기본 거래처 정보와 계약서 PDF를 함께 관리할 수 있습니다."
                           Foreground="#90CAF9" FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="연속입력 (F6)" Background="#00695C"
                        Margin="0,0,8,0" Command="{Binding SaveAndNewCommand}"/>
                <Button Grid.Column="2" Content="임대 자산 보기" Background="#6A1B9A"
                        Margin="0,0,8,0" Click="OpenRentalAssetsButton_Click"/>
                <Button Grid.Column="3" Content="저장" Background="#0D47A1" Padding="20,6"
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#1B5E20" Padding="12,4"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#A5D6A7" FontSize="11"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="12,8,12,12" Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="110" MinHeight="84"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerLabelPrimary"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerLabelSecondary"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="거래처명"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             FontWeight="Bold"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="고객분류"/>
                    <ComboBox Grid.Row="0" Grid.Column="3"
                              ItemsSource="{Binding Categories}"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding CategoryId}"
                              DisplayMemberPath="Name"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="대표전화"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="거래구분"/>
                    <ComboBox Grid.Row="1" Grid.Column="3"
                              ItemsSource="{Binding TradeTypes}"
                              SelectedItem="{Binding TradeType}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="휴대폰"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MobilePhone, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="2" Grid.Column="2" Content="담당자"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="부서"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="3" Grid.Column="2" Content="팩스번호"/>
                    <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding FaxNumber, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="담당지점"/>
                    <ComboBox Grid.Row="4" Grid.Column="1"
                              ItemsSource="{Binding OfficeCodes}"
                              SelectedItem="{Binding ResponsibleOfficeCode}"/>
                    <Label Grid.Row="4" Grid.Column="2" Content="가격등급"/>
                    <ComboBox Grid.Row="4" Grid.Column="3"
                              ItemsSource="{Binding PriceGrades}"
                              SelectedItem="{Binding PriceGrade}"/>
                </Grid>

                <Separator Grid.Row="1" Background="#2E4060"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerLabelPrimary"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerLabelSecondary"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="사업자번호"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BusinessNumber, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="대표자명"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Representative, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="대표전화"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BusinessType, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="종목"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding BusinessItem, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Separator Grid.Row="3" Background="#2E4060"/>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerLabelPrimary"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="사업자번호"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="업태"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DetailAddress, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Separator Grid.Row="5" Background="#2E4060"/>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerLabelPrimary"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Content="메모사항"
                           HorizontalContentAlignment="Left"
                           VerticalAlignment="Top"
                           Margin="0,0,0,2"/>
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             MinHeight="84"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <Separator Grid.Row="7" Background="#2E4060"/>

                <Border Grid.Row="10" Background="#132742" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="148"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="계약서 등록" FontWeight="Bold" Foreground="White" Margin="0,0,12,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ContractTypes}"
                                      SelectedItem="{Binding SelectedContractType}"/>
                            <Label Grid.Column="2" Content="체결일" Margin="10,0,0,0"/>
                            <DatePicker Grid.Column="3"
                                        SelectedDate="{Binding ContractSignedDate, Converter={StaticResource NullableDateOnlyConverter}}">
                                <DatePicker.Resources>
                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                                </DatePicker.Resources>
                            </DatePicker>
                            <Label Grid.Column="4" Content="만료일" Margin="10,0,0,0"/>
                            <DatePicker Grid.Column="5"
                                        SelectedDate="{Binding ContractExpireDate, Converter={StaticResource NullableDateOnlyConverter}}">
                                <DatePicker.Resources>
                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                                </DatePicker.Resources>
                            </DatePicker>
                            <TextBlock Grid.Column="6"
                                       Text="{Binding ContractEntryModeText}"
                                       Margin="12,0,0,0"
                                       Foreground="#90CAF9"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="메모"/>
                            <TextBox Grid.Column="1" Text="{Binding ContractDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                            <CheckBox Grid.Column="2" Content="대표 계약서" IsChecked="{Binding NewContractIsPrimary}" Margin="0,0,12,0"/>
                            <Button Grid.Column="3" Content="새 계약서" Background="#455A64" Margin="0,0,8,0"
                                    Command="{Binding BeginNewContractEntryCommand}"/>
                            <Button Grid.Column="4" Content="PDF 추가" Background="#1565C0" Margin="0,0,8,0"
                                    Command="{Binding AddContractCommand}"/>
                            <Button Grid.Column="5" Content="열기" Background="#2E7D32" Margin="0,0,8,0"
                                    Command="{Binding OpenContractCommand}"/>
                            <Button Grid.Column="6" Content="대표 지정" Background="#6A1B9A" Margin="0,0,8,0"
                                    Command="{Binding SetPrimaryContractCommand}"/>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid Grid.Row="0"
                                      ItemsSource="{Binding Contracts}"
                                      SelectedItem="{Binding SelectedContract}"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="대표" Binding="{Binding IsPrimary}" Width="60"/>
                                    <DataGridTemplateColumn Header="상태" Width="78">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding FileRegistrationStatus}"
                                                           HorizontalAlignment="Center"
                                                           FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                            <Setter Property="Foreground" Value="#FFCC80"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAttachedPdf}" Value="True">
                                                                    <Setter Property="Foreground" Value="#A5D6A7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="Black"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="구분" Binding="{Binding ContractType}" Width="110"/>
                                    <DataGridTextColumn Header="체결일" Binding="{Binding SignedDate}" Width="95"/>
                                    <DataGridTextColumn Header="만료일" Binding="{Binding ExpireDate}" Width="95"/>
                                    <DataGridTextColumn Header="파일명" Binding="{Binding FileName}" Width="190"/>
                                    <DataGridTextColumn Header="용량" Binding="{Binding FileSize, StringFormat={}{0:N0} B}" Width="100"/>
                                    <DataGridTextColumn Header="등록자" Binding="{Binding UploadedByUsername}" Width="90"/>
                                    <DataGridTextColumn Header="등록시각" Binding="{Binding UploadedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130"/>
                                    <DataGridTextColumn Header="메모" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                <TextBlock Text="스캔한 계약서는 PDF만 등록됩니다. 권장 크기: 15MB 이하" Foreground="#90CAF9" Margin="0,0,12,0"/>
                                <Button Content="삭제" Background="#B71C1C" Command="{Binding DeleteContractCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Separator Grid.Row="9" Background="#2E4060"/>

                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerLabelPrimary"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CustomerLabelSecondary"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="받는분"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Recipient, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="대표자명"/>
                    <DatePicker Grid.Row="0"
                                Grid.Column="3"
                                SelectedDate="{Binding RegisterDate, Converter={StaticResource DateOnlyConverter}}"
                                Background="#D9E6F5"
                                Foreground="Black">
                        <DatePicker.Resources>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                        </DatePicker.Resources>
                    </DatePicker>

                    <Label Grid.Row="1" Grid.Column="0" Content="E-MAIL"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <TextBlock Grid.Row="11"
                           Text="거래처를 먼저 저장한 뒤 계약서를 계속 추가할 수 있습니다."
                           Foreground="#EF9A9A"
                           FontSize="11"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>

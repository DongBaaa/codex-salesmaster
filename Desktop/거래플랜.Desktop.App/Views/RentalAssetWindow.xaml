<Window x:Class="거래플랜.Desktop.App.Views.RentalAssetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="렌탈 자산/설치현황"
        Height="940"
        Width="1640"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Height" Value="28"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="SelectedDateFormat" Value="Short"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0,10,0"/>
        </Style>
        <Style x:Key="RentalDatePickerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="렌탈 자산 / 설치현황" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7"/>
                    <TextBlock Text="장비 상태와 청구 연결 상태를 함께 관리해 청구 누락과 소속 오류를 줄입니다." Foreground="#9FB3C8" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="새로고침" Margin="0,0,6,0" Command="{Binding ReloadCommand}"/>
                    <Button Content="신규" Background="#1565C0" BorderBrush="#1565C0" Margin="0,0,6,0" Command="{Binding NewAssetCommand}"/>
                    <Button Content="저장" Background="#1B5E20" BorderBrush="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}"/>
                    <Button Content="삭제" Background="#C62828" BorderBrush="#C62828" Margin="0,0,6,0" Command="{Binding DeleteCommand}" IsEnabled="{Binding CanDeleteSelected}"/>
                    <Button Content="선택삭제" Background="#8E24AA" BorderBrush="#8E24AA" Margin="0,0,6,0" Command="{Binding DeleteCheckedCommand}"/>
                    <Button Content="회수장비내역서" Background="#5D4037" BorderBrush="#5D4037" Margin="0,0,6,0" Command="{Binding OpenReturnReportCommand}"/>
                    <Button Content="렌탈장비내역서" Background="#00897B" BorderBrush="#00897B" Margin="0,0,6,0" Command="{Binding OpenEquipmentDetailCommand}"/>
                    <Button Content="계약서 작성" Background="#6A1B9A" BorderBrush="#6A1B9A" Margin="0,0,6,0" Command="{Binding OpenContractWriterCommand}"/>
                    <Button Content="닫기 (F12)" Click="CloseButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="검색" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Width="240" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                <TextBlock Text="품목분류" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="150" ItemsSource="{Binding ItemCategoryFilterOptions}" SelectedItem="{Binding SelectedItemCategoryFilter}" Margin="0,0,12,0"/>
                <TextBlock Text="담당지점" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="150" ItemsSource="{Binding FilterOfficeOptions}" DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedOfficeFilter}" Margin="0,0,12,0"/>
                <TextBlock Text="상태" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Width="130" ItemsSource="{Binding AssetStatusOptions}" SelectedItem="{Binding SelectedStatusFilter}" Margin="0,0,12,0"/>
                <TextBlock Text="기준일" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Width="170" SelectedDate="{Binding ReferenceDate, Converter={StaticResource DateOnlyConverter}}" SelectedDateFormat="Short">
                    <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                </DatePicker>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.35*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}" BorderThickness="0" IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="46">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate><TextBlock Text="선택" HorizontalAlignment="Center"/></DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="관리번호" Binding="{Binding Source.ManagementNumber}" Width="110"/>
                        <DataGridTextColumn Header="담당지점" Binding="{Binding ResponsibleOfficeName}" Width="110"/>
                        <DataGridTextColumn Header="청구 거래처" Binding="{Binding BillToCustomerName}" Width="150"/>
                        <DataGridTextColumn Header="설치위치" Binding="{Binding InstallLocationDisplay}" Width="170"/>
                        <DataGridTextColumn Header="품목분류" Binding="{Binding Source.ItemCategoryName}" Width="120"/>
                        <DataGridTextColumn Header="품명" Binding="{Binding Source.ItemName}" Width="150"/>
                        <DataGridTextColumn Header="기계번호" Binding="{Binding Source.MachineNumber}" Width="140"/>
                        <DataGridTextColumn Header="상태" Binding="{Binding Source.AssetStatus}" Width="90"/>
                        <DataGridTextColumn Header="청구상태" Binding="{Binding BillingEligibilityStatus}" Width="100"/>
                        <DataGridTextColumn Header="월요금" Binding="{Binding Source.MonthlyFee, StringFormat=N0}" Width="100"/>
                        <DataGridTextColumn Header="만료일" Binding="{Binding Source.RentalEndDate}" Width="100"/>
                        <DataGridTextColumn Header="남은일수" Binding="{Binding DaysRemaining}" Width="76"/>
                        <DataGridCheckBoxColumn Header="이상" Binding="{Binding HasDataIssue}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="5" Text="렌탈 자산 상세" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="관리ID" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditManagementId}" IsReadOnly="True" Background="#24364F" BorderBrush="#324A69" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="관리번호" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding EditManagementNumber}" IsReadOnly="True" Background="#24364F" BorderBrush="#324A69" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="담당지점" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding EditOfficeOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding EditOfficeCode}" IsEnabled="{Binding CanEditOfficeSelection}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="3" Text="상태" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <ComboBox Grid.Row="2" Grid.Column="4" ItemsSource="{Binding EditableAssetStatusOptions}" SelectedItem="{Binding EditAssetStatus}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="거래처" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding EditCustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="조회" MinWidth="72" Padding="10,0" Click="CustomerLookupButton_Click"/>
                        </Grid>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="청구 거래처" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditBillToCustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="설치위치" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditInstallLocation, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="청구상태" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding BillingEligibilityStatusOptions}" SelectedItem="{Binding EditBillingEligibilityStatus}" IsEditable="True" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="6" Grid.Column="3" Text="제외사유" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="6" Grid.Column="4" Text="{Binding EditBillingExclusionReason, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="품목분류" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <ComboBox Grid.Row="7" Grid.Column="1" ItemsSource="{Binding ItemCategoryOptions}" DisplayMemberPath="Name" SelectedValuePath="Name" SelectedValue="{Binding EditItemCategoryName, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="7" Grid.Column="3" Text="제조사" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="7" Grid.Column="4" Text="{Binding EditManufacturer, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="품명" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <Grid Grid.Row="8" Grid.Column="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding EditItemName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="조회" MinWidth="72" Padding="10,0" Click="ItemLookupButton_Click"/>
                        </Grid>
                        <TextBlock Grid.Row="8" Grid.Column="3" Text="기계번호" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="8" Grid.Column="4" Text="{Binding EditMachineNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="매입처" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <Grid Grid.Row="9" Grid.Column="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding EditPurchaseVendor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="조회" MinWidth="72" Padding="10,0" Click="PurchaseVendorLookupButton_Click"/>
                        </Grid>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="월요금" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding EditMonthlyFee, Converter={StaticResource DecimalToString}, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="10" Grid.Column="3" Text="보증금" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="10" Grid.Column="4" Text="{Binding EditDepositText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="11" Grid.Column="0" Text="계약개월" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding EditContractMonths, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="11" Grid.Column="3" Text="매입일" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <DatePicker Grid.Row="11" Grid.Column="4" SelectedDate="{Binding EditPurchaseDate}" SelectedDateFormat="Short" Margin="0,0,0,8">
                            <DatePicker.Resources>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/>
                            </DatePicker.Resources>
                        </DatePicker>

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="계약일" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <DatePicker Grid.Row="12" Grid.Column="1" SelectedDate="{Binding EditContractDate}" SelectedDateFormat="Short" Margin="0,0,0,8">
                            <DatePicker.Resources><Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/></DatePicker.Resources>
                        </DatePicker>
                        <TextBlock Grid.Row="12" Grid.Column="3" Text="설치일" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <DatePicker Grid.Row="12" Grid.Column="4" SelectedDate="{Binding EditInstallDate}" SelectedDateFormat="Short" Margin="0,0,0,8">
                            <DatePicker.Resources><Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/></DatePicker.Resources>
                        </DatePicker>

                        <TextBlock Grid.Row="13" Grid.Column="0" Text="계약시작" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <DatePicker Grid.Row="13" Grid.Column="1" SelectedDate="{Binding EditContractStartDate}" SelectedDateFormat="Short" Margin="0,0,0,8">
                            <DatePicker.Resources><Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/></DatePicker.Resources>
                        </DatePicker>
                        <TextBlock Grid.Row="13" Grid.Column="3" Text="렌탈만료" VerticalAlignment="Center" Margin="0,0,10,8"/>
                        <DatePicker Grid.Row="13" Grid.Column="4" SelectedDate="{Binding EditRentalEndDate}" SelectedDateFormat="Short" Margin="0,0,0,8">
                            <DatePicker.Resources><Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/></DatePicker.Resources>
                        </DatePicker>

                        <TextBlock Grid.Row="14" Grid.Column="0" Text="관리메모" VerticalAlignment="Top" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}" Height="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,10,0,0" Background="#122038" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10">
            <DockPanel LastChildFill="False">
                <ProgressBar Width="220" Height="12" IsIndeterminate="{Binding IsBusy}" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#90CAF9" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>

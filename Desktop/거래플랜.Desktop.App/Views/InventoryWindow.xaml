<Window x:Class="거래플랜.Desktop.App.Views.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:거래플랜.Desktop.App.Converters"
        Title="품목/재고 관리"
        Height="900"
        Width="1220"
        MinHeight="860"
        MinWidth="1120"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:DecimalToStringConverter x:Key="DecimalToString"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="OfficeTabButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="110"/>
        </Style>
        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#9FB3C8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="MetricCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#10233A"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="MetricCaptionStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#9FB3C8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="MetricValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <Style x:Key="ValueDisplayBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F2034"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="AlternatingRowBackground" Value="#243B55"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A2B4A" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="품목/재고 관리"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#4FC3F7"/>
                    <TextBlock Text="{Binding TotalCount, StringFormat=' (전체 {0}건)'}"
                               Foreground="#90CAF9"
                               Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="신규 품목"
                            Background="#1B5E20"
                            Command="{Binding NewItemCommand}"/>
                    <Border Background="#0F2034"
                            BorderBrush="#4FC3F7"
                            BorderThickness="1"
                            CornerRadius="4"
                            Height="36"
                            Padding="10,0"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ToolTip="체크하면 저장 후 현재 입력값을 유지한 채 다음 신규 품목 등록을 바로 이어갑니다. 재고 수량은 새 품목으로 복사하지 않습니다.">
                        <CheckBox Content="저장 후 계속 입력"
                                  IsChecked="{Binding KeepEnteredValuesForNextNewItem, UpdateSourceTrigger=PropertyChanged}"
                                  Foreground="#E6EE9C"
                                  FontWeight="Bold"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="품목 저장"
                            Background="#0D47A1"
                            Command="{Binding SaveItemCommand}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="선택 품목 삭제"
                            Background="#B71C1C"
                            Command="{Binding DeleteItemCommand}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="재고 초기화"
                            Background="#E65100"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="선택한 품목의 재고를 0으로 초기화합니다. 기존 전표/재고이동 이력은 유지됩니다."
                            Click="ResetInventoryButton_Click"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="재고이동"
                            Background="#6A1B9A"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                            Click="InventoryTransferButton_Click"/>
                    <Rectangle Width="1" Height="20" Fill="#3E5875" Margin="4,0,10,0" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="닫기 (F12)"
                            Background="#37474F"
                            Margin="0"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="#1A2B4A"
                Padding="10,6"
                BorderBrush="#2E4060"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="검색:" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1"
                             Width="120"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="3" Text="재고방식:" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="4"
                              Width="140"
                              ItemsSource="{Binding TrackingTypeFilterOptions}"
                              SelectedItem="{Binding SelectedTrackingTypeFilter}"/>
                    <StackPanel Grid.Column="6" Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="{Binding InventoryScopeMessage}"
                                   Foreground="#90CAF9"/>
                        <TextBlock Text="{Binding TransferGuideMessage}"
                                   Foreground="#9FB3C8"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding CanSwitchOfficeTabs, Converter={StaticResource BoolToVisibility}}">
                    <Button Style="{StaticResource OfficeTabButtonStyle}"
                            Content="{Binding UsenetTabText}"
                            Background="#1565C0"
                            BorderBrush="#1565C0"
                            Command="{Binding ShowUsenetOfficeCommand}"/>
                    <Button Style="{StaticResource OfficeTabButtonStyle}"
                            Content="{Binding ItworldTabText}"
                            Background="#5D6B75"
                            BorderBrush="#5D6B75"
                            Command="{Binding ShowItworldOfficeCommand}"/>
                    <Button Style="{StaticResource OfficeTabButtonStyle}"
                            Content="{Binding YeonsuTabText}"
                            Background="#00897B"
                            BorderBrush="#00897B"
                            Margin="0"
                            Command="{Binding ShowYeonsuOfficeCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#0D1B2A" Padding="12,4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#90CAF9"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450" MinWidth="380"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding FilteredItems}"
                      SelectedItem="{Binding SelectedItem}"
                      IsReadOnly="True"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="품목명" Binding="{Binding NameOriginal}" Width="2.25*" MinWidth="210"/>
                    <DataGridTextColumn Header="규격" Binding="{Binding SpecificationOriginal}" Width="1.2*" MinWidth="116"/>
                    <DataGridTextColumn Header="운영유형" Binding="{Binding ItemKind}" Width="78"/>
                    <DataGridTextColumn Header="재고방식" Binding="{Binding TrackingType}" Width="68"/>
                    <DataGridTextColumn Header="선택 재고" Binding="{Binding DisplayedQuantity, StringFormat=N0}" Width="64"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#0D1B2A"
                          Cursor="SizeWE"/>

            <Grid Grid.Column="2" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="156"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="8,8,8,0"
                        Background="#1A2B4A"
                        Padding="10"
                        CornerRadius="6"
                        BorderBrush="#2E4060"
                        BorderThickness="1">
                    <DockPanel>
                        <TextBlock Text="{Binding SelectedOfficeStockLabel}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#4FC3F7"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock Text="{Binding UsenetTotalQuantity, StringFormat='USENET 합계 {0:N0}'}"
                                       Foreground="#90CAF9"
                                       Margin="0,0,12,0"
                                       Visibility="{Binding CanSwitchOfficeTabs, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding ItworldTotalQuantity, StringFormat='ITWORLD 합계 {0:N0}'}"
                                       Foreground="#CFD8DC"
                                       Margin="0,0,12,0"
                                       Visibility="{Binding CanSwitchOfficeTabs, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding YeonsuTotalQuantity, StringFormat='YEONSU 합계 {0:N0}'}"
                                       Foreground="#A5D6A7"
                                       Visibility="{Binding CanSwitchOfficeTabs, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="8,8,8,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Grid.IsSharedSizeScope="True">
                        <Border Background="#16263D"
                                Padding="12"
                                CornerRadius="6"
                                BorderBrush="#2E4060"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="품목 기본 정보"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#4FC3F7"/>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="InventoryLabelPrimary"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="InventoryLabelSecondary"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="32"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="품명"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold"/>
                                    <Label Grid.Row="0" Grid.Column="2" Content="품목분류"/>
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="3"
                                              ItemsSource="{Binding ItemCategoryOptions}"
                                               DisplayMemberPath="Name"
                                               SelectedValuePath="Name"
                                               SelectedValue="{Binding EditCategoryName, UpdateSourceTrigger=PropertyChanged}"/>

                                    <Label Grid.Row="1" Grid.Column="0" Content="운영유형"/>
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              ItemsSource="{Binding ItemKindOptions}"
                                              SelectedItem="{Binding EditItemKind, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Label Grid.Row="1" Grid.Column="2" Content="재고방식"/>
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="3"
                                              ItemsSource="{Binding TrackingTypeOptions}"
                                              SelectedItem="{Binding EditTrackingType, UpdateSourceTrigger=PropertyChanged}"/>

                                    <Label Grid.Row="2" Grid.Column="0" Content="규격"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditSpec, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Label Grid.Row="2" Grid.Column="2" Content="단위"/>
                                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding EditUnit, UpdateSourceTrigger=PropertyChanged}"/>

                                    <Label Grid.Row="3" Grid.Column="0"
                                           Content="기본 개수"
                                           ToolTip="박스 단위가 아닌 일반 수량 기준의 참고값입니다."/>
                                    <TextBox Grid.Row="3" Grid.Column="1"
                                             Text="{Binding EditBoxQty, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="일반 수량 기준으로 입력하세요. 현재고 표시는 선택 지점의 실제 재고 수량을 기준으로 합니다."/>
                                    <Label Grid.Row="3" Grid.Column="2" Content="보관위치"/>
                                    <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding EditStorageLocation, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Separator Background="#2E4060" Margin="0,8,0,8"/>

                                <TextBlock Text="재고 수량 현황"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#4FC3F7"/>
                                <TextBlock Text="{Binding TrackingTypeGuideText}"
                                           Foreground="#90CAF9"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>

                                <StackPanel Margin="0,8,0,0">
                                    <WrapPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,18,8"
                                                    Visibility="{Binding CanSwitchOfficeTabs, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="USENET 재고"/>
                                            <TextBlock Text="{Binding EditUsenetStock, StringFormat=N0}"
                                                       Margin="6,0,0,0"
                                                       Foreground="#90CAF9"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,18,8"
                                                    Visibility="{Binding CanSwitchOfficeTabs, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="ITWORLD 재고"/>
                                            <TextBlock Text="{Binding EditItworldStock, StringFormat=N0}"
                                                       Margin="6,0,0,0"
                                                       Foreground="#CFD8DC"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,18,8"
                                                    Visibility="{Binding CanSwitchOfficeTabs, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="YEONSU 재고"/>
                                            <TextBlock Text="{Binding EditYeonsuStock, StringFormat=N0}"
                                                       Margin="6,0,0,0"
                                                       Foreground="#A5D6A7"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,18,8">
                                            <TextBlock Text="{Binding SelectedOfficeStockLabel}"/>
                                            <TextBlock Text="{Binding EditSelectedOfficeStock, StringFormat=N0}"
                                                       Margin="6,0,0,0"
                                                       Foreground="#4FC3F7"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,18,8"
                                                    Visibility="{Binding CanSwitchOfficeTabs, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="전체 재고"/>
                                            <TextBlock Text="{Binding EditTotalStock, StringFormat=N0}"
                                                       Margin="6,0,0,0"
                                                       Foreground="#E6EE9C"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                    </WrapPanel>

                                    <WrapPanel Margin="0,2,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,18,8">
                                            <TextBlock Text="선택 재고 개수"/>
                                            <TextBlock Text="{Binding EditSelectedOfficeStock, StringFormat=N0}"
                                                       Margin="6,0,0,0"
                                                       Foreground="#90CAF9"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,18,8">
                                            <TextBlock Text="재고자산 금액"/>
                                            <TextBlock Text="{Binding AssetValue, StringFormat=N0}"
                                                       Margin="6,0,0,0"
                                                       Foreground="#A5D6A7"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,18,8">
                                            <TextBlock Text="부족재고 수량"/>
                                            <TextBlock Text="{Binding ShortageStock, StringFormat=N0}"
                                                       Margin="6,0,0,0"
                                                       Foreground="#EF9A9A"
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,18,8">
                                            <TextBlock Text="최소 보유 수량"/>
                                            <TextBox MinWidth="110"
                                                      Height="30"
                                                      Margin="8,0,10,0"
                                                      IsEnabled="{Binding IsInventoryTrackedItem}"
                                                      Text="{Binding EditSafetyStock, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Text="부족 판단 기준"
                                                       Style="{StaticResource SectionDescriptionStyle}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>

                                <Separator Background="#2E4060" Margin="0,8,0,8"/>

                                            <TextBlock Text="기준 단가"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#4FC3F7"/>

                                                                 <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource MetricCardBorderStyle}"
                                            Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="운영 기준"
                                                       Style="{StaticResource MetricCaptionStyle}"/>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="InventoryPriceLabel"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="36"/>
                                                    <RowDefinition Height="36"/>
                                                    <RowDefinition Height="36"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0" Grid.Column="0" Content="매입단가"/>
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding EditPurchasePrice, Converter={StaticResource DecimalToString}, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Label Grid.Row="1" Grid.Column="0" Content="매출단가"/>
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding EditSalePrice, Converter={StaticResource DecimalToString}, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Label Grid.Row="2" Grid.Column="0" Content="소매단가"/>
                                                <TextBox Grid.Row="2" Grid.Column="1"
                                                         Text="{Binding EditRetailPrice, Converter={StaticResource DecimalToString}, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Style="{StaticResource MetricCardBorderStyle}"
                                            Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="최근 이력 / 등급 단가"
                                                       Style="{StaticResource MetricCaptionStyle}"/>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="InventoryPriceLabel"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="36"/>
                                                    <RowDefinition Height="36"/>
                                                    <RowDefinition Height="36"/>
                                                    <RowDefinition Height="36"/>
                                                    <RowDefinition Height="36"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0" Grid.Column="0" Content="마지막구매"/>
                                                <Border Grid.Row="0" Grid.Column="1"
                                                        Style="{StaticResource ValueDisplayBorderStyle}">
                                                    <TextBlock Text="{Binding EditLastPurchaseDate}"
                                                               Foreground="#90CAF9"/>
                                                </Border>
                                                <Label Grid.Row="1" Grid.Column="0" Content="마지막판매"/>
                                                <Border Grid.Row="1" Grid.Column="1"
                                                        Style="{StaticResource ValueDisplayBorderStyle}">
                                                    <TextBlock Text="{Binding EditLastSaleDate}"
                                                               Foreground="#90CAF9"/>
                                                </Border>
                                                <Label Grid.Row="2" Grid.Column="0" Content="A단가"/>
                                                <TextBox Grid.Row="2" Grid.Column="1"
                                                         Text="{Binding EditPriceA, Converter={StaticResource DecimalToString}, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Label Grid.Row="3" Grid.Column="0" Content="B단가"/>
                                                <TextBox Grid.Row="3" Grid.Column="1"
                                                         Text="{Binding EditPriceB, Converter={StaticResource DecimalToString}, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Label Grid.Row="4" Grid.Column="0" Content="C단가"/>
                                                <TextBox Grid.Row="4" Grid.Column="1"
                                                         Text="{Binding EditPriceC, Converter={StaticResource DecimalToString}, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                 </Grid>

                                <Border Margin="0,12,0,0"
                                        Style="{StaticResource MetricCardBorderStyle}"
                                        Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="150"/>
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0">
                                            <TextBlock Text="매입처별 최근 구매단가"
                                                       Style="{StaticResource MetricCaptionStyle}"/>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="구매 전표에서 같은 매입처+품목을 다시 선택하면 최근 구매단가가 우선 적용됩니다."
                                                       Foreground="#9FB3C8"
                                                       TextWrapping="Wrap"/>
                                        </DockPanel>
                                        <TextBlock Grid.Row="1"
                                                   Text="품목마다 구매 업체별 실제 매입 조건을 확인하는 영역입니다. 신규 매입처 가격은 구매전표에서 단가를 입력해 저장하면 다음 구매 시 자동 후보가 됩니다."
                                                   Foreground="#9FB3C8"
                                                   Margin="0,6,0,8"
                                                   TextWrapping="Wrap"/>
                                        <DataGrid Grid.Row="2"
                                                  ItemsSource="{Binding SelectedItemVendorPurchasePrices}"
                                                  IsReadOnly="True"
                                                  BorderThickness="0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="매입처" Binding="{Binding VendorName}" Width="2*"/>
                                                <DataGridTextColumn Header="거래구분" Binding="{Binding VendorTradeType}" Width="90"/>
                                                <DataGridTextColumn Header="최근단가" Binding="{Binding UnitPrice, StringFormat=N0}" Width="100"/>
                                                <DataGridTextColumn Header="일자" Binding="{Binding LastPurchaseDate}" Width="100"/>
                                                <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="70"/>
                                                <DataGridTextColumn Header="전표번호" Binding="{Binding InvoiceNumber}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="InventoryMemoLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0"
                                           Content="품목 메모"
                                           VerticalAlignment="Top"
                                           Padding="0,8,8,0"
                                           ToolTip="선택한 품목에 대한 내부 메모입니다. 재고 초기화 기능과는 별도이며 저장 시 품목 메모로 보관됩니다."/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding EditSimpleMemo, UpdateSourceTrigger=PropertyChanged}"
                                             Height="148"
                                             MinHeight="148"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"
                                             VerticalScrollBarVisibility="Auto"
                                             ToolTip="선택한 품목의 내부 메모를 입력합니다. 이 내용은 전표 계산이나 재고 수량에는 영향을 주지 않습니다."/>
                                    <Border Grid.Column="2"
                                            Margin="16,0,0,0"
                                            Style="{StaticResource MetricCardBorderStyle}"
                                            Padding="14,12"
                                            VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="{Binding EditTrackingType, StringFormat='재고방식: {0}'}"
                                                       Style="{StaticResource MetricCaptionStyle}"/>
                                            <TextBlock Text="{Binding EditItemKind}"
                                                       Style="{StaticResource MetricValueTextStyle}"
                                                       Margin="0,8,0,0"/>
                                            <TextBlock Text="재고 = 입출고/재고이동 대상"
                                                       Foreground="#9FB3C8"
                                                       Margin="0,10,0,0"/>
                                            <TextBlock Text="자산 = 렌탈 자산/설치현황용"
                                                       Foreground="#9FB3C8"
                                                       Margin="0,6,0,0"/>
                                            <TextBlock Text="비재고 = 렌탈료/설치비 청구용"
                                                       Foreground="#9FB3C8"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Margin="10,10,10,10"
                        Background="#16263D"
                        Padding="12"
                        CornerRadius="6"
                        BorderBrush="#2E4060"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="재고 이동 / 입출고 내역 (재고 품목만)"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#4FC3F7"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="선택한 품목의 지점 이동 내역을 확인합니다."
                                       Foreground="#9FB3C8"/>
                        </DockPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding SelectedItemMovements}"
                                  IsReadOnly="True"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="일자" Binding="{Binding OccurredDate}" Width="95"/>
                                <DataGridTextColumn Header="사무실" Binding="{Binding OfficeDisplay}" Width="110"/>
                                <DataGridTextColumn Header="창고" Binding="{Binding WarehouseDisplay}" Width="120"/>
                                <DataGridTextColumn Header="구분" Binding="{Binding MovementTypeDisplay}" Width="120"/>
                                <DataGridTextColumn Header="수량" Binding="{Binding QuantityDelta, StringFormat={}{0:+#,0;-#,0;0}}" Width="80"/>
                                <DataGridTextColumn Header="메모" Binding="{Binding Note}" Width="*"/>
                                <DataGridTextColumn Header="저장자" Binding="{Binding CreatedByUsername}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>

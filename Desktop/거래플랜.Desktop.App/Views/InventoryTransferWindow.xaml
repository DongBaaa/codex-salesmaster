<Window x:Class="거래플랜.Desktop.App.Views.InventoryTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:거래플랜.Desktop.App.Converters"
        Title="내부 재고이동"
        Height="860"
        Width="1480"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>
        <conv:WarehouseCodeDisplayConverter x:Key="WarehouseCodeDisplay"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="MaxWidth" Value="150"/>
            <Setter Property="CalendarStyle" Value="{StaticResource GeoraePlanDatePickerCalendarStyle}"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,0,4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="AlternatingRowBackground" Value="#243B55"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A2B4A" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="내부 재고이동 - 저장 시 출발창고 재고가 차감되고, 도착창고 재고는 수령확정 후 반영됩니다."
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#4FC3F7"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="신규 (F6)"
                            Background="#1B5E20"
                            Margin="0,0,6,0"
                            Command="{Binding NewTransferCommand}"/>
                    <Button Content="저장 (F8)"
                            Background="#0D47A1"
                            Margin="0,0,6,0"
                            Command="{Binding SaveTransferCommand}"/>
                    <Button Content="문서 삭제"
                            Background="#B71C1C"
                            Margin="0,0,6,0"
                            IsEnabled="{Binding CanDeleteTransfer}"
                            Click="DeleteTransferButton_Click"/>
                    <Rectangle Width="1" Height="20" Fill="#3E5875" Margin="4,0,10,0" VerticalAlignment="Center"/>
                    <Button Content="닫기 (F12)"
                            Background="#37474F"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="#0D1B2A"
                Padding="12,4">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#90CAF9"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="수령대기 상태에서는 출고만 반영되고, 수령확정 시 도착 재고와 입고내역이 확정됩니다."
                           FontSize="11"
                           Foreground="#9FB3C8"/>
            </DockPanel>
        </Border>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450" MinWidth="360"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#16263D"
                    Padding="12"
                    CornerRadius="6"
                    BorderBrush="#2E4060"
                    BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="최근 재고이동 문서"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#4FC3F7"/>
                        <TextBlock Text="목록에서 선택하면 해당 재고이동 문서를 다시 불러옵니다."
                                   Foreground="#9FB3C8"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                        <DataGrid ItemsSource="{Binding Transfers}"
                                  SelectedItem="{Binding SelectedTransfer}"
                                  IsReadOnly="True"
                                  BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="이동일" Binding="{Binding TransferDate}" Width="82"/>
                            <DataGridTextColumn Header="이동번호" Binding="{Binding TransferNumber}" Width="66"/>
                            <DataGridTextColumn Header="출발" Binding="{Binding FromWarehouseCode, Converter={StaticResource WarehouseCodeDisplay}}" Width="84"/>
                            <DataGridTextColumn Header="도착" Binding="{Binding ToWarehouseCode, Converter={StaticResource WarehouseCodeDisplay}}" Width="84"/>
                            <DataGridTextColumn Header="상태" Binding="{Binding TransferStatus}" Width="80"/>
                            <DataGridTextColumn Header="품목수" Binding="{Binding Lines.Count}" Width="54"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#0D1B2A"
                          Cursor="SizeWE"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#16263D"
                        Padding="12"
                        CornerRadius="6"
                        BorderBrush="#2E4060"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="재고이동 기본 정보"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#4FC3F7"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="44"/>
                                </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="이동번호"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     IsReadOnly="True"
                                     Text="{Binding TransferNumberDisplay, Mode=OneWay}"
                                     Background="#C4D7EA"/>
                            <Label Grid.Row="0" Grid.Column="2" Content="이동일자"/>
                            <DatePicker Grid.Row="0" Grid.Column="3"
                                        SelectedDate="{Binding TransferDate, Converter={StaticResource DateOnlyConverter}}">
                                <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                            </DatePicker>

                            <Label Grid.Row="1" Grid.Column="0" Content="출발창고"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      ItemsSource="{Binding Warehouses}"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding FromWarehouseCode}"
                                      DisplayMemberPath="Name"/>
                            <Label Grid.Row="1" Grid.Column="2" Content="도착창고"/>
                            <ComboBox Grid.Row="1" Grid.Column="3"
                                      ItemsSource="{Binding Warehouses}"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding ToWarehouseCode}"
                                      DisplayMemberPath="Name"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="상태"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                       Text="{Binding TransferStatus}"
                                       Foreground="#FFD180"
                                       FontWeight="Bold"
                                       Margin="6,0"/>

                            <Label Grid.Row="3" Grid.Column="0" Content="이동경로"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                                       Text="{Binding TransferRouteText}"
                                       Foreground="#A5D6A7"
                                       FontWeight="Bold"
                                       Margin="6,0"/>

                            <Label Grid.Row="4" Grid.Column="0" Content="메모"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                                     Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"
                                     Padding="8,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        Background="#16263D"
                        Padding="12"
                        CornerRadius="6"
                        BorderBrush="#2E4060"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="410"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="이동 품목 입력"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#4FC3F7"/>
                            <TextBlock Text="검색영역 → 상세입력영역 → 하단 버튼 순서로 정리해 입력합니다."
                                       Foreground="#9FB3C8"
                                       Margin="0,4,0,0"/>

                            <Grid Margin="0,8,0,0"
                                  Grid.IsSharedSizeScope="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="TransferFormLabel"/>
                                        <ColumnDefinition Width="360" SharedSizeGroup="TransferWideInput"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0" Content="품목검색"/>
                                    <TextBox Grid.Column="1"
                                             x:Name="InputItemNameTextBox"
                                             Height="34"
                                             Text="{Binding InputItemName, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="InputItemNameTextBox_KeyDown"/>
                                    <Button Grid.Column="3"
                                            Content="찾기"
                                            Background="#1565C0"
                                            MinWidth="92"
                                            Width="92"
                                            Height="34"
                                            Padding="0"
                                            Click="ItemLookupButton_Click"/>
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding AvailableStockText}"
                                               Foreground="#90CAF9"
                                               Margin="0,0,0,0"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="TransferFormLabel"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="TransferFormLabel"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0" Content="규격"/>
                                    <TextBox Grid.Column="1"
                                             Height="34"
                                             Text="{Binding InputSpec, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Label Grid.Column="3" Content="전달비고"/>
                                    <TextBox Grid.Column="5"
                                             Height="34"
                                             Text="{Binding InputRemark, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="TransferFormLabel"/>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="TransferFormLabel"/>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="TransferFormLabel"/>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0" Content="단위"/>
                                    <TextBox Grid.Column="1"
                                             Height="34"
                                             Text="{Binding InputUnit, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Label Grid.Column="3" Content="요청수량"/>
                                    <TextBox Grid.Column="4"
                                             Height="34"
                                             Text="{Binding InputQty, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Label Grid.Column="6" Content="수령수량"/>
                                    <TextBox Grid.Column="7"
                                             Height="34"
                                             Text="{Binding InputReceivedQty, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="TransferFormLabel"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0" Content="품목 수령메모"/>
                                    <TextBox Grid.Column="1"
                                             Height="34"
                                             Text="{Binding InputReceiptRemark, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Grid.Row="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Margin="0,0,8,0"
                                               Text="수령수량/수령메모는 품목별 실제 입고 확인값입니다."
                                               Foreground="#9FB3C8"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    <Button Grid.Column="1"
                                            Content="행 추가"
                                            Background="#1B5E20"
                                            Margin="0,0,6,0"
                                            IsEnabled="{Binding CanAddLine}"
                                            Command="{Binding AddLineCommand}"/>
                                    <Button Grid.Column="2"
                                            Content="행 수정"
                                            Background="#0D47A1"
                                            Margin="0,0,6,0"
                                            IsEnabled="{Binding CanUpdateLine}"
                                            Command="{Binding UpdateLineCommand}"/>
                                    <Button Grid.Column="3"
                                            Content="행 삭제"
                                            Background="#B71C1C"
                                            IsEnabled="{Binding CanDeleteLine}"
                                            Command="{Binding DeleteLineCommand}"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#132236"
                                Padding="10"
                                CornerRadius="4"
                                BorderBrush="#2E4060"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="수령확정 / 반려"
                                           FontWeight="Bold"
                                           Foreground="#90CAF9"/>
                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="82"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="36"/>
                                    </Grid.RowDefinitions>
                                    <Label Grid.Row="0" Grid.Column="0" Content="수령메모"/>
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Height="34"
                                             Text="{Binding ReceiveMemo, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="반려사유"/>
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Margin="0,4,0,0"
                                             Height="34"
                                             Text="{Binding RejectReason, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <StackPanel Grid.Row="2" Margin="0,6,0,0">
                                    <TextBlock Text="도착지 담당자 또는 관리자만 처리할 수 있습니다."
                                               Foreground="#9FB3C8"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="도착지 담당자 또는 관리자만 처리할 수 있습니다."
                                               Foreground="#9FB3C8"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Bottom">
                                    <Button Content="수령확정"
                                            Background="#1565C0"
                                            Margin="0,0,6,0"
                                            IsEnabled="{Binding CanConfirmReceipt}"
                                            Command="{Binding ConfirmReceiptCommand}"/>
                                    <Button Content="반려"
                                            Background="#8E2430"
                                            IsEnabled="{Binding CanRejectTransfer}"
                                            Command="{Binding RejectTransferCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,8,0,0"
                        Background="#16263D"
                        Padding="12"
                        CornerRadius="6"
                        BorderBrush="#2E4060"
                        BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="이동 품목 목록"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#4FC3F7"
                                   Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding Lines}"
                                  SelectedItem="{Binding SelectedLine}"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="품목명" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="규격" Binding="{Binding Specification}" Width="128"/>
                                <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="56"/>
                                <DataGridTextColumn Header="요청수량" Binding="{Binding Quantity, StringFormat=N0}" Width="72"/>
                                <DataGridTextColumn Header="수령수량" Binding="{Binding ReceivedQuantity, StringFormat=N0}" Width="72"/>
                                <DataGridTextColumn Header="차이" Binding="{Binding QuantityDifference, StringFormat=N0}" Width="62"/>
                                <DataGridTextColumn Header="비고" Binding="{Binding Remark}" Width="138"/>
                                <DataGridTextColumn Header="수령메모" Binding="{Binding ReceiptRemark}" Width="138"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>

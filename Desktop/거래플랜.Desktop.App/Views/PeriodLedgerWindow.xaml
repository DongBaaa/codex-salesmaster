<Window x:Class="거래플랜.Desktop.App.Views.PeriodLedgerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="기간별 집계"
        Width="1100"
        Height="840"
        MinWidth="1000"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="MaxWidth" Value="150"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#546D88"/>
                    <Setter Property="BorderBrush" Value="#7F9ABB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#364A5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#6A86A8"/>
            <Setter Property="Foreground" Value="#D9E8FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#273C5B"/>
                    <Setter Property="BorderBrush" Value="#8FB4DD"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F324E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#2D8DE0"/>
            <Setter Property="BorderBrush" Value="#2D8DE0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="MinWidth" Value="126"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#47A1F1"/>
                    <Setter Property="BorderBrush" Value="#47A1F1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E79CC"/>
                    <Setter Property="BorderBrush" Value="#1E79CC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="LedgerDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#DCE8F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#B5C7DB"/>
            <Setter Property="VerticalGridLinesBrush" Value="#B5C7DB"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="ColumnHeaderHeight" Value="30"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style x:Key="LedgerGridTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="LedgerGridCenterTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource LedgerGridTextStyle}">
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LedgerGridRightTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource LedgerGridTextStyle}">
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        <Style x:Key="LedgerGridNoteTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource LedgerGridTextStyle}">
            <Setter Property="ToolTip" Value="{Binding Note}"/>
        </Style>
        <Style x:Key="LedgerGridItemNoteTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource LedgerGridTextStyle}">
            <Setter Property="ToolTip" Value="{Binding ItemNote}"/>
        </Style>
    </Window.Resources>

        <Grid Margin="12" Grid.IsSharedSizeScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="14,12">
            <StackPanel>
                    <TextBlock Text="집계 종류"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#4FC3F7"/>
                <TextBlock Text="거래처별 집계, 판매/구매/수금·지급 원장, 연수구 납품내역을 한 화면에서 정리합니다."
                           Foreground="#9FB3C8"
                           Margin="0,4,0,0"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,8,0,0"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="개별업체집계일 때는 거래처를 선택하고, 전체업체집계일 때는 검색 결과를 참고만 합니다."
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#90CAF9"/>
                    <TextBlock Text="개별업체집계일 때는 거래처를 선택하고, 전체업체집계일 때는 검색 결과를 참고만 합니다."
                               Margin="0,4,0,0"
                               Foreground="#9FB3C8"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="PeriodSearchLabel"/>
                            <ColumnDefinition Width="230"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="거래처 검색"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBox Grid.Column="1"
                                  Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding CanSelectCustomer}"/>
                        <Button Grid.Column="2"
                                Content="찾기"
                                Style="{StaticResource OutlineButtonStyle}"
                                Margin="8,0,0,0"
                                Command="{Binding SearchCustomerCommand}"
                                IsEnabled="{Binding CanSelectCustomer}"/>
                    </Grid>

                    <ComboBox Margin="0,8,0,0"
                              IsEnabled="{Binding CanSelectCustomer}"
                              ItemsSource="{Binding Customers}"
                              SelectedItem="{Binding SelectedCustomer}"
                              DisplayMemberPath="NameOriginal"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#122038"
                        BorderBrush="#2E4060"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedCustomer.NameOriginal, TargetNullValue=선택된 거래처 없음}"
                                   Foreground="#90CAF9"
                                   FontWeight="Bold"
                                   FontSize="15"/>
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding ScopeHintMessage}"
                                   Foreground="#EF9A9A"
                                   TextWrapping="Wrap"/>
                        <TextBlock Margin="0,12,0,0"
                                   Text="선택거래처"
                                   Foreground="#9FB3C8"/>
                        <TextBlock Text="{Binding SelectedCustomer.NameOriginal, TargetNullValue=선택된 거래처 없음}"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                 Margin="0,8,0,0"
                 Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="PeriodFilterLabel"/>
                        <ColumnDefinition Width="172"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="172"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Content="전월"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,6,0"
                            Command="{Binding SetPreviousMonthCommand}"/>
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="당월"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,12,0"
                            Command="{Binding SetCurrentMonthCommand}"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                                   Text="기간"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="0,0,4,0"/>
                    <DatePicker Grid.Row="0"
                                Grid.Column="3"
                                SelectedDate="{Binding FromDate}"
                                SelectedDateFormat="Short"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                        <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                    </DatePicker>
                    <TextBlock Grid.Row="0"
                               Grid.Column="4"
                               Text="~"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="6,0"/>
                    <DatePicker Grid.Row="0"
                                Grid.Column="5"
                                SelectedDate="{Binding ToDate}"
                                SelectedDateFormat="Short"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                        <DatePicker.Resources>
                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
                    </DatePicker.Resources>
                    </DatePicker>

                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                                   Text="거래처 범위"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="0,12,10,0"/>
                    <ComboBox Grid.Row="1"
                              Grid.Column="3"
                              Grid.ColumnSpan="3"
                              Margin="0,10,0,0"
                              MinWidth="240"
                              ItemsSource="{Binding ScopeOptions}"
                              SelectedItem="{Binding SelectedScopeOption}"/>
                </Grid>

                <Border Grid.Column="1"
                        Background="#122038"
                        BorderBrush="#2E4060"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="옵션"
                                   FontWeight="Bold"
                                   Foreground="#90CAF9"
                                   FontSize="15"/>
                        <CheckBox Content="가나다라순 정렬"
                                  IsChecked="{Binding SortByCustomerName}"
                                  Margin="0,10,0,6"/>
                        <CheckBox Content="순이익 표시"
                                  IsChecked="{Binding ShowProfit}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="집계 종류"
                                   Foreground="#90CAF9"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,10"/>
                        <RadioButton Content="1. 판매+구매 거래 원장" IsChecked="{Binding IsSalesPurchaseSelected}"/>
                        <RadioButton Content="2. 판매/매출 거래 원장" IsChecked="{Binding IsSalesSelected}"/>
                        <RadioButton Content="3. 구매/매입 거래 원장" IsChecked="{Binding IsPurchaseSelected}"/>
                        <RadioButton Content="4. 수금/지급 거래 원장" IsChecked="{Binding IsReceiptPaymentSelected}"/>
                        <RadioButton Content="5. 연수구 납품내역" IsChecked="{Binding IsYeonsuDeliverySelected}"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Padding="10"
                            Background="#122038"
                            BorderBrush="#2E4060"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="진행 상태"
                                       Foreground="#90CAF9"
                                       FontWeight="Bold"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding LastExportPath}"
                                       Margin="0,8,0,0"
                                       Foreground="#A5D6A7"
                                       TextWrapping="Wrap"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0,12,0,0"
                            Padding="10"
                            Background="#122038"
                            BorderBrush="#2E4060"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       Text="요약"
                                       Foreground="#90CAF9"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Text="거래금액" Foreground="#9FB3C8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryTradeAmountText}" TextAlignment="Right" FontWeight="Bold"/>
                            <TextBlock Grid.Row="2" Text="수금액" Foreground="#9FB3C8" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SummaryReceiptAmountText}" TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="3" Text="지급액" Foreground="#9FB3C8" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SummaryPaymentAmountText}" TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="4" Text="누적잔액" Foreground="#9FB3C8" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SummaryRunningBalanceText}" TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="5" Text="거래 건수" Foreground="#9FB3C8" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SummaryCountText}" TextAlignment="Right" FontWeight="Bold" Margin="0,5,0,0"/>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Text="화면은 거래 1건을 1줄로 보여주고, 선택한 거래의 품목 상세만 오른쪽 아래에 표시합니다. 엑셀 출력은 기존처럼 상세/소계를 포함합니다."
                               Foreground="#9FB3C8"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="거래원장 기본 목록"
                                       Foreground="#90CAF9"
                                       FontWeight="Bold"
                                       FontSize="16"/>
                            <TextBlock Text="전표메모는 기본 목록의 비고 칸을 더블클릭해서 수정할 수 있습니다."
                                       Foreground="#9FB3C8"
                                       FontSize="12"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="전표/품목 검색"
                                   VerticalAlignment="Center"
                                   Foreground="#EAF2FF"
                                   Margin="0,0,8,0"/>
                        <TextBox Grid.Column="2"
                                 MinWidth="220"
                                 Text="{Binding LedgerSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <DataGrid x:Name="LedgerRowsDataGrid"
                              Grid.Row="1"
                              Style="{StaticResource LedgerDataGridStyle}"
                              ItemsSource="{Binding LedgerRows}"
                              SelectedItem="{Binding SelectedLedgerRow, Mode=TwoWay}"
                              IsReadOnly="True"
                              MouseDoubleClick="LedgerRowsDataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="거래날짜" Binding="{Binding DateText}" Width="105" ElementStyle="{StaticResource LedgerGridCenterTextStyle}"/>
                            <DataGridTextColumn Header="거래처" Binding="{Binding CustomerName}" Width="1.4*" MinWidth="140" ElementStyle="{StaticResource LedgerGridTextStyle}"/>
                            <DataGridTemplateColumn Header="구분" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding DivisionBackground}"
                                                CornerRadius="9"
                                                Padding="8,2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Division}"
                                                       Foreground="{Binding DivisionForeground}"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="품목요약" Binding="{Binding Summary}" Width="1.6*" MinWidth="160" ElementStyle="{StaticResource LedgerGridTextStyle}"/>
                            <DataGridTextColumn Header="거래금액" Binding="{Binding TradeAmount, StringFormat={}{0:N0}}" Width="110" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="수금액" Binding="{Binding ReceiptAmount, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="지급액" Binding="{Binding PaymentAmount, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="누적잔액" Binding="{Binding RunningBalance, StringFormat={}{0:N0}}" Width="110" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="전표메모" Binding="{Binding NotePreview}" Width="1.2*" MinWidth="140" ElementStyle="{StaticResource LedgerGridNoteTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,10,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="선택 거래 품목 상세"
                                   Foreground="#90CAF9"
                                   FontWeight="Bold"
                                   FontSize="15"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DetailHintText}"
                                   Foreground="#9FB3C8"
                                   TextAlignment="Right"
                                   TextWrapping="Wrap"
                                   Margin="12,0,0,0"/>
                    </Grid>

                    <DataGrid x:Name="DetailItemsDataGrid"
                              Grid.Row="3"
                              Style="{StaticResource LedgerDataGridStyle}"
                              ItemsSource="{Binding SelectedLedgerItems}"
                              SelectedItem="{Binding SelectedLedgerItem, Mode=TwoWay}"
                              IsReadOnly="True"
                              MouseDoubleClick="DetailItemsDataGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="품명" Binding="{Binding ItemName}" Width="1.5*" MinWidth="160" ElementStyle="{StaticResource LedgerGridTextStyle}"/>
                            <DataGridTextColumn Header="규격" Binding="{Binding Specification}" Width="1.3*" MinWidth="140" ElementStyle="{StaticResource LedgerGridTextStyle}"/>
                            <DataGridTextColumn Header="수량" Binding="{Binding Quantity, StringFormat={}{0:N0}}" Width="80" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="단가" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="공급가" Binding="{Binding SupplyAmount, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="부가세" Binding="{Binding VatAmount, StringFormat={}{0:N0}}" Width="90" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="합계" Binding="{Binding LineAmount, StringFormat={}{0:N0}}" Width="100" ElementStyle="{StaticResource LedgerGridRightTextStyle}"/>
                            <DataGridTextColumn Header="품목비고" Binding="{Binding ItemNotePreview}" Width="1.1*" MinWidth="130" ElementStyle="{StaticResource LedgerGridItemNoteTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.Row="4"
                Margin="0,8,0,0"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ProgressBar Grid.Column="0"
                             Width="180"
                             Height="10"
                             Margin="0,0,14,0"
                             Background="#203454"
                             Foreground="#48A8F3"
                             IsIndeterminate="{Binding IsBusy}"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="집계 실행 중에는 진행 표시가 활성화됩니다."
                           Foreground="#8EA6C4"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="집계시작"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding StartAggregationCommand}"
                        Margin="0,0,8,0"/>
                <Button Grid.Column="3"
                        Content="닫기"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="110"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

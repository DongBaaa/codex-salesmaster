<Window x:Class="거래플랜.Desktop.App.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="거래명세서 미리보기"
        Width="1180"
        Height="860"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="92"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="CloseToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <Border DockPanel.Dock="Top"
                Background="#1A2B4A"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="거래명세서 미리보기"
                               Foreground="#EAF2FF"
                               FontFamily="맑은 고딕"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#A7D1FF"
                               FontFamily="맑은 고딕"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="확대"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Background="#314A6B"
                            Command="{Binding ZoomInCommand}"/>
                    <Button Content="축소"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Background="#314A6B"
                            Command="{Binding ZoomOutCommand}"/>
                    <Button Content="인쇄"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Background="#0D47A1"
                            Command="{Binding PrintCommand}"/>
                    <Button Content="닫기"
                            Style="{StaticResource CloseToolbarButtonStyle}"
                            Background="#455A64"
                            Command="{Binding CloseCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Margin="0,12,0,0"
                Background="#0F1D31"
                BorderBrush="#2E4060"
                BorderThickness="1"
                Padding="8"
                CornerRadius="6">
            <DocumentViewer Document="{Binding Document}" Zoom="{Binding Zoom, Mode=TwoWay}" />
        </Border>
    </DockPanel>
</Window>


<Window x:Class="거래플랜.Desktop.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="거래플랜 - 로그인" Width="480" MinWidth="480" MinHeight="450"
        SizeToContent="Height" WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1A2B4A"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4FC3F7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>
        <Style x:Key="FieldPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4FC3F7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Border Background="#10233D"
                BorderBrush="#2C476A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="30,26">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="거래플랜"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#4FC3F7"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="거래플랜 ERP"
                           FontSize="12"
                           Foreground="#90CAF9"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,26"/>

                <TextBlock Text="아이디" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldTextBoxStyle}"/>

                <TextBlock Text="비밀번호" Style="{StaticResource FieldLabelStyle}"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource FieldPasswordBoxStyle}"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <CheckBox Content="아이디 저장"
                              IsChecked="{Binding RememberUsername}"
                              Foreground="#B0BEC5"
                              Margin="0,0,16,0"/>
                    <CheckBox Content="비밀번호 저장"
                              IsChecked="{Binding RememberPassword}"
                              Foreground="#B0BEC5"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#EF9A9A"
                           FontSize="11"
                           Margin="0,8,0,12"
                           MinHeight="30"
                           TextWrapping="Wrap"/>

                <Button Content="로그인"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Background="#0D47A1"
                        IsDefault="True"/>

                <Button Content="오프라인 모드로 시작"
                        Command="{Binding OfflineLoginCommand}"
                        Visibility="{Binding ShowOfflineButton, Converter={StaticResource BoolToVisibility}}"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Background="#37474F"
                        Foreground="#D2E8FF"
                        Margin="0,8,0,0"/>

                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Margin="0,10,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>


<Window x:Class="거래플랜.Desktop.App.Views.RentalSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="렌탈 기준설정"
        Height="900"
        Width="1180"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="렌탈 기준설정" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7"/>
                    <TextBlock Text="알림 기준, 담당지점 기준, 엑셀 가져오기 경로를 관리합니다." Foreground="#9FB3C8" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="새로고침" Margin="0,0,6,0" Command="{Binding ReloadCommand}"/>
                    <Button Content="닫기 (F12)" Click="CloseButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="알림/가져오기 설정" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="알림 기준" VerticalAlignment="Center" Margin="0,0,4,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding AlertDaysText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="저장" Background="#1B5E20" BorderBrush="#1B5E20" Command="{Binding SaveAlertSettingsCommand}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="청구 파일" VerticalAlignment="Center" Margin="0,0,4,8"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BillingWorkbookPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8"/>
                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                        <Button Content="찾기" Width="70" MinWidth="70" Margin="0,0,6,0" Command="{Binding BrowseBillingWorkbookCommand}"/>
                        <Button Content="가져오기" Width="88" MinWidth="88" Background="#1565C0" BorderBrush="#1565C0" Command="{Binding ImportBillingWorkbookCommand}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="자산 파일" VerticalAlignment="Center" Margin="0,0,4,8"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding AssetWorkbookPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8"/>
                    <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal">
                        <Button Content="찾기" Width="70" MinWidth="70" Margin="0,0,6,0" Command="{Binding BrowseAssetWorkbookCommand}"/>
                        <Button Content="가져오기" Width="88" MinWidth="88" Background="#00897B" BorderBrush="#00897B" Command="{Binding ImportAssetWorkbookCommand}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="예: 7,3,1,0 → 7일 전, 3일 전, 하루 전, 당일 알림" Foreground="#9FB3C8" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="5" Grid.ColumnSpan="3" Text="엑셀 가져오기는 관리자 권한에서만 권장합니다." Foreground="#9FB3C8" Margin="0,6,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="담당지점 목록" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Offices}" BorderThickness="0" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="코드" Binding="{Binding Code}" Width="140"/>
                            <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="220"/>
                            <DataGridCheckBoxColumn Header="대표" Binding="{Binding IsHeadOffice}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <TextBlock Text="렌탈의 담당지점은 공용 담당지점 마스터를 그대로 사용합니다." Foreground="#9FB3C8"/>
                        <TextBlock Text="담당지점 추가/수정은 환경설정 > 담당지점 관리에서 진행하세요." Foreground="#9FB3C8" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,10,0,0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="렌탈 거래처명 정리" Foreground="#4FC3F7" FontWeight="Bold"/>
                        <TextBlock Text="메인 거래처 테이블 기준으로 렌탈 청구프로필/설치자산의 거래처명과 담당지점 연결을 점검합니다." Foreground="#9FB3C8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button Content="검토 새로고침" Margin="0,0,6,0" Command="{Binding ReloadCustomerLinkCleanupCommand}"/>
                        <Button Content="메인 거래처명 동기화" Background="#1565C0" BorderBrush="#1565C0" Command="{Binding NormalizeCustomerLinksCommand}" IsEnabled="{Binding CanManage}"/>
                    </WrapPanel>
                </DockPanel>

                <TextBlock Grid.Row="1" Text="{Binding CustomerLinkCleanupSummary}" Foreground="#90CAF9" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="2" ItemsSource="{Binding CustomerLinkCleanupRows}" BorderThickness="0" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="유형" Binding="{Binding EntityType}" Width="90"/>
                        <DataGridTextColumn Header="담당지점" Binding="{Binding ResponsibleOfficeName}" Width="110"/>
                        <DataGridTextColumn Header="현재 거래처명" Binding="{Binding CurrentCustomerName}" Width="190"/>
                        <DataGridTextColumn Header="메인 거래처명" Binding="{Binding MasterCustomerName}" Width="190"/>
                        <DataGridTextColumn Header="품명" Binding="{Binding ItemName}" Width="150"/>
                        <DataGridTextColumn Header="설치위치" Binding="{Binding InstallLocation}" Width="160"/>
                        <DataGridTextColumn Header="연결 청구프로필" Binding="{Binding LinkedProfileDisplay}" Width="220"/>
                        <DataGridTextColumn Header="이슈" Binding="{Binding IssueSummary}" Width="220"/>
                        <DataGridTextColumn Header="권장 처리" Binding="{Binding SuggestedAction}" Width="190"/>
                        <DataGridCheckBoxColumn Header="자동" Binding="{Binding CanAutoNormalize}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,10,0,0" Background="#122038" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10">
            <DockPanel LastChildFill="False">
                <ProgressBar Width="220" Height="12" IsIndeterminate="{Binding IsBusy}" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#90CAF9" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>

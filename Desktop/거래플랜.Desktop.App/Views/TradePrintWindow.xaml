<Window x:Class="거래플랜.Desktop.App.Views.TradePrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="거래플랜 인쇄"
        Width="780"
        Height="560"
        MinWidth="780"
        MinHeight="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        FontFamily="맑은 고딕">
    <Window.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A7D1FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0B2036"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16,14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="거래플랜 전용 인쇄"
                           Foreground="#EAF2FF"
                           FontSize="22"
                           FontWeight="Bold"/>
                <TextBlock Text="Windows 기본 인쇄창 대신 거래플랜 안에서 프린터, 페이지, 매수를 선택해 바로 인쇄하거나 문서 파일로 저장합니다."
                           Foreground="#A7D1FF"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="프린터" Style="{StaticResource SectionTitleStyle}"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="PrinterComboBox"
                              Grid.Column="0"
                              Height="34"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="OnPrinterSelectionChanged"/>
                    <Button x:Name="PropertiesButton"
                            Grid.Column="1"
                            Content="속성..."
                            Width="112"
                            Height="34"
                            Margin="10,0,0,0"
                            Click="OnPrinterPropertiesClick"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="종류:" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="PrinterTypeTextBlock" Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="위치:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    <TextBlock x:Name="PrinterLocationTextBlock" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="상태:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    <TextBlock x:Name="PrinterStatusTextBlock" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}" Margin="0,4,0,0"/>
                </Grid>

                <CheckBox x:Name="ReverseOrderCheckBox"
                          Grid.Row="3"
                          Content="역방향 인쇄"
                          Foreground="#EAF2FF"
                          Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionBorderStyle}">
                <StackPanel>
                    <TextBlock Text="페이지" Style="{StaticResource SectionTitleStyle}"/>
                    <RadioButton x:Name="AllPagesRadioButton"
                                 Content="모든 페이지"
                                 GroupName="PageMode"
                                 Foreground="#EAF2FF"
                                 IsChecked="True"
                                 Checked="OnPageModeChecked"
                                 Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="PageRangeRadioButton"
                                     Content="페이지:"
                                     GroupName="PageMode"
                                     Foreground="#EAF2FF"
                                     VerticalAlignment="Center"
                                     Checked="OnPageModeChecked"/>
                        <TextBox x:Name="PageRangeTextBox"
                                 Width="190"
                                 Height="30"
                                 Margin="10,0,0,0"
                                 IsEnabled="False"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="PageHelpTextBlock"
                               Text="페이지 번호나 범위를 쉼표로 구분하세요. 예: 1,3,5-12"
                               Foreground="#A7D1FF"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="PageCountTextBlock"
                               Foreground="#6FD3FF"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="인쇄 매수" Style="{StaticResource SectionTitleStyle}"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="인쇄 매수"
                                   Style="{StaticResource LabelStyle}"
                                   Width="90"/>
                        <TextBox x:Name="CopyCountTextBox"
                                 Width="80"
                                 Height="30"
                                 Text="1"
                                 TextAlignment="Right"
                                 VerticalContentAlignment="Center"/>
                        <StackPanel Margin="6,0,0,0">
                            <Button Content="▲" Width="32" Height="15" Padding="0" Click="OnCopyCountIncreaseClick"/>
                            <Button Content="▼" Width="32" Height="15" Padding="0" Click="OnCopyCountDecreaseClick"/>
                        </StackPanel>
                    </StackPanel>
                    <CheckBox x:Name="CollateCheckBox"
                              Grid.Row="2"
                              Content="한 부씩 인쇄"
                              Foreground="#EAF2FF"
                              IsChecked="True"
                              Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="5"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="0"
                           Text="프린터와 인쇄 옵션을 확인한 뒤 확인을 누르세요."
                           Foreground="#90CAF9"
                           FontSize="13"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="PDF 저장"
                            Style="{StaticResource DialogButtonStyle}"
                            MinWidth="112"
                            Background="#526985"
                            Click="OnSavePdfClick"/>
                    <Button Content="파일 저장(XPS)"
                            Style="{StaticResource DialogButtonStyle}"
                            MinWidth="132"
                            Background="#526985"
                            Click="OnSaveFileClick"/>
                    <Button x:Name="PrintButton"
                            Content="확인"
                            Style="{StaticResource DialogButtonStyle}"
                            Background="#1F7ACC"
                            IsDefault="True"
                            Click="OnOkClick"/>
                    <Button Content="취소"
                            Style="{StaticResource DialogButtonStyle}"
                            Background="#3D4F66"
                            IsCancel="True"
                            Click="OnCancelClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

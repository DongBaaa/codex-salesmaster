<Window x:Class="거래플랜.Desktop.App.Views.RentalAssetLinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="렌탈 자산 연결"
        Height="820"
        Width="1480"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style x:Key="ReadOnlyInfoTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#24364F"/>
            <Setter Property="BorderBrush" Value="#324A69"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Height" Value="28"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="SelectedDateFormat" Value="Short"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0,10,0"/>
        </Style>
        <Style x:Key="RentalDatePickerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource UnifiedDatePickerButtonStyle}"/>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="렌탈 자산 연결" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7"/>
                    <TextBlock Text="설치현황 자산을 선택해 현재 거래처 청구에 연결하고, 저장 시 거래처명/설치정보도 함께 반영합니다." Foreground="#9FB3C8" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="현재 거래처" Foreground="#9FB3C8" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding CurrentCustomerName}" FontSize="18" FontWeight="Bold" Foreground="#81D4FA" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding CurrentOfficeName, StringFormat=담당지점: {0}}" Foreground="#9FB3C8" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="검색" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Width="260" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                <CheckBox Content="다른 청구프로필 연결 장비도 표시" IsChecked="{Binding IncludeRelinkTargets}" Foreground="#EAF2FF" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="새로고침" Command="{Binding ReloadCommand}" Background="#1565C0" BorderBrush="#1565C0"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.3*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                <DataGrid ItemsSource="{Binding Assets}" SelectedItem="{Binding SelectedAsset}" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="선택" Binding="{Binding IsSelected, Mode=TwoWay}" Width="54"/>
                        <DataGridTextColumn Header="시리얼번호" Binding="{Binding MachineNumber}" Width="150"/>
                        <DataGridTextColumn Header="품명" Binding="{Binding ItemName}" Width="150"/>
                        <DataGridTextColumn Header="현재 거래처" Binding="{Binding CurrentCustomerName}" Width="170"/>
                        <DataGridTextColumn Header="설치위치" Binding="{Binding InstallLocation}" Width="180"/>
                        <DataGridTextColumn Header="상태" Binding="{Binding AssetStatus}" Width="84"/>
                        <DataGridTextColumn Header="현재 청구프로필" Binding="{Binding CurrentBillingProfileDisplay}" Width="220"/>
                        <DataGridTextColumn Header="담당지점" Binding="{Binding ResponsibleOfficeName}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="선택 자산 상세정보" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="연결 거래처" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAsset.TargetCustomerName}" Style="{StaticResource ReadOnlyInfoTextBoxStyle}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="현재 청구프로필" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAsset.CurrentBillingProfileDisplay}" Style="{StaticResource ReadOnlyInfoTextBoxStyle}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="설치위치" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAsset.InstallLocation, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="월 렌탈료" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectedAsset.MonthlyFee, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="계약 시작일" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding SelectedAsset.ContractStartDate}" SelectedDateFormat="Short" Margin="0,0,0,8">
                                <DatePicker.Resources>
                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource RentalDatePickerButtonStyle}"/>
                                </DatePicker.Resources>
                            </DatePicker>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="청구상태" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SelectedAsset.BillingEligibilityStatus}" Style="{StaticResource ReadOnlyInfoTextBoxStyle}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="기계 매입일" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SelectedAsset.PurchaseDateDisplay, Mode=OneWay}" Style="{StaticResource ReadOnlyInfoTextBoxStyle}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="설치일" VerticalAlignment="Center" Margin="0,0,10,8"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SelectedAsset.InstallDateDisplay, Mode=OneWay}" Style="{StaticResource ReadOnlyInfoTextBoxStyle}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="메모" VerticalAlignment="Top" Margin="0,0,10,0"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SelectedAsset.Notes, UpdateSourceTrigger=PropertyChanged}" Height="84" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </Grid>

                        <Border Background="#223754" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="안내" Foreground="#4FC3F7" FontWeight="Bold"/>
                                <TextBlock Text="선택된 장비는 저장 시 현재 거래처에 연결되고, 설치현황 거래처명도 메인 거래처명 기준으로 함께 정리됩니다." Margin="0,6,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="다른 청구프로필에 연결된 장비를 선택하면 저장 전에 재연결 여부를 다시 확인합니다." Foreground="#FFCC80" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,10,0,0" Background="#122038" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="선택 반영" Background="#1B5E20" BorderBrush="#1B5E20" Margin="0,0,8,0" Click="ConfirmButton_Click" IsEnabled="{Binding CanConfirm}"/>
                    <Button Content="취소" Click="CancelButton_Click"/>
                </StackPanel>
                <ProgressBar Width="220" Height="12" IsIndeterminate="{Binding IsBusy}" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#90CAF9" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>

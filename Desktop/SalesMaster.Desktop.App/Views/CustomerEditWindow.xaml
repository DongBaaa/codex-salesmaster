<Window x:Class="SalesMaster.Desktop.App.Views.CustomerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SalesMaster.Desktop.App.Converters"
        Title="거래처 등록/수정" Height="720" Width="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1A2B4A" KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="CaretBrush" Value="Black"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Padding" Value="0,0,6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#0D47A1" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="거래처 등록 및 수정"
                           FontSize="15" FontWeight="Bold" Foreground="White"/>
                <Button Grid.Column="1" Content="닫기 (F12)" Background="#B71C1C"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#0D1B2A" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="신규 거래처 정보를 입력한 뒤 저장하거나 연속입력을 사용하세요."
                           Foreground="#90CAF9" FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="연속입력 (F6)" Background="#00695C"
                        Margin="0,0,8,0" Command="{Binding SaveAndNewCommand}"/>
                <Button Grid.Column="2" Content="저장" Background="#0D47A1" Padding="20,6"
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#1B5E20" Padding="12,4"
                Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#A5D6A7" FontSize="11"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,10" Width="620">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="거래처명"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Background="#D9E6F5" Foreground="Black" FontWeight="Bold"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="고객분류"/>
                    <ComboBox Grid.Row="0" Grid.Column="3"
                              ItemsSource="{Binding Categories}"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding CategoryId}"
                              DisplayMemberPath="Name"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="대표전화"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="담당자"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="휴대폰"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MobilePhone, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="2" Grid.Column="2" Content="팩스번호"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding FaxNumber, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="부서"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="3" Grid.Column="2" Content="가격등급"/>
                    <ComboBox Grid.Row="3" Grid.Column="3"
                              ItemsSource="{Binding PriceGrades}"
                              SelectedItem="{Binding PriceGrade}"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="담당지점"/>
                    <ComboBox Grid.Row="4" Grid.Column="1"
                              ItemsSource="{Binding OfficeCodes}"
                              SelectedItem="{Binding ResponsibleOfficeCode}"/>
                </Grid>

                <Separator Background="#2E4060" Margin="0,6"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="사업자번호"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BusinessNumber, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="대표자명"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Representative, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="업태"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BusinessType, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="종목"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding BusinessItem, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Separator Background="#2E4060" Margin="0,6"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="업체주소"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="상세주소"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DetailAddress, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Separator Background="#2E4060" Margin="0,6"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="받는분"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Recipient, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="등록일자"/>
                    <DatePicker Grid.Row="0" Grid.Column="3"
                                SelectedDate="{Binding RegisterDate, Converter={StaticResource DateOnlyConverter}}"
                                Background="#D9E6F5" Foreground="Black"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="E-MAIL"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="홈페이지"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                             Text="{Binding HomePage, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Separator Background="#2E4060" Margin="0,6"/>

                <Label Content="메모사항" HorizontalContentAlignment="Left" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" Height="90" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="필수 항목(거래처명)을 먼저 입력해주세요."
                           Foreground="#EF9A9A" FontSize="11" Margin="0,8,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>

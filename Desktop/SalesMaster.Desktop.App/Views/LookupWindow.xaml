<Window x:Class="SalesMaster.Desktop.App.Views.LookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="검색" Height="480" Width="540"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#1E2D40">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0"
                     Background="White" Foreground="Black" BorderBrush="#4FC3F7"
                     Padding="8,6" FontSize="13"
                     KeyDown="SearchBox_KeyDown"
                     TextChanged="SearchBox_TextChanged"/>
            <Button Content="검색" Grid.Column="1" Margin="6,0,0,0"
                    Background="#0D47A1" Foreground="White" Padding="12,6"
                    BorderThickness="0" Click="SearchButton_Click"/>
        </Grid>

        <DataGrid Grid.Row="1"
                  x:Name="ResultGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="#1E2D40"
                  Foreground="White"
                  RowBackground="#243B55"
                  AlternatingRowBackground="#1E2D40"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#2E3D50"
                  BorderThickness="1" BorderBrush="#4FC3F7"
                  MouseDoubleClick="ResultGrid_MouseDoubleClick"
                  KeyDown="ResultGrid_KeyDown">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1A2B4A"/>
                    <Setter Property="Foreground" Value="#4FC3F7"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="이름" Binding="{Binding PrimaryText}" Width="*"/>
                <DataGridTextColumn Header="추가정보" Binding="{Binding SecondaryText}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="RegisterButton" Visibility="Collapsed" Padding="16,6" Margin="0,0,8,0"
                    Background="#2E7D32" Foreground="White" BorderThickness="0"
                    Click="RegisterButton_Click"/>
            <Button Content="선택 (Enter)" Padding="16,6" Margin="0,0,8,0"
                    Background="#0D47A1" Foreground="White" BorderThickness="0"
                    Click="SelectButton_Click"/>
            <Button Content="취소 (Esc)" Padding="16,6"
                    Background="#455A64" Foreground="White" BorderThickness="0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

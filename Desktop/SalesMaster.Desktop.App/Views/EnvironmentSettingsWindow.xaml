<Window x:Class="SalesMaster.Desktop.App.Views.EnvironmentSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경설정"
        Height="820"
        Width="1240"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0C4DA"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#151F2E"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#9FB3C8"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A2B4A"
                Padding="12"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="환경설정" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7"/>
                    <TextBlock Text="회사 정보, 담당지점, 사용자 계정을 관리합니다." Foreground="#9FB3C8" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="닫기(F12)"
                        Width="120"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,10,0,0">
            <TabItem Header="회사 설정">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#1A2B4A" CornerRadius="6" Padding="16" BorderBrush="#2E4060" BorderThickness="1">
                            <StackPanel MaxWidth="760">
                                <TextBlock Text="회사 기본 정보" FontSize="18" FontWeight="Bold" Foreground="#4FC3F7" Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Content="상호"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CompanyTradeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="대표자"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CompanyRepresentative, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Label Grid.Row="2" Grid.Column="0" Content="사업자번호"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CompanyBusinessNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Label Grid.Row="3" Grid.Column="0" Content="업태"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CompanyBusinessType, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Label Grid.Row="4" Grid.Column="0" Content="종목"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CompanyBusinessItem, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Label Grid.Row="5" Grid.Column="0" Content="주소"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Label Grid.Row="6" Grid.Column="0" Content="연락처"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding CompanyContactNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Label Grid.Row="7" Grid.Column="0" Content="이메일"/>
                                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding CompanyEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Label Grid.Row="8" Grid.Column="0" Content="계좌문구"/>
                                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding CompanyBankAccountText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="72" Margin="0,0,0,8"/>
                                    <Label Grid.Row="9" Grid.Column="0" Content="직인 이미지"/>
                                    <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding CompanyStampImagePath}" VerticalAlignment="Center" Foreground="#90CAF9" Margin="0,0,10,0"/>
                                        <Button Content="이미지 선택" Background="#37474F" Command="{Binding SelectStampImageCommand}" Margin="0,0,6,0"/>
                                        <Button Content="삭제" Background="#E53935" Command="{Binding ClearStampImageCommand}"/>
                                    </StackPanel>
                                </Grid>
                                <Button Content="회사 정보 저장" Background="#1E88E5" HorizontalAlignment="Left" Command="{Binding SaveCompanyProfileCommand}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#102039" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="외부 레거시 데이터 추출/가져오기" Foreground="#4FC3F7" FontWeight="Bold" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="원본 DB(FDB)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding LegacySourceDbPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="찾기" Background="#455A64" Command="{Binding SelectLegacySourceDbPathCommand}"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="거래처 엑셀" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding LegacyCustomerExcelPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="찾기" Background="#455A64" Command="{Binding SelectLegacyCustomerExcelPathCommand}"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="제품 엑셀" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding LegacyItemExcelPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="찾기" Background="#455A64" Command="{Binding SelectLegacyItemExcelPathCommand}"/>
                                </Grid>

                                <WrapPanel Margin="0,4,0,0">
                                    <Button Content="1) 원본 DB → 엑셀 추출" Background="#00796B" Command="{Binding ExportLegacyDataCommand}" Margin="0,0,8,0"/>
                                    <Button Content="2) 엑셀 → 코덱스 DB 반영" Background="#1565C0" Command="{Binding ImportLegacyExcelDataCommand}" Margin="0,0,8,0"/>
                                    <Button Content="추출 + 반영 한번에" Background="#6D4C41" Command="{Binding ExportAndImportLegacyDataCommand}"/>
                                </WrapPanel>

                                <TextBlock Text="{Binding LegacyMigrationStatus}" Foreground="#90CAF9" Margin="0,10,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="선택값 관리">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#1A2B4A" CornerRadius="6" Padding="16" BorderBrush="#2E4060" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="거래처 선택값 관리" FontSize="18" FontWeight="Bold" Foreground="#4FC3F7"/>
                                <TextBlock Text="거래처 등록/수정에서 사용하는 고객분류, 가격등급, 거래구분 선택값을 관리합니다." Foreground="#9FB3C8" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Margin="0,14,0,0">
                            <Grid Margin="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="고객분류" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    <Button Content="신규" Background="#1565C0" Margin="14,0,6,0" Command="{Binding NewCategoryOptionCommand}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveCategoryOptionCommand}"/>
                                    <Button Content="삭제" Background="#C62828" Command="{Binding DeleteCategoryOptionCommand}"/>
                                </StackPanel>

                                <DataGrid Grid.Row="1" Grid.Column="0"
                                          ItemsSource="{Binding CustomerCategories}"
                                          SelectedItem="{Binding SelectedCategoryOption}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="기본" Binding="{Binding IsSystemDefault}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1" Grid.Column="2" Background="#102039" CornerRadius="6" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="고객분류 편집" Foreground="#90CAF9" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Label Content="이름"/>
                                        <TextBox Text="{Binding CategoryOptionName, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="기본 고객분류는 이름 수정만 가능하고 삭제는 제한됩니다." Foreground="#9FB3C8" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Margin="0,14,0,0">
                            <Grid Margin="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="가격등급" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    <Button Content="신규" Background="#1565C0" Margin="14,0,6,0" Command="{Binding NewPriceGradeOptionCommand}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SavePriceGradeOptionCommand}"/>
                                    <Button Content="삭제" Background="#C62828" Command="{Binding DeletePriceGradeOptionCommand}"/>
                                </StackPanel>

                                <DataGrid Grid.Row="1" Grid.Column="0"
                                          ItemsSource="{Binding PriceGradeOptions}"
                                          SelectedItem="{Binding SelectedPriceGradeOption}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="기준단가" Binding="{Binding PriceSourceDisplay}" Width="110"/>
                                        <DataGridCheckBoxColumn Header="기본" Binding="{Binding IsSystemDefault}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1" Grid.Column="2" Background="#102039" CornerRadius="6" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="가격등급 편집" Foreground="#90CAF9" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Label Content="이름"/>
                                        <TextBox Text="{Binding PriceGradeOptionName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                        <Label Content="기준단가"/>
                                        <ComboBox ItemsSource="{Binding PriceSourceOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding PriceGradePriceSource}"/>
                                        <TextBlock Text="가격등급명은 자유롭게 수정할 수 있고, 기준단가는 실제 품목 단가 필드와 연결됩니다." Foreground="#9FB3C8" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Margin="0,14,0,0">
                            <Grid Margin="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="거래구분" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                    <Button Content="신규" Background="#1565C0" Margin="14,0,6,0" Command="{Binding NewTradeTypeOptionCommand}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveTradeTypeOptionCommand}"/>
                                    <Button Content="삭제" Background="#C62828" Command="{Binding DeleteTradeTypeOptionCommand}"/>
                                </StackPanel>

                                <DataGrid Grid.Row="1" Grid.Column="0"
                                          ItemsSource="{Binding TradeTypeOptions}"
                                          SelectedItem="{Binding SelectedTradeTypeOption}"
                                          IsReadOnly="True"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="매출" Binding="{Binding AllowsSales}" Width="80"/>
                                        <DataGridCheckBoxColumn Header="매입" Binding="{Binding AllowsPurchase}" Width="80"/>
                                        <DataGridCheckBoxColumn Header="기본" Binding="{Binding IsSystemDefault}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1" Grid.Column="2" Background="#102039" CornerRadius="6" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="거래구분 편집" Foreground="#90CAF9" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <Label Content="이름"/>
                                        <TextBox Text="{Binding TradeTypeOptionName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                        <CheckBox Content="매출 가능" IsChecked="{Binding TradeTypeAllowsSales}" Margin="0,0,0,6"/>
                                        <CheckBox Content="매입 가능" IsChecked="{Binding TradeTypeAllowsPurchase}"/>
                                        <TextBlock Text="거래구분은 판매/구매 화면의 거래처 선택 가능 여부를 결정합니다." Foreground="#9FB3C8" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="담당지점 관리">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="신규 담당지점" Background="#1565C0" Margin="0,0,6,0" Command="{Binding NewOfficeCommand}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveOfficeCommand}"/>
                                    <Button Content="삭제" Background="#C62828" Margin="0,0,6,0" Command="{Binding DeleteOfficeCommand}"/>
                                    <Button Content="새로고침" Background="#455A64" Command="{Binding ReloadOfficesCommand}"/>
                                </StackPanel>
                            </Border>
                            <DataGrid ItemsSource="{Binding Offices}"
                                      SelectedItem="{Binding SelectedOffice}"
                                      IsReadOnly="True"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="코드" Binding="{Binding Code}" Width="140"/>
                                    <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*"/>
                                    <DataGridCheckBoxColumn Header="기본지점" Binding="{Binding IsHeadOffice}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <TextBlock Text="담당지점 편집" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="기본 담당지점도 관리자 계정에서는 코드와 이름을 수정할 수 있습니다. 삭제만 제한됩니다." Foreground="#9FB3C8" Margin="0,8,0,12" TextWrapping="Wrap"/>

                            <Label Content="담당지점 코드"/>
                            <TextBox Text="{Binding OfficeCode, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanEditOfficeCode}"
                                     Margin="0,0,0,10"/>

                            <Label Content="담당지점 이름"/>
                            <TextBox Text="{Binding OfficeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="사용자 관리">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#102039" Padding="12" CornerRadius="6,6,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="신규 사용자" Background="#1565C0" Margin="0,0,6,0" Command="{Binding NewUserCommand}"/>
                                    <Button Content="저장" Background="#1B5E20" Margin="0,0,6,0" Command="{Binding SaveUserCommand}" IsEnabled="{Binding CanManageUsers}"/>
                                    <Button Content="삭제" Background="#C62828" Margin="0,0,6,0" Command="{Binding DeleteUserCommand}" IsEnabled="{Binding CanManageUsers}"/>
                                    <Button Content="새로고침" Background="#455A64" Command="{Binding ReloadUsersCommand}" IsEnabled="{Binding CanManageUsers}"/>
                                </StackPanel>
                            </Border>
                            <DataGrid ItemsSource="{Binding Users}"
                                      SelectedItem="{Binding SelectedUser}"
                                      IsReadOnly="True"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="아이디" Binding="{Binding Username}" Width="*"/>
                                    <DataGridTextColumn Header="담당지점" Binding="{Binding OfficeCode}" Width="120"/>
                                    <DataGridTextColumn Header="권한" Binding="{Binding Role}" Width="120"/>
                                    <DataGridCheckBoxColumn Header="활성" Binding="{Binding IsActive}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1A2B4A" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <TextBlock Text="사용자 계정 편집" Foreground="#4FC3F7" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding UserManagementHint}"
                                       Foreground="#9FB3C8"
                                       Margin="0,8,0,12"
                                       TextWrapping="Wrap"/>

                            <Label Content="아이디"/>
                            <TextBox Text="{Binding EditingUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"
                                     IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="담당지점"/>
                            <ComboBox ItemsSource="{Binding UserOfficeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding EditingUserOfficeCode}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="권한"/>
                            <ComboBox ItemsSource="{Binding RoleOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding EditingUserRole}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <CheckBox Content="활성 계정"
                                      IsChecked="{Binding EditingUserIsActive}"
                                      Margin="0,0,0,10"
                                      IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="비밀번호"/>
                            <TextBox Text="{Binding EditingPassword, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"
                                     IsEnabled="{Binding CanManageUsers}"/>

                            <Label Content="비밀번호 확인"/>
                            <TextBox Text="{Binding EditingPasswordConfirm, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"
                                     IsEnabled="{Binding CanManageUsers}"/>

                            <TextBlock Text="신규 사용자는 비밀번호가 필수이고, 기존 사용자는 비워두면 변경하지 않습니다."
                                       Foreground="#9FB3C8"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar Width="220" Height="12" IsIndeterminate="{Binding IsBusy}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#90CAF9" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>

<Window x:Class="SalesMaster.Desktop.App.Views.CustomerManagementWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="거래처 관리"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AlternatingRowBackground" Value="#223754"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A2B4A"
                Padding="12"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="거래처 관리"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#4FC3F7"/>
                <TextBlock Text="거래처 등록, 수정, 담당지점 변경을 관리합니다."
                           Foreground="#9FB3C8"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Background="#1A2B4A"
                Padding="12"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Width="340"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"/>
                    <Button Content="찾기"
                            Margin="8,0,0,0"
                            Command="{Binding SearchCommand}"/>
                    <TextBlock Text="고객분류"
                               Margin="16,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#9FB3C8"/>
                    <ComboBox Width="170"
                              ItemsSource="{Binding CategoryFilters}"
                              SelectedItem="{Binding SelectedCategoryFilter}"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="거래처 신규 등록"
                            Background="#1565C0"
                            BorderBrush="#1565C0"
                            Margin="0,0,6,0"
                            Click="CreateCustomerButton_Click"/>
                    <Button Content="선택 거래처 수정"
                            Background="#8E24AA"
                            BorderBrush="#8E24AA"
                            Margin="0,0,6,0"
                            Click="EditCustomerButton_Click"/>
                    <Rectangle Width="1"
                               Height="18"
                               Fill="#3E5875"
                               Margin="4,0,10,0"
                               VerticalAlignment="Center"/>
                    <Button Content="담당지점 저장"
                            Background="#1B5E20"
                            BorderBrush="#1B5E20"
                            Margin="0,0,6,0"
                            Command="{Binding SaveOfficeChangesCommand}"/>
                    <Button Content="새로고침"
                            Margin="0,0,6,0"
                            Command="{Binding ReloadCommand}"/>
                    <Button Content="닫기"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#1A2B4A"
                CornerRadius="6"
                BorderBrush="#2E4060"
                BorderThickness="1">
                <DataGrid x:Name="CustomerRowsDataGrid"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}"
                      IsReadOnly="False"
                      BorderThickness="0"
                      MouseDoubleClick="CustomerRowsDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="거래처명" Binding="{Binding NameOriginal, Mode=OneWay}" Width="2.3*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="고객분류" Binding="{Binding CategoryName, Mode=OneWay}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="사업자번호" Binding="{Binding BusinessNumber, Mode=OneWay}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="대표전화" Binding="{Binding Phone, Mode=OneWay}" Width="130" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="담당지점" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.OfficeCodes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding ResponsibleOfficeCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridCheckBoxColumn Header="변경됨"
                                            Binding="{Binding IsModified, Mode=OneWay}"
                                            Width="80"
                                            IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,10,0,0"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ProgressBar Width="220"
                                 Height="12"
                                 IsIndeterminate="{Binding IsBusy}"
                                 Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#90CAF9"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>

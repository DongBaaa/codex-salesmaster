<Window x:Class="SalesMaster.Desktop.App.Views.PeriodLedgerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="자료 기간별 집계"
        Height="760"
        Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="40"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="Height" Value="40"/>
        </Style>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}"/>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#435A72"/>
            <Setter Property="BorderBrush" Value="#5D7593"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#546D88"/>
                    <Setter Property="BorderBrush" Value="#7F9ABB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#364A5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#6A86A8"/>
            <Setter Property="Foreground" Value="#D9E8FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#273C5B"/>
                    <Setter Property="BorderBrush" Value="#8FB4DD"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F324E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#2D8DE0"/>
            <Setter Property="BorderBrush" Value="#2D8DE0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="MinWidth" Value="140"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#47A1F1"/>
                    <Setter Property="BorderBrush" Value="#47A1F1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E79CC"/>
                    <Setter Property="BorderBrush" Value="#1E79CC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="자료 기간별 집계" FontSize="22" FontWeight="Bold" Foreground="#4FC3F7"/>
                <TextBlock Text="전체자료 집계 - 거래처/판매/구매/수금지불 원장" Foreground="#9FB3C8" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="고객(거래처) 찾기" Margin="0,0,0,6"/>
                    <Grid Width="730">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Row="0"
                                 Grid.Column="0"
                                 Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanSelectCustomer}"/>
                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Content="찾기"
                                Style="{StaticResource OutlineButtonStyle}"
                                Margin="10,0,0,0"
                                Width="110"
                                Command="{Binding SearchCustomerCommand}"
                                IsEnabled="{Binding CanSelectCustomer}"/>
                        <ComboBox Grid.Row="1"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  Margin="0,10,0,0"
                                  IsEnabled="{Binding CanSelectCustomer}"
                                  ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}"
                                  DisplayMemberPath="NameOriginal"/>
                    </Grid>
                </StackPanel>

                <Border Grid.Column="1" Margin="10,0,0,0" Background="#122038" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel>
                        <TextBlock Text="[ 고객/거래처 정보 ]" Foreground="#90CAF9" FontWeight="Bold"/>
                        <TextBlock Margin="0,10,0,0" Text="{Binding ScopeHintMessage}" Foreground="#EF9A9A" TextWrapping="Wrap"/>
                        <TextBlock Margin="0,8,0,0" Text="선택거래처" Foreground="#9FB3C8"/>
                        <TextBlock Text="{Binding SelectedCustomer.NameOriginal}" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="0,10,0,0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0"
                                Grid.Column="0"
                                Content="전월"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="88"
                                Command="{Binding SetPreviousMonthCommand}"/>
                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Content="당월"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,14,0"
                                Width="88"
                                Command="{Binding SetCurrentMonthCommand}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="기간" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding FromDate}" Width="160" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="~" Margin="8,0" VerticalAlignment="Center"/>
                        <DatePicker Grid.Row="0" Grid.Column="5" SelectedDate="{Binding ToDate}" Width="160" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="구분" Margin="0,12,8,0" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,12,0,0"
                                  Width="210"
                                  ItemsSource="{Binding ScopeOptions}"
                                  SelectedItem="{Binding SelectedScopeOption}"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="옵션" FontWeight="Bold" Foreground="#90CAF9" Margin="0,0,0,6"/>
                    <CheckBox Content="순이익표시" IsChecked="{Binding ShowProfit}" Margin="0,0,0,4"/>
                    <CheckBox Content="가나다라순 정렬" IsChecked="{Binding SortByCustomerName}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,10,0,0" Background="#1A2B4A" Padding="12" CornerRadius="6" BorderBrush="#2E4060" BorderThickness="1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="집계 종류" Foreground="#90CAF9" FontWeight="Bold" Margin="0,0,0,10"/>
                    <RadioButton Content="1. 기간내의 판매+구매 거래 원장" IsChecked="{Binding IsSalesPurchaseSelected}"/>
                    <RadioButton Content="2. 기간내의 판매/매출 거래 원장" IsChecked="{Binding IsSalesSelected}"/>
                    <RadioButton Content="3. 기간내의 구매/매입 거래 원장" IsChecked="{Binding IsPurchaseSelected}"/>
                    <RadioButton Content="4. 기간내의 수금/지불 거래 원장" IsChecked="{Binding IsReceiptPaymentSelected}"/>

                    <Border Margin="0,16,0,0" Background="#122038" BorderBrush="#2E4060" BorderThickness="1" CornerRadius="4" Padding="10">
                        <StackPanel>
                            <TextBlock Text="진행 상태" Foreground="#90CAF9" FontWeight="Bold"/>
                            <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding LastExportPath}" Margin="0,6,0,0" Foreground="#A5D6A7" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="0,10,0,0"
                Background="#122038"
                BorderBrush="#2E4060"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,10,14,10">
            <DockPanel LastChildFill="False">
                <ProgressBar DockPanel.Dock="Left"
                             Width="360"
                             Height="16"
                             IsIndeterminate="{Binding IsBusy}"
                             VerticalAlignment="Center"
                             Margin="0,0,20,0"/>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="집계시작"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding StartAggregationCommand}"
                            Margin="0,0,10,0"/>
                    <Button Content="닫기"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="110"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>

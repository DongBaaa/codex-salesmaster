<Window x:Class="SalesMaster.Desktop.App.Views.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SalesMaster.Desktop.App.Converters"
        Title="상품재고 재고관리" Height="680" Width="1080"
        WindowStartupLocation="CenterOwner"
        Background="#151F2E" KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="CaretBrush" Value="Black"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Padding" Value="0,0,6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E2D40"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="RowBackground" Value="#1E2D40"/>
            <Setter Property="AlternatingRowBackground" Value="#243B55"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2B4A"/>
            <Setter Property="Foreground" Value="#4FC3F7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- 헤더 -->
        <Border DockPanel.Dock="Top" Background="#1A2B4A" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="상품/재고 관리 - 등록, 수정, 삭제 및 조회"
                               FontSize="14" FontWeight="Bold" Foreground="#4FC3F7"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCount, StringFormat=' (전체 {0}건)'}"
                               Foreground="#90CAF9" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="등록 (신규)" Background="#1B5E20" Margin="0,0,6,0"
                            Command="{Binding NewItemCommand}"/>
                    <Button Content="저장" Background="#0D47A1" Margin="0,0,6,0"
                            Command="{Binding SaveItemCommand}"/>
                    <Button Content="삭제" Background="#B71C1C" Margin="0,0,16,0"
                            Command="{Binding DeleteItemCommand}"/>
                    <Button Content="닫기 (F12)" Background="#37474F"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 상태 바 -->
        <Border DockPanel.Dock="Bottom" Background="#0D1B2A" Padding="12,4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#90CAF9"/>
        </Border>

        <!-- 검색 바 -->
        <Border DockPanel.Dock="Top" Background="#1A2B4A" Padding="8,5" BorderBrush="#2E4060" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="검색:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="200" Padding="6,4"/>
                <TextBlock Text="{Binding TotalCount, StringFormat=' 총 {0}건'}"
                           Foreground="#78909C" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- 좌우 분할 레이아웃 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽: 품목 목록 ─────────────────────────────────── -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding FilteredItems}"
                      SelectedItem="{Binding SelectedItem}"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="품목명" Binding="{Binding NameOriginal}" Width="*"/>
                    <DataGridTextColumn Header="규격" Binding="{Binding SpecificationOriginal}" Width="90"/>
                    <DataGridTextColumn Header="수량" Binding="{Binding CurrentStock, StringFormat=N0}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#0D1B2A" Cursor="SizeWE"/>

            <!-- ── 오른쪽: 상품 상세 입력폼 ──────────────────────── -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,10">

                    <!-- 품명 + 품목분류 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="품 명"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="White" Foreground="Black" FontWeight="Bold"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="품목분류"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding EditCategoryName, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="규 격"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditSpec, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="1" Grid.Column="2" Content="단 위"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding EditUnit, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="기본Box수량"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditBoxQty, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="보관위치"/>
                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding EditStorageLocation, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Separator Background="#2E4060" Margin="0,4"/>

                    <!-- 재고 현황 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="현재고"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditCurrentStock, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="안전재고"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding EditSafetyStock, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Box현재고"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding BoxCurrentStock, StringFormat=N0}"
                                   Foreground="#4FC3F7" FontWeight="Bold" Margin="6,0"/>
                        <Label Grid.Row="1" Grid.Column="2" Content="부재재고"/>
                        <TextBlock Grid.Row="1" Grid.Column="3"
                                   Text="{Binding ShortageStock, StringFormat=N0}"
                                   Foreground="#EF9A9A" Margin="6,0"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="자산금액"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding AssetValue, StringFormat=N0}"
                                   Foreground="#A5D6A7" FontWeight="Bold" Margin="6,0"/>
                    </Grid>

                    <Separator Background="#2E4060" Margin="0,4"/>

                    <!-- 단가 정보 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="65"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="매입단가"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditPurchasePrice, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="마지막구매"/>
                        <TextBlock Grid.Row="0" Grid.Column="3"
                                   Text="{Binding EditLastPurchaseDate}" Foreground="#90CAF9" Margin="6,0"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="매출단가"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditSalePrice, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="1" Grid.Column="2" Content="A단가"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding EditPriceA, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="소매단가"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditRetailPrice, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="2" Grid.Column="2" Content="B단가"/>
                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding EditPriceB, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="마지막판매"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding EditLastSaleDate}" Foreground="#90CAF9" Margin="6,0"/>
                        <Label Grid.Row="3" Grid.Column="2" Content="C단가"/>
                        <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding EditPriceC, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <Separator Background="#2E4060" Margin="0,4"/>

                    <!-- 간단메모 + 체크박스 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="간단메모"/>
                        <TextBox Grid.Column="1" Text="{Binding EditSimpleMemo, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Grid.Column="2" Orientation="Vertical" Margin="12,0,0,0">
                            <CheckBox Content="판매" IsChecked="{Binding EditIsSale}"
                                      Foreground="#E0E0E0" FontFamily="맑은 고딕"/>
                            <CheckBox Content="렌탈" IsChecked="{Binding EditIsRental}"
                                      Foreground="#E0E0E0" FontFamily="맑은 고딕" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>

<Window x:Class="SalesMaster.Desktop.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="코덱스 레거시 판매관리 - 로그인" Height="360" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1A2B4A">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
    <Grid>
        <StackPanel Margin="40" VerticalAlignment="Center">
            <TextBlock Text="코덱스 레거시 판매관리" FontSize="28" FontWeight="Bold"
                       Foreground="#4FC3F7" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="SalesMaster" FontSize="12" Foreground="#90CAF9"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="아이디" Foreground="#B0BEC5" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Background="White" Foreground="Black" BorderBrush="#4FC3F7"
                     Padding="8,6" FontSize="14" Margin="0,0,0,12"/>

            <TextBlock Text="비밀번호" Foreground="#B0BEC5" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox"
                         Background="White" Foreground="Black" BorderBrush="#4FC3F7"
                         Padding="8,6" FontSize="14" Margin="0,0,0,4"
                         PasswordChanged="PasswordBox_PasswordChanged"
                         KeyDown="PasswordBox_KeyDown"/>

            <StackPanel Orientation="Horizontal" Margin="0,6,0,2">
                <CheckBox Content="아이디 저장"
                          IsChecked="{Binding RememberUsername}"
                          Foreground="#B0BEC5"
                          Margin="0,0,14,0"/>
                <CheckBox Content="비밀번호 저장"
                          IsChecked="{Binding RememberPassword}"
                          Foreground="#B0BEC5"/>
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF9A9A"
                       FontSize="11" Margin="0,6,0,10" TextWrapping="Wrap"/>

            <Button Content="로그인" Command="{Binding LoginCommand}"
                    Background="#0D47A1" Foreground="White" FontSize="14" FontWeight="Bold"
                    Padding="0,10" BorderThickness="0" Cursor="Hand"/>

            <Button Content="오프라인 모드로 시작"
                    Command="{Binding OfflineLoginCommand}"
                    Visibility="{Binding ShowOfflineButton, Converter={StaticResource BoolToVisibility}}"
                    Background="#37474F" Foreground="#90CAF9" FontSize="12"
                    Padding="0,8" BorderThickness="0" Cursor="Hand" Margin="0,6,0,0"/>

            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>
    </Grid>
</Window>

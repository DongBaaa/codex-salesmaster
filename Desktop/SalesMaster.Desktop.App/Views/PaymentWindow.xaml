<Window x:Class="SalesMaster.Desktop.App.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SalesMaster.Desktop.App.Converters"
        Title="수금/지급 입력"
        Width="1000"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#151F2E"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B7C8DC"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ReadOnlyInfoTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Background" Value="#D5E1EF"/>
        </Style>
        <Style x:Key="NoteTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="Background" Value="#E6E6E6"/>
            <Setter Property="BorderBrush" Value="#8F8F8F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}"/>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#2D8DE0"/>
            <Setter Property="BorderBrush" Value="#2D8DE0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="MinWidth" Value="130"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#122038"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="#2E4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#162642"/>
            <Setter Property="AlternatingRowBackground" Value="#13213A"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="VerticalGridLinesBrush" Value="#2E4060"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="28"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#23395A"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#355172"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A2B4A"
                Padding="14,12"
                BorderBrush="#2E4060"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="수금/지급 입력"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="거래처별 수금·지급 내역 입력과 최근 처리기록 확인"
                               Foreground="#9FB3C8"
                               Margin="0,6,0,0"
                               FontSize="14"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="닫기(F12)"
                        Background="#E3E3E3"
                        Foreground="#111"
                        MinWidth="112"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#1A2B4A"
                    BorderBrush="#2E4060"
                    BorderThickness="1"
                    Padding="12"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="210"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="고객/거래처"/>
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="{Binding CustomerName}"
                            Background="#D9E6F5"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            FontWeight="Bold"
                            Foreground="Black"
                            Margin="0,0,14,8"
                            Click="CustomerSelectButton_Click"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="가격등급"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="3"
                             Style="{StaticResource ReadOnlyInfoTextBoxStyle}"
                             Text="{Binding CustomerCategory}"
                             Margin="0,0,0,8"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="대표전화"/>
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Style="{StaticResource ReadOnlyInfoTextBoxStyle}"
                             Text="{Binding CustomerPhone}"
                             Margin="0,0,14,0"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="담당자"/>
                    <TextBox Grid.Row="1"
                             Grid.Column="3"
                             Style="{StaticResource ReadOnlyInfoTextBoxStyle}"
                             Text="{Binding CustomerContactPerson}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#1A2B4A"
                        BorderBrush="#A43B3B"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="수금 처리내역"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FF6B6B"
                                   Margin="0,0,0,10"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="수금일자"/>
                            <DatePicker Grid.Row="0"
                                        Grid.Column="1"
                                        SelectedDate="{Binding ReceiptDate, Converter={StaticResource DateOnlyConverter}}"
                                        Margin="0,0,0,6"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="현금수금"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CashReceipt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="카드수금"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CardReceipt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <Label Grid.Row="3" Grid.Column="0" Content="통장수금"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding BankReceipt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <Label Grid.Row="4" Grid.Column="0" Content="D.C 해줌"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding DiscountApplied, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Border Grid.Row="2"
                                Margin="0,10,0,0"
                                Padding="12,10"
                                Background="#122038"
                                BorderBrush="#2E4060"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="수금결제"
                                           Foreground="#B7C8DC"
                                           FontSize="15"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ReceiptTotal, StringFormat={}{0:N0}}"
                                           FontWeight="Bold"
                                           FontSize="26"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="#1A2B4A"
                        BorderBrush="#3D58B5"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="지불 처리내역"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#6B86FF"
                                   Margin="0,0,0,10"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="지급일자"/>
                            <DatePicker Grid.Row="0"
                                        Grid.Column="1"
                                        SelectedDate="{Binding PaymentDate, Converter={StaticResource DateOnlyConverter}}"
                                        Margin="0,0,0,6"/>
                            <Label Grid.Row="1" Grid.Column="0" Content="현금지급"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CashPayment, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="카드지급"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CardPayment, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <Label Grid.Row="3" Grid.Column="0" Content="통장지급"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding BankPayment, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <Label Grid.Row="4" Grid.Column="0" Content="D.C 받음"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding DiscountReceived, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Border Grid.Row="2"
                                Margin="0,10,0,0"
                                Padding="12,10"
                                Background="#122038"
                                BorderBrush="#2E4060"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="지불결제"
                                           Foreground="#B7C8DC"
                                           FontSize="15"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PaymentTotal, StringFormat={}{0:N0}}"
                                           FontWeight="Bold"
                                           FontSize="26"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,12,0,0"
                    Background="#1A2B4A"
                    BorderBrush="#2E4060"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="거래내용"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Style="{StaticResource NoteTextBoxStyle}"
                             Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="전표메모"/>
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Style="{StaticResource NoteTextBoxStyle}"
                             Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Margin="0,12,0,0"
                    Background="#1A2B4A"
                    BorderBrush="#2E4060"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="최근 처리내역"
                                   Foreground="#90CAF9"
                                   FontWeight="Bold"
                                   FontSize="18"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedCustomer.NameOriginal, TargetNullValue=거래처를 선택하면 표시됩니다.}"
                                   Foreground="#8EA6C4"
                                   FontSize="13"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding History}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="일자" Binding="{Binding TransactionDate}" Width="100"/>
                            <DataGridTextColumn Header="수금합계" Binding="{Binding ReceiptTotal, StringFormat={}{0:N0}}" Width="110"/>
                            <DataGridTextColumn Header="지불합계" Binding="{Binding PaymentTotal, StringFormat={}{0:N0}}" Width="110"/>
                            <DataGridTextColumn Header="거래내용" Binding="{Binding Note}" Width="*"/>
                            <DataGridTextColumn Header="메모" Binding="{Binding Memo}" Width="1.1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#122038"
                Padding="12,10"
                BorderBrush="#2E4060"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="영수증인쇄"
                        MinWidth="120"
                        Margin="0,0,6,0"/>
                <Button Grid.Column="1"
                        Content="입금증인쇄"
                        MinWidth="120"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusMessage}"
                           Margin="16,0,0,0"
                           Foreground="#A5D6A7"
                           TextWrapping="Wrap"/>
                <Button Grid.Column="3"
                        Content="저장"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

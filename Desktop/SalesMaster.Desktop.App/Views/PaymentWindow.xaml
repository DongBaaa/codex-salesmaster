<Window x:Class="SalesMaster.Desktop.App.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SalesMaster.Desktop.App.Converters"
        Title="수금/지급 입력" Height="770" Width="760"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#151F2E" KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0C4DA"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Padding" Value="0,0,8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#D9E6F5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#4A6382"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="Background" Value="#E6E6E6"/>
            <Setter Property="BorderBrush" Value="#8F8F8F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A2B4A" Padding="12,10" BorderBrush="#2E4060" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="수금/지급 입력" Foreground="White" FontSize="32" FontWeight="Bold"/>
                <Button Grid.Column="1" Content="닫기(F12)" Background="#E3E3E3" Foreground="#111" Width="120" Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#122038" Padding="10" BorderBrush="#2E4060" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="영수증인쇄" Width="142" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="입금증인쇄" Width="142"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" Margin="14,0,0,0" Foreground="#1B5E20"/>
                <Button Grid.Column="3" Content="저장" Width="120" Command="{Binding SaveCommand}"/>
            </Grid>
        </Border>

        <StackPanel Margin="10,8">
            <Border Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="고객/거래처"/>
                    <Button Grid.Row="0" Grid.Column="1" Content="{Binding CustomerName}" Background="White" HorizontalAlignment="Stretch" FontWeight="Bold" Foreground="#1A237E" Click="CustomerSelectButton_Click"/>
                    <Label Grid.Row="0" Grid.Column="2" Content="고객분류"/>
                    <TextBox Grid.Row="0" Grid.Column="3" TextAlignment="Left"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="대표전화"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CustomerPhone}" TextAlignment="Left"/>
                    <Label Grid.Row="1" Grid.Column="2" Content="영업사원"/>
                    <TextBox Grid.Row="1" Grid.Column="3" TextAlignment="Left"/>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="10" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="수금처리내역" Foreground="Red" FontWeight="Bold" FontSize="30" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="수금일자"/>
                            <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding ReceiptDate, Converter={StaticResource DateOnlyConverter}}" Margin="0,0,0,6"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="현금수금"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CashReceipt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="카드수금"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CardReceipt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <Label Grid.Row="3" Grid.Column="0" Content="통장수금"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding BankReceipt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <Label Grid.Row="4" Grid.Column="0" Content="D.C 해줌"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding DiscountApplied, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Separator Margin="0,10,0,8" Background="#9A9A9A"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="수금결제"/>
                            <TextBlock Grid.Column="1" Text="{Binding ReceiptTotal, StringFormat=N0}" FontWeight="Bold" FontSize="24" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="10" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="지불처리내역" Foreground="Blue" FontWeight="Bold" FontSize="30" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="지급일자"/>
                            <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding PaymentDate, Converter={StaticResource DateOnlyConverter}}" Margin="0,0,0,6"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="현금지급"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CashPayment, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="카드지급"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CardPayment, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <Label Grid.Row="3" Grid.Column="0" Content="통장지급"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding BankPayment, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                            <Label Grid.Row="4" Grid.Column="0" Content="D.C 받음"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding DiscountReceived, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Separator Margin="0,10,0,8" Background="#9A9A9A"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="지불결제"/>
                            <TextBlock Grid.Column="1" Text="{Binding PaymentTotal, StringFormat=N0}" FontWeight="Bold" FontSize="24" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#1A2B4A" BorderBrush="#2E4060" BorderThickness="1" Padding="10" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="거래내용"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Left" Margin="0,0,0,8"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="전표메모"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Left"/>
                </Grid>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
